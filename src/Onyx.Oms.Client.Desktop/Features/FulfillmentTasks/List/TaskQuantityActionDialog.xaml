<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Onyx.Oms.Client.Desktop.Features.FulfillmentTasks.List.TaskQuantityActionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.FulfillmentTasks.List"
    Title="{x:Bind ActionTitle}"
    PrimaryButtonText="Confirm"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    Style="{StaticResource DefaultContentDialogStyle}">

    <StackPanel Spacing="12" Width="400">

        <Border Background="{ThemeResource LayerFillColorAltBrush}" 
                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" 
                BorderThickness="0" 
                CornerRadius="8" 
                Padding="12">

            <StackPanel Spacing="8">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Product" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind Task.ProductName}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Visibility="{x:Bind HasOrderNumber}">
                        <TextBlock Text="Order" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                        <TextBlock Text="{x:Bind Task.OrderNumber}" FontFamily="Consolas" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>

                <MenuFlyoutSeparator Margin="0,4"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Task Progress" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold">
                        <Run Text="{x:Bind Task.CompletedQuantity}" />
                        <Run Text=" / " Foreground="{ThemeResource TextFillColorDisabledBrush}" />
                        <Run Text="{x:Bind Task.RequestedQuantity}" />
                    </TextBlock>
                </Grid>

                <ProgressBar Minimum="0" Maximum="{x:Bind Task.RequestedQuantity}" Value="{x:Bind Task.CompletedQuantity}" />

            </StackPanel>

        </Border>

        <StackPanel Spacing="8">
            <TextBlock Text="{x:Bind ActionMessage}" Style="{StaticResource BodyTextBlockStyle}" />

            <NumberBox x:Name="InputBox" 
                       Value="{x:Bind InputValue, Mode=TwoWay}"
                       Minimum="1" 
                       Maximum="{x:Bind MaxAllowedQuantity}"
                       SpinButtonPlacementMode="Inline"
                       HorizontalAlignment="Stretch"
                       FontSize="20"
                       FontWeight="SemiBold"/>
        </StackPanel>

    </StackPanel>
</ContentDialog>
