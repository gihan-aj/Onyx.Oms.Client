<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Roles.RolesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Roles"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Roles" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,24" />

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Search Box -->
            <AutoSuggestBox PlaceholderText="Search roles..."
                            QueryIcon="Find"
                            Width="300"
                            HorizontalAlignment="Left"
                            Text="{x:Bind ViewModel.SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QuerySubmitted="OnQuerySubmitted" />

            <!-- Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.RefreshCommand}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Refresh" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button Style="{StaticResource AccentButtonStyle}" Click="OnNewClick">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Add" />
                            <TextBlock Text="New" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>

        <!-- DataGrid -->
        <toolkit:DataGrid Grid.Row="2"
                          ItemsSource="{x:Bind ViewModel.Roles, Mode=OneWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          CanUserSortColumns="True"
                          Sorting="OnDataGridSorting"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
            <toolkit:DataGrid.Columns>
                <toolkit:DataGridTextColumn Header="Name" Binding="{Binding Name}" Tag="name" Width="*" MinWidth="150" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" ElementStyle="{StaticResource LeftAlignedCellStyle}" />
                <toolkit:DataGridTextColumn Header="Description" Binding="{Binding Description}" Tag="description" Width="*" MinWidth="200" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" ElementStyle="{StaticResource LeftAlignedCellStyle}" />
                <toolkit:DataGridTextColumn Header="Permissions" Binding="{Binding PermissionCount}" Tag="permissionCount" Width="120" MinWidth="100" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}" />
                <toolkit:DataGridTextColumn Header="Users" Binding="{Binding UserCount}" Tag="userCount" Width="100" MinWidth="80" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}" />
                
                <toolkit:DataGridTemplateColumn Header="Status" Tag="isActive" Width="100" MinWidth="100" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StatusBadgeStyle}" 
                                    Background="{Binding IsActive, Converter={StaticResource StatusBackgroundConverter}}">
                                <TextBlock Text="{Binding IsActive, Converter={StaticResource StatusTextConverter}}"
                                           Style="{StaticResource StatusBadgeTextStyle}"
                                           Foreground="{Binding IsActive, Converter={StaticResource StatusForegroundConverter}}" />
                            </Border>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>

                <toolkit:DataGridTemplateColumn Header="Actions" Width="150" MinWidth="150" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="local:RoleDto">
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                <Button Content="&#xE73E;" FontFamily="Segoe MDL2 Assets" ToolTipService.ToolTip="Activate" Style="{StaticResource SubtleButtonStyle}" Click="OnActivateClick"
                                        Visibility="{x:Bind IsActive, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" ToolTipService.ToolTip="Deactivate" Style="{StaticResource SubtleButtonStyle}" Click="OnDeactivateClick"
                                        Visibility="{x:Bind IsActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <AppBarSeparator />
                                <Button Content="&#xE70F;" FontFamily="Segoe MDL2 Assets" ToolTipService.ToolTip="Edit" Style="{StaticResource SubtleButtonStyle}" Click="OnEditClick" />
                                <AppBarSeparator />
                                <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" ToolTipService.ToolTip="Delete" Style="{StaticResource SubtleButtonStyle}" Foreground="Red" Click="OnDeleteClick" />
                            </StackPanel>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>
            </toolkit:DataGrid.Columns>
        </toolkit:DataGrid>

        <!-- No Data Message -->
        <StackPanel Grid.Row="2"
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Spacing="16"
                    Visibility="{x:Bind ViewModel.HasNoData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <SymbolIcon Symbol="ContactInfo" RenderTransformOrigin="0.5,0.5">
                <SymbolIcon.RenderTransform>
                    <ScaleTransform ScaleX="2" ScaleY="2" />
                </SymbolIcon.RenderTransform>
            </SymbolIcon>
            <TextBlock HorizontalAlignment="Center" Text="No roles found." Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock HorizontalAlignment="Center" Text="Try adjusting your search or add a new role." Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Loading Indicator -->
        <ProgressRing Grid.Row="2" 
                      IsActive="{x:Bind ViewModel.IsListLoading, Mode=OneWay}" 
                      Width="50" Height="50" 
                      HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- Pagination -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Rows Per Page (Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Rows per page:" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" />
                <ComboBox ItemsSource="{x:Bind ViewModel.PageSizes}" 
                          SelectedItem="{x:Bind ViewModel.PageSize, Mode=TwoWay}"
                          Width="80" />
            </StackPanel>

            <!-- Page Summary (Center) -->
            <TextBlock Grid.Column="1" 
                       Text="{x:Bind ViewModel.PageSummary, Mode=OneWay}" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       Style="{StaticResource CaptionTextBlockStyle}" />

            <!-- Navigation Buttons (Right) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16">
                <Button Content="Previous" Command="{x:Bind ViewModel.PreviousPageCommand}" IsEnabled="{x:Bind ViewModel.HasPreviousPage, Mode=OneWay}" />
                <Button Content="Next" Command="{x:Bind ViewModel.NextPageCommand}" IsEnabled="{x:Bind ViewModel.HasNextPage, Mode=OneWay}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
