<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Onyx.Oms.Client.Desktop.Features.Orders.ShippingConfirmationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    Title="Ship Order"
    PrimaryButtonText="Mark as Shipped"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind CanShip, Mode=OneWay}"
    Style="{StaticResource DefaultContentDialogStyle}">

    <ContentDialog.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
    </ContentDialog.Resources>

    <StackPanel Spacing="16" Width="400">

        <!-- Warning Banner (Only visible if missing Courier or Address) -->
        <InfoBar IsOpen="{x:Bind HasMissingInfo, Mode=OneWay}"
             Severity="Warning"
             Title="Action Required"
             Message="You must assign a Courier and a Shipping Address in the Logistics section before shipping this order."
             IsClosable="False" />
        <Grid ColumnSpacing="16" RowSpacing="16" Margin="0,8,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Courier Details -->
            <FontIcon Grid.Row="0" Grid.Column="0" Glyph="&#xE825;" FontSize="20" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top" Margin="0,2,0,0"/>
            <StackPanel Grid.Row="0" Grid.Column="1">
                <TextBlock Text="Courier" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="{x:Bind CourierName, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" 
                       Visibility="{x:Bind HasCourier, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <!-- Fallback text if missing -->
                <TextBlock Text="Not Assigned" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemFillColorCautionBrush}"
                       Visibility="{x:Bind HasCourier, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
            </StackPanel>
            <!-- Shipping Address Details -->
            <FontIcon Grid.Row="1" Grid.Column="0" Glyph="&#xE707;" FontSize="20" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top" Margin="0,2,0,0"/>
            <StackPanel Grid.Row="1" Grid.Column="1">
                <TextBlock Text="Shipping Address" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="{x:Bind ShippingAddress, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap"
                       Visibility="{x:Bind HasAddress, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <!-- Fallback text if missing -->
                <TextBlock Text="Not Assigned" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemFillColorCautionBrush}"
                       Visibility="{x:Bind HasAddress, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
        <!-- Tracking Number Input (Disabled if they can't ship) -->
        <TextBox Header="Tracking Number (Optional)" 
             Text="{x:Bind TrackingNumber, Mode=TwoWay}"
             PlaceholderText="e.g. TRK-123456789"
             IsEnabled="{x:Bind CanShip, Mode=OneWay}" />

    </StackPanel>
</ContentDialog>
