<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Roles.RoleFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Roles"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:NullToTrueConverter x:Key="NullToTrueConverter" />
        <local:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:EmptyStringToObjectConverter x:Key="StringToVisibilityConverter" EmptyValue="Collapsed" NotEmptyValue="Visible" />

        <DataTemplate x:Key="FolderTemplate" x:DataType="local:PermissionTreeItemViewModel">
            <TreeViewItem ItemsSource="{x:Bind Children}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <CheckBox IsThreeState="{x:Bind Value, Converter={StaticResource NullToTrueConverter}}" 
                              IsChecked="{x:Bind IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                              IsEnabled="{x:Bind IsNotReadOnly, Mode=OneWay}"
                              Content="{x:Bind Name}" 
                              Margin="0,0,0,0" />
                </StackPanel>
            </TreeViewItem>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="24">
            <!-- Form Center Card Setup -->
            <Border MaxWidth="600" 
                    MinWidth="600"
                    VerticalAlignment="Top" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    Padding="32"
                    HorizontalAlignment="Center">
                    
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ProgressRing Grid.Row="0" Grid.RowSpan="7" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center" Canvas.ZIndex="10" />

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="{x:Bind ViewModel.Title, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,24" />

                    <!-- Name Field -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <TextBox Header="Name" Text="{x:Bind ViewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 IsReadOnly="{x:Bind ViewModel.IsReadOnly, Mode=OneWay}"
                                 IsEnabled="{x:Bind ViewModel.IsLoading, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}"/>
                        <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}" 
                                   Text="{x:Bind ViewModel.NameError, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.NameError, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"
                                   Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Description Field -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,16">
                        <TextBox Header="Description" Text="{x:Bind ViewModel.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" 
                                 IsReadOnly="{x:Bind ViewModel.IsReadOnly, Mode=OneWay}"
                                 IsEnabled="{x:Bind ViewModel.IsLoading, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}"/>
                        <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}" 
                                   Text="{x:Bind ViewModel.DescriptionError, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.DescriptionError, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"
                                   Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Permissions Header -->
                    <TextBlock Grid.Row="3" Text="Permissions" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />

                    <!-- TreeView for Permissions -->
                    <Border Grid.Row="4" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="8" MaxHeight="400">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TreeView ItemsSource="{x:Bind ViewModel.PermissionGroups, Mode=OneWay}" 
                                      ItemTemplate="{StaticResource FolderTemplate}" 
                                      SelectionMode="None" 
                                      IsEnabled="{x:Bind ViewModel.IsLoading, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}">
                            </TreeView>
                        </ScrollViewer>
                    </Border>

                    <!-- Buttons Area -->
                    <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,32,0,0">
                        <Button Content="Cancel" Command="{x:Bind ViewModel.CancelCommand}" Style="{StaticResource SubtleButtonStyle}" />
                        <Button Content="Save" Command="{x:Bind ViewModel.SaveCommand}" Style="{StaticResource AccentButtonStyle}" 
                                Visibility="{x:Bind ViewModel.IsNotReadOnly, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
