<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Onyx.Oms.Client.Desktop.Features.Roles.RoleDetailsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Roles"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d"
    Title="Role Details"
    CloseButtonText="Close"
    DefaultButton="Close"
    CornerRadius="8"
    CloseButtonStyle="{StaticResource AccentButtonStyle}">

    <ContentDialog.Resources>
        <converters:EmptyStringToObjectConverter x:Key="StringToVisibilityConverter" EmptyValue="Collapsed" NotEmptyValue="Visible" />
    </ContentDialog.Resources>

    <StackPanel Spacing="16" MinWidth="400" MaxWidth="500" MaxHeight="600">
        <!-- Status Badge -->
        <Border Style="{StaticResource StatusBadgeStyle}" 
                Background="{x:Bind Role.IsActive, Mode=OneTime, Converter={StaticResource StatusBackgroundConverter}}"
                HorizontalAlignment="Left">
            <TextBlock Text="{x:Bind Role.IsActive, Mode=OneTime, Converter={StaticResource StatusTextConverter}}"
                       Style="{StaticResource StatusBadgeTextStyle}"
                       Foreground="{x:Bind Role.IsActive, Mode=OneTime, Converter={StaticResource StatusForegroundConverter}}" />
        </Border>

        <Grid RowSpacing="12" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Name:" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Top" />
            <TextBlock Grid.Column="1" Text="{x:Bind Role.Name, Mode=OneTime}" TextWrapping="Wrap" />

            <TextBlock Grid.Row="1" Text="Description:" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Top" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind Role.Description, Mode=OneTime}" TextWrapping="Wrap" />
        </Grid>

        <TextBlock Text="Assigned Permissions" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
        
        <!-- Grouped Permissions -->
        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="12" MaxHeight="300">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{x:Bind GroupedPermissions, Mode=OneTime}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:PermissionDisplayGroup">
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="{x:Bind GroupName}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource SystemControlForegroundAccentBrush}" Margin="0,0,0,8" />
                                
                                <GridView ItemsSource="{x:Bind Permissions}" SelectionMode="None" IsItemClickEnabled="False" >
                                    <GridView.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Border Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="8,4"
                                                    Margin="0,0,8,8">
                                                <TextBlock Text="{x:Bind}" Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Border>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </StackPanel>
</ContentDialog>
