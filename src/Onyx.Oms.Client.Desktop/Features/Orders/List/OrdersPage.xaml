<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Orders.List.OrdersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Orders.List"
    xmlns:parent="using:Onyx.Oms.Client.Desktop.Features.Orders"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Row: Title, Search, Actions -->
        <Grid Grid.Row="0" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                   Text="Orders" 
                   Style="{StaticResource SubtitleTextBlockStyle}" 
                   VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0"/>

            <AutoSuggestBox Grid.Column="1"
                        PlaceholderText="Search orders by number..."
                        QueryIcon="Find"
                        Width="320"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        QuerySubmitted="AutoSuggestBox_QuerySubmitted"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Style="{StaticResource SubtleButtonStyle}" ToolTipService.ToolTip="Refresh Data"
                    Command="{x:Bind ViewModel.RefreshCommand}">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                </Button>

                <AppBarSeparator/>

                <DropDownButton Style="{StaticResource AccentButtonStyle}" 
                                Background="Transparent" 
                                BorderThickness="1" 
                                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                    <DropDownButton.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE712;" FontSize="14" />
                            <TextBlock Text="More Actions" />
                        </StackPanel>
                    </DropDownButton.Content>
                    <DropDownButton.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Bulk Print Shipping Labels"
                                            Command="{x:Bind ViewModel.BulkPrintShippingLabelsCommand}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE896;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>

                <Button Style="{StaticResource AccentButtonStyle}" 
                    Command="{x:Bind ViewModel.NewOrderCommand}"
                    IsEnabled="{x:Bind ViewModel.CanCreateOrders}"
                    Visibility="{x:Bind ViewModel.CanCreateOrders, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="New Order" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>

        <!-- SelectorBar -->
        <Grid Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="16,0,16,12">
            <SelectorBar x:Name="TabSelectorBar" SelectionChanged="SelectorBar_SelectionChanged" >
                <SelectorBarItem Text="{x:Bind ViewModel.AllActiveTabText, Mode=OneWay}" Tag="All" IsSelected="True" FontWeight="Bold"/>
                <SelectorBarItem Text="{x:Bind ViewModel.PendingTabText, Mode=OneWay}" Tag="Pending" FontWeight="Bold"/>
                <SelectorBarItem Text="{x:Bind ViewModel.ProcessingTabText, Mode=OneWay}" Tag="Processing" FontWeight="Bold"/>
                <SelectorBarItem Text="{x:Bind ViewModel.ReadyToPackTabText, Mode=OneWay}" Tag="ReadyToPack" FontWeight="Bold"/>
                <SelectorBarItem Text="{x:Bind ViewModel.PackedTabText, Mode=OneWay}" Tag="Packed" FontWeight="Bold"/>
                <SelectorBarItem Text="{x:Bind ViewModel.HistoricalTabText, Mode=OneWay}" Tag="Historical" FontWeight="Bold"/>
            </SelectorBar>
        </Grid>

        <!-- Status Chips (Only visible for All Active) -->
        <Grid Grid.Row="2" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="16,0,16,12"
              Visibility="{x:Bind IsAllActiveTab(ViewModel.SelectedTab), Mode=OneWay}">
            <ItemsControl ItemsSource="{x:Bind ViewModel.StatusChips, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <labs:WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:StatusChipViewModel">
                        <ToggleButton Content="{x:Bind DisplayName}" 
                                      IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                      CornerRadius="16" Margin="4"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        <!--<Grid Grid.Row="2" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="16,0,16,12"
              Visibility="{x:Bind IsAllActiveTab(ViewModel.SelectedTab), Mode=OneWay}">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.StatusChips, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal" Spacing="8" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="local:StatusChipViewModel">
                        <ToggleButton Content="{x:Bind DisplayName}" 
                                      IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                      CornerRadius="16" />
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </Grid>-->

        <!-- Filters -->
        <Grid Grid.Row="3" Padding="16,0,16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="16" Padding="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="From Date" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <CalendarDatePicker Date="{x:Bind ViewModel.FromDate, Mode=TwoWay}" Width="140"/>
                    </StackPanel>
                    
                    <StackPanel>
                        <TextBlock Text="To Date" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <CalendarDatePicker Date="{x:Bind ViewModel.ToDate, Mode=TwoWay}" Width="140"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Customer" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <parent:CustomerPicker x:Name="CustomerPicker"
                                          Width="200"
                                          SelectedCustomer="{x:Bind ViewModel.SelectedCustomer, Mode=TwoWay}"
                                          PlaceholderText="Select Customer"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Courier" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.Couriers}"
                              SelectedItem="{x:Bind ViewModel.SelectedCourier, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              PlaceholderText="Select Courier"
                              Width="180"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Payment Status" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.PaymentStatusOptions}"
                              SelectedItem="{x:Bind ViewModel.SelectedPaymentStatus, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              Width="180"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="COD" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.IsCodOptions}"
                              SelectedItem="{x:Bind ViewModel.SelectedIsCod, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              Width="90"/>
                    </StackPanel>

                    <Button Content="Clear" Style="{StaticResource SubtleButtonStyle}" VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.ClearFiltersCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <ProgressBar Grid.Row="3" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" 
             IsIndeterminate="True" 
             Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" 
             Canvas.ZIndex="100" />

        <!-- DataGrid Constraints Wrapper -->
        <Grid Grid.Row="4" x:Name="TableContainer">

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Enabled"
                      VerticalScrollBarVisibility="Disabled"
                      VerticalScrollMode="Disabled">

                <toolkit:DataGrid x:Name="OrdersDataGrid"
                              Width="{Binding ActualWidth, ElementName=TableContainer}"
                              MinWidth="1180"
                              ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              CanUserSortColumns="True"
                              Sorting="OrdersDataGrid_Sorting"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Hidden"
                              BorderThickness="0"
                              RowBackground="Transparent"
                              AlternatingRowBackground="{ThemeResource LayerFillColorDefaultBrush}">

                    <toolkit:DataGrid.RowStyle>
                        <Style TargetType="toolkit:DataGridRow">
                            <Setter Property="ContextFlyout">
                                <Setter.Value>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Manage Order" Click="ManageMenuItem_Click" IsEnabled="{Binding CanEdit}">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE70F;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                        <MenuFlyoutItem Text="{Binding DownloadInvoiceText}" Click="DownloadInvoiceMenuItem_Click"
                                                        Visibility="{Binding CanDownloadInvoice, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE896;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                        <MenuFlyoutItem Text="Send Order Status" Click="SendOrderStatusMenuItem_Click"
                                                        Visibility="{Binding CanDownloadInvoice, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE724;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                        <MenuFlyoutItem Text="Shipping Label" Click="DownloadShippingLabelMenuItem_Click"
                                                        Visibility="{Binding CanDownloadShippingLabel, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE896;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                        <MenuFlyoutSeparator Visibility="{Binding CanConfirm, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        
                                        <MenuFlyoutItem Text="Confirm" Click="ConfirmMenuItem_Click" Visibility="{Binding CanConfirm, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8FB;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                        <MenuFlyoutItem Text="Cancel" Click="CancelMenuItem_Click" Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE711;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                        <MenuFlyoutSeparator Visibility="{Binding CanProgress, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        
                                        <MenuFlyoutItem Text="Pack" Click="PackMenuItem_Click" Visibility="{Binding CanPack, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7B8;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                        <MenuFlyoutItem Text="Ship" Click="ShipMenuItem_Click" Visibility="{Binding CanShip, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE724;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                        <MenuFlyoutItem Text="Deliver" Click="DeliverMenuItem_Click" Visibility="{Binding CanDeliver, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE707;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                        <MenuFlyoutItem Text="Complete" Click="CompleteMenuItem_Click" Visibility="{Binding CanComplete, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE930;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                        <MenuFlyoutItem Text="Fail Delivery" Click="FailDeliveryMenuItem_Click" Visibility="{Binding CanFailDelivery, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7BA;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                        <MenuFlyoutItem Text="Receive Return" Click="ReceiveReturnMenuItem_Click" Visibility="{Binding CanReceiveReturn, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE8B5;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        
                                        <MenuFlyoutItem Text="Process Return" Click="ProcessReturnMenuItem_Click" Visibility="{Binding CanProcessReturn, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE8D5;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </toolkit:DataGrid.RowStyle>

                    <toolkit:DataGrid.Columns>

                        <!-- Order Number -->
                        <toolkit:DataGridTextColumn Header="Order #" 
                                            Binding="{Binding OrderNumber}" Tag="orderNumber" 
                                            Width="Auto" MinWidth="120" 
                                            FontWeight="SemiBold"
                                            HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" 
                                            ElementStyle="{StaticResource LeftAlignedCellStyle}" />

                        <!-- Date -->
                        <toolkit:DataGridTextColumn Header="Date" 
                                            Binding="{Binding OrderDateDisplay}" Tag="orderDate" 
                                            Width="Auto" MinWidth="160" 
                                            HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" 
                                            ElementStyle="{StaticResource LeftAlignedCellStyle}" />

                        <!-- Customer -->
                        <toolkit:DataGridTemplateColumn Header="Customer" Tag="customerName" Width="*" MinWidth="200" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}">
                            <toolkit:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="local:OrderGridItem">
                                    <StackPanel VerticalAlignment="Center" Margin="12,4">
                                        <TextBlock Text="{x:Bind CustomerName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind CustomerDisplay, TargetNullValue=''}" FontSize="12" IsTextSelectionEnabled="True" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </toolkit:DataGridTemplateColumn.CellTemplate>
                        </toolkit:DataGridTemplateColumn>

                        <!-- Status -->
                        <toolkit:DataGridTemplateColumn Header="Status" Tag="status" Width="140" MinWidth="140" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                            <toolkit:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="local:OrderGridItem">
                                    <Border Style="{StaticResource StatusBadgeStyle}" 
                                            HorizontalAlignment="Center"
                                            Background="{x:Bind Status, Converter={StaticResource OrderStatusBackgroundConverter}}">
                                        <TextBlock Text="{x:Bind Status, Mode=OneWay}"
                                                   Style="{StaticResource StatusBadgeTextStyle}"
                                                   Foreground="{x:Bind Status, Converter={StaticResource OrderStatusForegroundConverter}}" />
                                    </Border>
                                </DataTemplate>
                            </toolkit:DataGridTemplateColumn.CellTemplate>
                        </toolkit:DataGridTemplateColumn>

                        <!-- Payment Status -->
                        <toolkit:DataGridTemplateColumn Header="Payment" Tag="paymentStatus" Width="140" MinWidth="140" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                            <toolkit:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="local:OrderGridItem">
                                    <Border Style="{StaticResource StatusBadgeStyle}" 
                                            HorizontalAlignment="Center"
                                            Background="{x:Bind PaymentStatus, Converter={StaticResource PaymentStatusBackgroundConverter}}">
                                        <TextBlock Text="{x:Bind PaymentStatus, Mode=OneWay}"
                                                   Style="{StaticResource StatusBadgeTextStyle}"
                                                   Foreground="{x:Bind PaymentStatus, Converter={StaticResource PaymentStatusForegroundConverter}}" />
                                    </Border>
                                </DataTemplate>
                            </toolkit:DataGridTemplateColumn.CellTemplate>
                        </toolkit:DataGridTemplateColumn>

                        <!-- Total -->
                        <toolkit:DataGridTextColumn Header="Total" 
                                            Binding="{Binding GrandTotalDisplay}" Tag="grandTotalAmount" 
                                            Width="Auto" MinWidth="150" 
                                            HeaderStyle="{StaticResource RightAlignedHeaderStyle}" 
                                            ElementStyle="{StaticResource RightAlignedCellStyle}" />

                        <!-- Row Actions -->
                        <toolkit:DataGridTemplateColumn Width="80" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                            <toolkit:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="local:OrderGridItem">
                                    <Button Style="{StaticResource SubtleButtonStyle}" 
                                    Background="Transparent"
                                    HorizontalAlignment="Stretch" 
                                    VerticalAlignment="Stretch"
                                    ToolTipService.ToolTip="Actions"
                                    Tapped="OnActionButtonTapped">

                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE712;" />

                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Manage Order" Click="ManageMenuItem_Click" IsEnabled="{x:Bind CanEdit}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE70F;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutItem Text="{x:Bind DownloadInvoiceText}" Click="DownloadInvoiceMenuItem_Click"
                                                                Visibility="{x:Bind CanDownloadInvoice, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE896;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                
                                                <MenuFlyoutItem Text="Send Order Status" Click="SendOrderStatusMenuItem_Click"
                                                                Visibility="{x:Bind CanDownloadInvoice, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE724;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                
                                                <MenuFlyoutItem Text="Shipping Label" Click="DownloadShippingLabelMenuItem_Click"
                                                                Visibility="{x:Bind CanDownloadShippingLabel, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE896;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutSeparator Visibility="{x:Bind CanConfirm, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <MenuFlyoutItem Text="Confirm" Click="ConfirmMenuItem_Click" Visibility="{x:Bind CanConfirm, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8FB;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutItem Text="Cancel" Click="CancelMenuItem_Click" Visibility="{x:Bind CanCancel, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE711;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutSeparator Visibility="{x:Bind CanProgress, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                
                                                <MenuFlyoutItem Text="Pack" Click="PackMenuItem_Click" Visibility="{x:Bind CanPack, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7B8;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutItem Text="Ship" Click="ShipMenuItem_Click" Visibility="{x:Bind CanShip, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE724;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutItem Text="Deliver" Click="DeliverMenuItem_Click" Visibility="{x:Bind CanDeliver, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE707;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutItem Text="Complete" Click="CompleteMenuItem_Click" Visibility="{x:Bind CanComplete, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE930;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutItem Text="Fail Delivery" Click="FailDeliveryMenuItem_Click" Visibility="{x:Bind CanFailDelivery, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7BA;"/></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutItem Text="Receive Return" Click="ReceiveReturnMenuItem_Click" Visibility="{x:Bind CanReceiveReturn, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE8B5;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutItem Text="Process Return" Click="ProcessReturnMenuItem_Click" Visibility="{x:Bind CanProcessReturn, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE8D5;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </DataTemplate>
                            </toolkit:DataGridTemplateColumn.CellTemplate>
                        </toolkit:DataGridTemplateColumn>

                    </toolkit:DataGrid.Columns>

                </toolkit:DataGrid>
            </ScrollViewer>

            <!-- Loading Indicator -->
            <Grid Opacity="0.8" 
              Visibility="{x:Bind ViewModel.IsListLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ProgressRing IsActive="True" Width="48" Height="48" />
            </Grid>

            <!-- No Data Message -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                    Visibility="{x:Bind ViewModel.HasNoData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <FontIcon Glyph="&#xE719;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock HorizontalAlignment="Center" Text="No orders found." 
                       Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Content="Clear Filters" 
                    Command="{x:Bind ViewModel.ClearFiltersCommand}" 
                    Style="{StaticResource DefaultButtonStyle}" 
                    HorizontalAlignment="Center"/>
            </StackPanel>

        </Grid>

        <!-- Pagination -->
        <Grid Grid.Row="5"
          Background="{ThemeResource LayerFillColorDefaultBrush}"
          Padding="16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Rows Per Page (Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Rows per page:" VerticalAlignment="Center" 
                       Style="{StaticResource CaptionTextBlockStyle}" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.PageSizes}" 
                      SelectedItem="{x:Bind ViewModel.PageSize, Mode=TwoWay}"
                      Style="{StaticResource DefaultComboBoxStyle}"
                      MinWidth="80" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Page Summary (Center) -->
            <TextBlock Grid.Column="1" 
                   Text="{x:Bind ViewModel.PageSummary, Mode=OneWay}" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center" 
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Style="{StaticResource CaptionTextBlockStyle}" />

            <!-- Navigation Buttons (Right) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button Style="{StaticResource SubtleButtonStyle}" 
                    Command="{x:Bind ViewModel.PreviousPageCommand}" 
                    IsEnabled="{x:Bind ViewModel.HasPreviousPage, Mode=OneWay}" 
                    ToolTipService.ToolTip="Previous Page">
                    <FontIcon Glyph="&#xE76B;" FontSize="12" />
                </Button>
                <Button Style="{StaticResource SubtleButtonStyle}" 
                    Command="{x:Bind ViewModel.NextPageCommand}" 
                    IsEnabled="{x:Bind ViewModel.HasNextPage, Mode=OneWay}" 
                    ToolTipService.ToolTip="Next Page">
                    <FontIcon Glyph="&#xE76C;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
