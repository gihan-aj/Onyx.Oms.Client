<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Onyx.Oms.Client.Desktop.Features.Orders.CustomerPicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Orders"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- Trigger button -->
        <Button x:Name="PickerButton"
                Click="PickerButton_Click"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                ToolTipService.ToolTip="{x:Bind SelectedCustomer.Name, Mode=OneWay, FallbackValue='', TargetNullValue=''}">
            <Button.Content>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock x:Name="HeaderButtonText" 
                               Text="{x:Bind PlaceholderText, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis"/>
                    <FontIcon Grid.Column="1" 
                              FontFamily="Segoe MDL2 Assets" 
                              Glyph="&#xE70D;" 
                              FontSize="12" 
                              Margin="8,0,0,0" />
                </Grid>
            </Button.Content>

            <Button.Flyout>
                <Flyout Placement="Bottom"
                        Opened="Flyout_Opened"
                        Closed="Flyout_Closed">
                    <Flyout.FlyoutPresenterStyle>
                        <Style TargetType="FlyoutPresenter">
                            <Setter Property="MaxWidth" Value="10000" />
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Flyout.FlyoutPresenterStyle>
                    <Grid x:Name="FlyoutRootGrid" MaxHeight="300">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Search Box -->
                        <TextBox x:Name="SearchBox"
                                 PlaceholderText="Search customers..."
                                 TextChanged="SearchBox_TextChanged"
                                 Margin="0,0,0,8"/>

                        <ProgressBar x:Name="LoadingProgressBar" 
                                     Grid.Row="1"
                                     IsIndeterminate="True"
                                     Visibility="Collapsed"/>

                        <!-- List -->
                        <ListView x:Name="ItemsListView"
                                  Grid.Row="2"
                                  ItemsSource="{x:Bind Items, Mode=OneWay}"
                                  SelectionMode="Single"
                                  SelectionChanged="ItemsListView_SelectionChanged"
                                  Loaded="ItemsListView_Loaded"
                                  Unloaded="ItemsListView_Unloaded">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:CustomerDto">
                                    <StackPanel Margin="0,8" ToolTipService.ToolTip="{x:Bind Name}">
                                        <TextBlock Text="{x:Bind Name, TargetNullValue='Unnamed'}" 
                                                   FontWeight="SemiBold" 
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind PrimaryPhone, TargetNullValue=''}" 
                                                       FontSize="12" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Address}" 
                                                       FontSize="12" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        
                        <!-- No Items -->
                        <StackPanel x:Name="NoItemsTextBlock" Grid.Row="2" Margin="8,8,16,0" Visibility="Collapsed">
                            <TextBlock Text="No customers found." 
                                       FontSize="14" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Flyout>
            </Button.Flyout>
        </Button>

    </Grid>
</UserControl>
