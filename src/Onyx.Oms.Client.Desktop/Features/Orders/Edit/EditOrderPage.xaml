<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Orders.Edit.EditOrderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Orders.Edit"
    xmlns:parent="using:Onyx.Oms.Client.Desktop.Features.Orders"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:sharedConverters="using:Onyx.Oms.Client.Desktop.Shared.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
        <converters:EmptyObjectToObjectConverter x:Key="NullToVisibilityConverter" EmptyValue="Visible" NotEmptyValue="Collapsed" />
        <converters:EmptyObjectToObjectConverter x:Key="InvertedNullToVisibilityConverter" EmptyValue="Collapsed" NotEmptyValue="Visible" />
        <converters:EmptyCollectionToObjectConverter x:Key="EmptyListToVisibiltyConverter" EmptyValue="Visible" NotEmptyValue="Collapsed" />
        <sharedConverters:DecimalToDoubleConverter x:Key="DecimalToDoubleConverter" />
        <sharedConverters:StringListConverter x:Key="StringListConverter" />
        <sharedConverters:StringToBoolConverter x:Key="StringToBoolConverter" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Sticky Header with Back Button -->
        <Grid Grid.Row="0" Padding="24,16"
              Background="{ThemeResource LayerFillColorDefaultBrush}">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{x:Bind ViewModel.GoBackCommand}" 
                    Style="{StaticResource SubtleButtonStyle}" Margin="0,0,16,0">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>

            <TextBlock Grid.Column="1" 
                       Text="{x:Bind ViewModel.PageTitle, Mode=OneWay}" 
                       Style="{StaticResource SubtitleTextBlockStyle}" 
                       FontWeight="SemiBold" VerticalAlignment="Center" />

        </Grid>

        <ProgressBar Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" 
                     IsIndeterminate="True" 
                     Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" 
                     Canvas.ZIndex="100" />

        <!-- Scrollable Body -->
        <ScrollViewer Grid.Row="1" 
                      Padding="16" 
                      VerticalScrollBarVisibility="Auto" 
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10000*" MaxWidth="1200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" Spacing="16">

                    <Grid ColumnSpacing="12">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" MinWidth="350" />
                            <ColumnDefinition Width="2*" MinWidth="350" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="12">

                            <!-- Customer Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Customer Details" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Customer cannot be edited." 
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               Margin="0,0,0,12" />
                                </StackPanel>

                                <!-- Customer Details Display -->
                                <StackPanel Visibility="{x:Bind ViewModel.HasCustomerDetails, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="{ThemeResource LayerFillColorAltBrush}"
                                            Padding="16" CornerRadius="8" Margin="0,12,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Glyph="&#xE77B;" FontSize="32" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind ViewModel.CustomerDetails.Name, Mode=OneWay, TargetNullValue='', FallbackValue=''}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon Glyph="&#xE717;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.CustomerDetails.PrimaryPhone, Mode=OneWay, TargetNullValue='', FallbackValue=''}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{x:Bind ViewModel.CustomerDetails.HasEmail, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <FontIcon Glyph="&#xE715;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.CustomerDetails.Email, Mode=OneWay, TargetNullValue='', FallbackValue=''}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                            </StackPanel>

                            <!-- Products Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Items" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="Select products or product variants and required quantities." 
                                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <CommandBar Grid.Column="1" 
                                                Background="Transparent" 
                                                IsOpen="False" 
                                                DefaultLabelPosition="Right" 
                                                IsSticky="True">
                                        
                                        <AppBarButton Icon="Edit" Label="Edit" 
                                                      Visibility="{x:Bind ViewModel.OrderItems.CanModifyCart, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.OrderItems.BeginEditCommand, Mode=OneWay}" />
                                        
                                        <AppBarButton Icon="Add" Label="Add" 
                                                      ToolTipService.ToolTip="Add an item" 
                                                      Visibility="{x:Bind ViewModel.OrderItems.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.OrderItems.ShowProductPickerCommand, Mode=OneWay}" />

                                        <AppBarButton Icon="Save" Label="Save" 
                                                      AllowFocusOnInteraction="True"
                                                      Visibility="{x:Bind ViewModel.OrderItems.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.UpdateOrderItemsCommand}" />

                                        <AppBarButton Icon="Cancel" Label="Cancel" 
                                                      Visibility="{x:Bind ViewModel.OrderItems.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.OrderItems.CancelEditCommand, Mode=OneWay}" />

                                    </CommandBar>
                                </Grid>

                                <!-- READONLY MODE -->
                                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.OrderItems.IsReadonly, Mode=OneWay}">

                                    <ItemsControl ItemsSource="{x:Bind ViewModel.OrderItems.Items, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:EditOrderLineItem">

                                                <Grid Background="{ThemeResource LayerFillColorAltBrush}"
                                                      CornerRadius="8" 
                                                      Padding="12" Margin="0,0,0,8">

                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="64" />
                                                        <ColumnDefinition Width="*" MinWidth="150" />
                                                        <ColumnDefinition Width="Auto" MinWidth="120" />
                                                        <ColumnDefinition Width="Auto" MinWidth="180" />
                                                        <ColumnDefinition Width="Auto" MinWidth="140" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Image (Same as Edit Mode) -->
                                                    <Grid Grid.Column="0" Width="56" Height="56" CornerRadius="4" 
                                                          Background="{ThemeResource LayerFillColorAltBrush}" BorderThickness="1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}">
                                                        <Image Source="{x:Bind ImageSource, Mode=OneWay}" Stretch="UniformToFill" />
                                                    </Grid>

                                                    <!-- Product Details -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                                        <TextBlock Text="{x:Bind ProductName, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{x:Bind Sku, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>

                                                    <!-- Status Badge -->
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0">
                                                        <TextBlock Text="Status" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <!-- You can style this border based on the Status enum using a converter later! -->
                                                        <Border Background="{ThemeResource SystemFillColorNeutralBrush}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                                            <TextBlock Text="{x:Bind Status, Mode=OneWay}" FontSize="12" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <!-- Fulfillment Progress (Allocated / Requested) -->
                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="16,0,0,0">
                                                        <TextBlock Text="Fulfillment" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <!-- Progress Bar comparing Allocated to Requested -->
                                                            <ProgressBar Value="{x:Bind AllocatedQuantity, Mode=OneWay}" 
                                                                         Maximum="{x:Bind Quantity, Mode=OneWay}" 
                                                                         Width="80" />
                                                            <TextBlock Style="{StaticResource BodyTextBlockStyle}">
                                                                <Run Text="{x:Bind AllocatedQuantity, Mode=OneWay}" FontWeight="SemiBold"/>
                                                                <Run Text=" / " Foreground="{ThemeResource TextFillColorDisabledBrush}"/>
                                                                <Run Text="{x:Bind Quantity, Mode=OneWay}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Contextual Action Buttons -->
                                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="16,0,0,0" HorizontalAlignment="Right">

                                                        <!-- Shown if they need it, and you have it in stock -->
                                                        <Button Content="Allocate Stock" 
                                                                Style="{StaticResource AccentButtonStyle}"
                                                                Visibility="{x:Bind CanAllocateStock, Mode=OneWay}" />

                                                        <!-- Shown if they need it, and you DO NOT have it -->
                                                        <Button Content="Create Task" 
                                                                Visibility="{x:Bind CanCreateTask, Mode=OneWay}">
                                                            <Button.Flyout>
                                                                <MenuFlyout>
                                                                    <MenuFlyoutItem Text="Production Task" Icon="Repair" />
                                                                    <MenuFlyoutItem Text="Procurement Task" Icon="Shop" />
                                                                </MenuFlyout>
                                                            </Button.Flyout>
                                                        </Button>

                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>

                                <!-- EDIT MODE -->
                                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.OrderItems.IsEditing, Mode=OneWay}">

                                    <ListView ItemsSource="{x:Bind ViewModel.OrderItems.Items, Mode=OneWay}"
                                              SelectionMode="None"
                                              HorizontalAlignment="Stretch"
                                              ScrollViewer.VerticalScrollMode="Disabled">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Margin" Value="0,0,0,8" />
                                                <Setter Property="Padding" Value="0" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="local:EditOrderLineItem">
                                                <Grid Background="{ThemeResource LayerFillColorAltBrush}"
                                                      CornerRadius="8"
                                                      BorderThickness="0"
                                                      BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                                      Padding="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="64" />
                                                        <ColumnDefinition Width="*" MinWidth="150" />
                                                        <ColumnDefinition Width="Auto" MinWidth="120" />
                                                        <ColumnDefinition Width="Auto" MinWidth="140" />
                                                        <ColumnDefinition Width="Auto" MinWidth="100" />
                                                        <ColumnDefinition Width="Auto" MinWidth="40" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Image -->
                                                    <Grid Grid.Column="0" Width="56" Height="56" CornerRadius="4" 
                                                          Background="{ThemeResource LayerFillColorAltBrush}" BorderThickness="1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                                          VerticalAlignment="Center">
                                                        <FontIcon Glyph="&#xE8B9;" FontSize="16" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                        <Image Source="{x:Bind ImageSource, Mode=OneWay}" Stretch="UniformToFill" />
                                                    </Grid>

                                                    <!-- Product Details -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                                        <TextBlock Text="{x:Bind ProductName, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{x:Bind Sku, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    </StackPanel>

                                                    <!-- Unit Price -->
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0">
                                                        <TextBlock Text="Unit Price" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock Style="{StaticResource BodyTextBlockStyle}">
                                                            <Run Text="{x:Bind BaseCurrency, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                            <Run Text=" " />
                                                            <Run Text="{x:Bind UnitPrice, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Quantity & Availability -->
                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="16,0,0,0">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <NumberBox Value="{x:Bind Quantity, Mode=TwoWay}" 
                                                                       Minimum="1" 
                                                                       SpinButtonPlacementMode="Inline" 
                                                                       Width="120" />
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                                            <ProgressBar Value="{x:Bind AvailableQuantity, Mode=OneWay}" 
                                                                         Maximum="{x:Bind Quantity, Mode=OneWay}" 
                                                                         Foreground="{x:Bind QuantityProgressBrush, Mode=OneWay}"
                                                                         Width="60" />
                                                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                                                                <Run Text="{x:Bind AvailableQuantity, Mode=OneWay}"/>
                                                                <Run Text="/" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                                <Run Text="{x:Bind Quantity, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Line Total -->
                                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="16,0,0,0">
                                                        <TextBlock Text="Total" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}">
                                                            <Run Text="{x:Bind BaseCurrency, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                            <Run Text=" " />
                                                            <Run Text="{x:Bind LineTotal, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Remove Action -->
                                                    <Button Grid.Column="5" 
                                                            Style="{StaticResource SubtleButtonStyle}" 
                                                            VerticalAlignment="Center" 
                                                            Margin="16,0,0,0"
                                                            ToolTipService.ToolTip="Remove Item"
                                                            Command="{x:Bind RemoveCommand, Mode=OneWay}"
                                                            CommandParameter="{x:Bind}">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="16" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                                    </Button>

                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <!-- Empty State -->
                                    <StackPanel Visibility="{x:Bind GetOrderItemsEmptyState(ViewModel.OrderItems.Items.Count), Mode=OneWay}"
                                                VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Margin="0,32,0,32">
                                        <FontIcon Glyph="&#xE7B3;" FontSize="32" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Text="No items added yet" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                </StackPanel>

                            </StackPanel>

                        </StackPanel>
                        
                        <!-- Right Column -->
                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="12">

                            <!-- Logistics Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Logistics" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="Determine the shipping reality." 
                                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <CommandBar Grid.Column="1" 
                                                Background="Transparent" 
                                                IsOpen="False" 
                                                DefaultLabelPosition="Right" 
                                                IsSticky="True">
                                        <AppBarButton Icon="Edit" Label="Edit" 
                                                      Visibility="{x:Bind ViewModel.Logistics.IsReadonly, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.Logistics.BeginEditCommand, Mode=OneWay}" />

                                        <AppBarButton Icon="Save" Label="Save" 
                                                      AllowFocusOnInteraction="True"
                                                      Visibility="{x:Bind ViewModel.Logistics.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.UpdateOrderLogisticsCommand}" />

                                        <AppBarButton Icon="Cancel" Label="Cancel" 
                                                      Visibility="{x:Bind ViewModel.Logistics.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.Logistics.CancelEditCommand, Mode=OneWay}" />

                                    </CommandBar>
                                </Grid>

                                <!-- READONLY MODE -->
                                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.Logistics.IsReadonly, Mode=OneWay}">
                                    
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Payment Method" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                        <TextBlock Text="Cash on Delivery" 
                                                   Style="{StaticResource BodyTextBlockStyle}" 
                                                   Visibility="{x:Bind ViewModel.Logistics.IsCashOnDelivery, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <TextBlock Text="Prepaid" 
                                                   Style="{StaticResource BodyTextBlockStyle}" 
                                                   Visibility="{x:Bind ViewModel.Logistics.IsCashOnDelivery, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Courier" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.Logistics.SelectedCourier.Name, Mode=OneWay, TargetNullValue='No Courier Selected', FallbackValue='No Courier Selected'}" Style="{StaticResource BodyTextBlockStyle}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Shipping Address" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.Logistics.ShippingAddressStreet, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}" Visibility="{x:Bind ViewModel.Logistics.ShippingAddressStreet, Mode=OneWay, Converter={StaticResource InvertedNullToVisibilityConverter}}"/>
                                        <TextBlock Style="{StaticResource BodyTextBlockStyle}">
                                            <Run Text="{x:Bind ViewModel.Logistics.ShippingAddressCity, Mode=OneWay}"/>
                                            <Run Text=" - "/>
                                            <Run Text="{x:Bind ViewModel.Logistics.ShippingAddressDistrict, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource BodyTextBlockStyle}">
                                            <Run Text="{x:Bind ViewModel.Logistics.ShippingAddressState, Mode=OneWay}"/>
                                            <Run Text=", "/>
                                            <Run Text="{x:Bind ViewModel.Logistics.ShippingAddressPostalCode, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{x:Bind ViewModel.Logistics.ShippingAddressCountry, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- EDIT MODE -->
                                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.Logistics.IsEditing, Mode=OneWay}">
                                    <StackPanel Spacing="16" Margin="0,16,0,0">
                                        <ToggleSwitch Header="Cash on Delivery" 
                                                      IsEnabled="False"
                                                      IsOn="{x:Bind ViewModel.Logistics.IsCashOnDelivery, Mode=TwoWay}" 
                                                      OnContent="Yes" OffContent="No" />

                                        <ComboBox Header="Courier" 
                                                  ItemsSource="{x:Bind ViewModel.Logistics.Couriers, Mode=OneWay}" 
                                                  SelectedItem="{x:Bind ViewModel.Logistics.SelectedCourier, Mode=TwoWay}"
                                                  DisplayMemberPath="Name" 
                                                  PlaceholderText="Select a Courier" 
                                                  HorizontalAlignment="Stretch" />

                                        <StackPanel Spacing="8" Margin="0,8,0,0">
                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                           Text="Shipping Address" 
                                                           Style="{StaticResource BodyStrongTextBlockStyle}" 
                                                           VerticalAlignment="Center"/>

                                                <!-- The autofill button -->
                                                <HyperlinkButton Grid.Column="1" 
                                                                 Content="Use Customer Default Address" 
                                                                 Command="{x:Bind ViewModel.Logistics.UseCustomerAddressCommand}" 
                                                                 Margin="12,0,0,0" 
                                                                 VerticalAlignment="Center" />
                                            </Grid>

                                            <TextBox Header="Street Address" Text="{x:Bind ViewModel.Logistics.ShippingAddressStreet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Header="City" Text="{x:Bind ViewModel.Logistics.ShippingAddressCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <ComboBox Grid.Column="1" Header="State / Province" 
                                                          ItemsSource="{x:Bind ViewModel.Logistics.Provinces, Mode=OneWay}"
                                                          SelectedItem="{x:Bind ViewModel.Logistics.ShippingAddressState, Mode=TwoWay}"
                                                          HorizontalAlignment="Stretch" />
                                            </Grid>

                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" Header="District" 
                                                          ItemsSource="{x:Bind ViewModel.Logistics.Districts, Mode=OneWay}"
                                                          SelectedItem="{x:Bind ViewModel.Logistics.ShippingAddressDistrict, Mode=TwoWay}"
                                                          HorizontalAlignment="Stretch" />
                                                <TextBox Grid.Column="1" Header="Postal Code" Text="{x:Bind ViewModel.Logistics.ShippingAddressPostalCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>

                                            <TextBox Header="Country" Text="{x:Bind ViewModel.Logistics.ShippingAddressCountry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                            </StackPanel>

                            <!-- Financial Adjustments Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Financial Adjustments" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="Handle shipping fees, taxes, and discounts." 
                                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <CommandBar Grid.Column="1" 
                                                Background="Transparent" 
                                                IsOpen="False" 
                                                DefaultLabelPosition="Right" 
                                                IsSticky="True">
                                        <AppBarButton Icon="Edit" Label="Edit" 
                                                      Visibility="{x:Bind ViewModel.Financials.IsReadonly, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.Financials.BeginEditCommand, Mode=OneWay}" />

                                        <AppBarButton Icon="Save" Label="Save" 
                                                      AllowFocusOnInteraction="True"
                                                      Visibility="{x:Bind ViewModel.Financials.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.UpdateFinancialsCommand}" />

                                        <AppBarButton Icon="Cancel" Label="Cancel" 
                                                      Visibility="{x:Bind ViewModel.Financials.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.Financials.CancelEditCommand, Mode=OneWay}" />

                                    </CommandBar>
                                </Grid>

                                <!-- READONLY MODE -->
                                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.Financials.IsReadonly, Mode=OneWay}">
                                    
                                    
                                    
                                </StackPanel>

                                <!-- EDIT MODE -->
                                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.Financials.IsEditing, Mode=OneWay}">

                                    <StackPanel>
                                        <TextBlock Text="Shipping Fee"
                                                   Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{x:Bind ViewModel.Financials.BaseCurrency, Mode=OneWay}"
                                                       VerticalAlignment="Center" Grid.Column="0"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <NumberBox Value="{x:Bind ViewModel.Financials.ShippingFee, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}" 
                                                       SpinButtonPlacementMode="Inline" 
                                                       Minimum="0"
                                                       Grid.Column="1"/>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Tax Amount"
                                                   Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{x:Bind ViewModel.Financials.BaseCurrency, Mode=OneWay}"
                                                       VerticalAlignment="Center" Grid.Column="0"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <NumberBox Value="{x:Bind ViewModel.Financials.TaxAmount, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}" 
                                                       SpinButtonPlacementMode="Inline" 
                                                       Minimum="0" 
                                                       IsEnabled="False" 
                                                       Grid.Column="1"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Discount Actions -->
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="Discount" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4" />

                                        <Button Content="Apply Discount" 
                                                Command="{x:Bind ViewModel.Financials.ShowApplyDiscountDialogCommand, Mode=OneWay}"
                                                Visibility="{x:Bind ViewModel.Financials.HasDiscount, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />

                                        <!-- Applied Discount Chip -->
                                        <Grid Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                              CornerRadius="4"
                                              Padding="12,8"
                                              Visibility="{x:Bind ViewModel.Financials.HasDiscount, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource SystemFillColorSuccessBrush}">
                                                    <Run Text="{x:Bind ViewModel.Financials.AppliedDiscount.Type, Mode=OneWay}" />
                                                    <Run Text=" Discount Applied" />
                                                </TextBlock>
                                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemFillColorSuccessBrush}">
                                                    <Run Text="Value:" />
                                                    <Run Text="{x:Bind ViewModel.Financials.AppliedDiscount.Value, Mode=OneWay}" />
                                                    <Run Text=" | Reason:" />
                                                    <Run Text="{x:Bind ViewModel.Financials.AppliedDiscount.Reason, Mode=OneWay, TargetNullValue='None', FallbackValue='None'}" />
                                                </TextBlock>
                                            </StackPanel>

                                            <Button Grid.Column="1" 
                                                    Style="{StaticResource SubtleButtonStyle}" 
                                                    Command="{x:Bind ViewModel.Financials.ClearDiscountCommand, Mode=OneWay}"
                                                    ToolTipService.ToolTip="Remove Discount"
                                                    VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                        
                    </Grid>
                    
                </StackPanel>
                
            </Grid>
            
        </ScrollViewer>

        <ProgressRing Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Stretch" 
             IsIndeterminate="True" 
             Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" 
             Canvas.ZIndex="100" />

    </Grid>
</Page>
