<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Catalog.CatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Catalog"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />

        <!-- Tile Button Style -->
        <Style x:Key="DashboardTileButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource SurfaceStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,14,16,16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="130"/>
            <Setter Property="MinWidth" Value="200"/>
        </Style>
        <Style x:Key="ChipBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="24,16"
              Background="{ThemeResource LayerFillColorDefaultBrush}" ColumnSpacing="8">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Catalog &amp; inventory" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Bind ViewModel.LastSyncedText, Mode=OneWay}" 
                           Style="{StaticResource CaptionTextBlockStyle}" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <Button Command="{x:Bind ViewModel.RefreshCommand}" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Padding="8"
                        ToolTipService.ToolTip="Refresh Dashboard">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Button>
            </StackPanel>

        </Grid>

        <ProgressBar Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" 
                     IsIndeterminate="True" 
                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" 
                     Canvas.ZIndex="100" />

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}">

            <StackPanel Padding="32" Spacing="24" HorizontalAlignment="Stretch">

                <!-- ROW 1: Overview -->
                <StackPanel Spacing="10">

                    <TextBlock Text="OVERVIEW" FontSize="11" FontWeight="SemiBold" CharacterSpacing="80" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <Grid ColumnSpacing="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Total Variants -->
                        <Button Grid.Column="0" Command="{x:Bind ViewModel.NavigateToCatalogCommand}" Style="{StaticResource DashboardTileButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Total variants" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{x:Bind ViewModel.DashboardSummary.TotalVariantCount, Mode=OneWay, TargetNullValue='--'}" FontSize="34" FontWeight="Medium" LineHeight="34"/>
                                    <TextBlock Text="across catalog" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource ChipBorderStyle}" Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}">
                                    <TextBlock Text="View catalog" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Out of Stock -->
                        <Button Grid.Column="1" Command="{x:Bind ViewModel.NavigateToStockoutsCommand}" Style="{StaticResource DashboardTileButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Out of stock" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{x:Bind ViewModel.DashboardSummary.OutOfStockCount, Mode=OneWay, TargetNullValue='--'}" FontSize="34" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorCriticalBrush}" LineHeight="34"/>
                                    <TextBlock Text="variants unavailable" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource ChipBorderStyle}" Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}">
                                    <TextBlock Text="View stockouts" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Low Stock -->
                        <Button Grid.Column="2" Command="{x:Bind ViewModel.NavigateToLowStockAlertsCommand}" Style="{StaticResource DashboardTileButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Low stock" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{x:Bind ViewModel.DashboardSummary.LowStockCount, Mode=OneWay, TargetNullValue='--'}" FontSize="34" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorCautionBrush}" LineHeight="34"/>
                                    <TextBlock Text="below threshold" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource ChipBorderStyle}" Background="{ThemeResource SystemFillColorCautionBackgroundBrush}">
                                    <TextBlock Text="View alerts" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Incoming (Inbound) -->
                        <Button Grid.Column="3" Command="{x:Bind ViewModel.NavigateToFulfillmentTasksCommand}" Style="{StaticResource DashboardTileButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Incoming (inbound)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{x:Bind ViewModel.DashboardSummary.Inbound.TotalUnits, Mode=OneWay, TargetNullValue='--'}" FontSize="34" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorSuccessBrush}" LineHeight="34"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                                        <TextBlock Text="units in" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.DashboardSummary.Inbound.VariantCount, Mode=OneWay, TargetNullValue='--'}" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="variants" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource ChipBorderStyle}" Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}">
                                    <TextBlock Text="View tasks" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                </Border>
                            </Grid>
                        </Button>

                    </Grid>
                    
                </StackPanel>

                <!-- ROW 2: Wide Tiles -->
                <StackPanel Spacing="10">

                    <TextBlock Text="STOCK BREAKDOWN" FontSize="11" FontWeight="SemiBold" CharacterSpacing="80" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <Grid ColumnSpacing="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Stock On Hand -->
                        <Button Grid.Column="0" Command="{x:Bind ViewModel.NavigateToStockReportCommand}" Style="{StaticResource DashboardTileButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Stock on hand" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,12"/>

                                <Grid Grid.Row="1" VerticalAlignment="Bottom">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Total Units -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Total units" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.DashboardSummary.StockTotals.StockOnHand, Mode=OneWay, TargetNullValue='--'}" FontSize="24" FontWeight="Medium"/>
                                    </StackPanel>

                                    <Border Grid.Column="1" Background="{ThemeResource SurfaceStrokeColorDefaultBrush}" Margin="0,4" VerticalAlignment="Stretch"/>
                                    <!-- Reserved -->
                                    <StackPanel Grid.Column="2" Padding="16,0,0,0">
                                        <TextBlock Text="Reserved" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.DashboardSummary.StockTotals.ReservedStock, Mode=OneWay, TargetNullValue='--'}" FontSize="24" FontWeight="Medium"/>
                                    </StackPanel>
                                    <Border Grid.Column="3" Background="{ThemeResource SurfaceStrokeColorDefaultBrush}" Margin="0,4" VerticalAlignment="Stretch"/>
                                    <!-- Available -->
                                    <StackPanel Grid.Column="4" Padding="16,0,0,0">
                                        <TextBlock Text="Available" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.DashboardSummary.StockTotals.AvailableStock, Mode=OneWay, TargetNullValue='--'}" FontSize="24" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                    </StackPanel>
                                    <!-- Chip -->
                                    <Border Grid.Column="5" Margin="16,0,0,0" Padding="8,4" CornerRadius="12" Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}" VerticalAlignment="Bottom">
                                        <TextBlock Text="Full report" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Button>

                        <!-- Fulfillment Tasks -->
                        <Button Grid.Column="1" Command="{x:Bind ViewModel.NavigateToFulfillmentTasksCommand}" Style="{StaticResource DashboardTileButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Active fulfillment tasks" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,12"/>
                                <Grid Grid.Row="1" VerticalAlignment="Bottom">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- In Production -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="In production" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.DashboardSummary.FulfillmentTasks.InProduction, Mode=OneWay, TargetNullValue='--'}" FontSize="24" FontWeight="Medium"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{ThemeResource SurfaceStrokeColorDefaultBrush}" Margin="0,4" VerticalAlignment="Stretch"/>
                                    <!-- Procurement -->
                                    <StackPanel Grid.Column="2" Padding="16,0,0,0">
                                        <TextBlock Text="Procurement" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.DashboardSummary.FulfillmentTasks.Procurement, Mode=OneWay, TargetNullValue='--'}" FontSize="24" FontWeight="Medium"/>
                                    </StackPanel>
                                    <!-- Chip -->
                                    <Border Grid.Column="3" Margin="16,0,0,0" Padding="8,4" CornerRadius="12" Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}" VerticalAlignment="Bottom">
                                        <TextBlock Text="Task backlog" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Button>

                    </Grid>
                    
                </StackPanel>

                <!-- ROW 3: Alerts -->
                <StackPanel Spacing="10">

                    <TextBlock Text="ALERTS" FontSize="11" FontWeight="SemiBold" CharacterSpacing="80" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <Grid ColumnSpacing="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Out of Stock List -->
                        <Border Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0" CornerRadius="12" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="16" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    <TextBlock Text="Out of stock variants" FontWeight="Medium" FontSize="14"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Alerts.OutOfStock, Mode=OneWay}"
                                              Visibility="{x:Bind ViewModel.HasOutOfStockAlerts, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:StockAlertItemDto">
                                            <Button Command="{Binding ElementName=RootGrid, Path=DataContext.NavigateToProductDetailCommand}" 
                                                    CommandParameter="{x:Bind}"
                                                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"
                                                    Style="{StaticResource SubtleButtonStyle}"
                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{x:Bind VariantLabel}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1" Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}" CornerRadius="12" Padding="8,2">
                                                        <TextBlock Text="0 units" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                    </Border>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Visibility="{x:Bind ViewModel.HasOutOfStockAlerts, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,24,0,24" Spacing="8">
                                    <FontIcon Glyph="&#xE73E;" FontSize="24" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                    <TextBlock Text="All good! No variants out of stock." 
                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Low Stock List -->
                        <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0" CornerRadius="12" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="16" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                    <TextBlock Text="Low stock variants" FontWeight="Medium" FontSize="14"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Alerts.LowStock, Mode=OneWay}"
                                              Visibility="{x:Bind ViewModel.HasLowStockAlerts, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:StockAlertItemDto">
                                            <Button Command="{Binding ElementName=RootGrid, Path=DataContext.NavigateToProductDetailCommand}" 
                                                    CommandParameter="{x:Bind}"
                                                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"
                                                    Style="{StaticResource SubtleButtonStyle}"
                                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{x:Bind VariantLabel}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1" Background="{ThemeResource SystemFillColorCautionBackgroundBrush}" CornerRadius="12" Padding="8,2">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="{x:Bind AvailableStock}" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                                            <TextBlock Text="left" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Visibility="{x:Bind ViewModel.HasLowStockAlerts, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,24,0,24" Spacing="8">
                                    <FontIcon Glyph="&#xE73E;" FontSize="24" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                    <TextBlock Text="Stock levels look healthy." 
                                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </Grid>
                    
                </StackPanel>
                
            </StackPanel>
            
        </ScrollViewer>
        
    </Grid>
</Page>
