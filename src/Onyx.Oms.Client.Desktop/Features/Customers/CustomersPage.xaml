<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Customers.CustomersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Customers"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header  and Filters -->
        <Grid Grid.Row="0" Padding="16,12" 
              Background="{ThemeResource LayerFillColorDefaultBrush}" 
              ColumnSpacing="8" RowSpacing="12">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Top Row: Title, Search, Actions -->
            <TextBlock Grid.Row="0" Grid.Column="0" 
                       Text="Customers" 
                       Style="{StaticResource SubtitleTextBlockStyle}" 
                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0"/>

            <AutoSuggestBox Grid.Row="0" Grid.Column="1" 
                            PlaceholderText="Search by name, email or phone..."
                            QueryIcon="Find"
                            Width="320"
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QuerySubmitted="OnQuerySubmitted" />

            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.RefreshCommand}" Style="{StaticResource SubtleButtonStyle}" ToolTipService.ToolTip="Refresh Data">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                </Button>

                <AppBarSeparator />

                <Button x:Name="NewCustomerButton" Command="{x:Bind ViewModel.NewCustomerCommand}" Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="New Customer" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Filters -->
            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="16">
                <ComboBox ItemsSource="{x:Bind ViewModel.StatusOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedStatus, Mode=TwoWay}"
                          PlaceholderText="Status"
                          Width="120"/>

                <Button Content="Clear Filters" Style="{StaticResource SubtleButtonStyle}"
                        Command="{x:Bind ViewModel.ClearFiltersCommand}"/>
            </StackPanel>

        </Grid>

        <Grid Grid.Row="1">

            <toolkit:DataGrid x:Name="CustomersDataGrid"
                              ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              CanUserSortColumns="True"
                              Sorting="OnDataGridSorting"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              BorderThickness="0"
                              RowBackground="Transparent"
                              AlternatingRowBackground="{ThemeResource LayerFillColorDefaultBrush}">

                <toolkit:DataGrid.Columns>

                    <toolkit:DataGridTextColumn Header="Name" 
                                                Binding="{Binding Name}" 
                                                Width="*" MinWidth="180"
                                                HeaderStyle="{StaticResource LeftAlignedHeaderStyle}"
                                                ElementStyle="{StaticResource LeftAlignedCellStyle}"
                                                FontWeight="SemiBold" />

                    <toolkit:DataGridTextColumn Header="Email" 
                                                Binding="{Binding Email}" 
                                                Width="220"
                                                HeaderStyle="{StaticResource LeftAlignedHeaderStyle}"
                                                ElementStyle="{StaticResource LeftAlignedCellStyle}" />

                    <toolkit:DataGridTextColumn Header="Phone" 
                                                Binding="{Binding PrimaryPhone}" 
                                                Width="160"
                                                FontFamily="Consolas"
                                                HeaderStyle="{StaticResource RightAlignedHeaderStyle}"
                                                ElementStyle="{StaticResource RightAlignedCellStyle}" />

                    <toolkit:DataGridTextColumn Header="Location" 
                                                Binding="{Binding Address}" 
                                                Width="200"
                                                HeaderStyle="{StaticResource LeftAlignedHeaderStyle}"
                                                ElementStyle="{StaticResource LeftAlignedCellStyle}" />

                    <toolkit:DataGridTemplateColumn Header="Status" 
                                                    Width="120" 
                                                    HeaderStyle="{StaticResource CenteredHeaderStyle}">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource StatusBadgeStyle}" 
                                        HorizontalAlignment="Center"
                                        Background="{Binding IsActive, Converter={StaticResource StatusBackgroundConverter}}">
                                    <TextBlock Text="{Binding IsActive, Converter={StaticResource StatusTextConverter}}"
                                               Style="{StaticResource StatusBadgeTextStyle}"
                                               Foreground="{Binding IsActive, Converter={StaticResource StatusForegroundConverter}}" />
                                </Border>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>

                    <toolkit:DataGridTemplateColumn 
                                                    Width="80"
                                                    HeaderStyle="{StaticResource CenteredHeaderStyle}">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="local:CustomerDto">
                                <Button Style="{StaticResource SubtleButtonStyle}" 
                                        Background="Transparent"
                                        HorizontalAlignment="Stretch" 
                                        VerticalAlignment="Stretch"
                                        ToolTipService.ToolTip="Actions"
                                        Tapped="OnActionButtonTapped">

                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE712;" />

                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="View Details" Icon="ContactInfo" Click="OnViewClick" />

                                            <MenuFlyoutSeparator />

                                            <MenuFlyoutItem Text="Edit" Icon="Edit" Click="OnEditClick" 
                                                            IsEnabled="{x:Bind CanEdit}" />

                                            <MenuFlyoutItem Text="Activate" Icon="Play" Click="OnActivateClick" 
                                                            Visibility="{x:Bind IsActive, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                                            IsEnabled="{x:Bind CanEdit}" />

                                            <MenuFlyoutItem Text="Deactivate" Icon="Pause" Click="OnDeactivateClick" 
                                                            Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                                            IsEnabled="{x:Bind CanEdit}" />

                                            <MenuFlyoutSeparator />

                                            <MenuFlyoutItem Text="Delete" Icon="Delete" Foreground="Red" Click="OnDeleteClick" 
                                                            IsEnabled="{x:Bind CanDelete}" />
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>

                </toolkit:DataGrid.Columns>
            </toolkit:DataGrid>

            <Grid Background="{ThemeResource LayerFillColorAltBrush}" Opacity="0.8" 
                  Visibility="{x:Bind ViewModel.IsListLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ProgressRing IsActive="True" Width="48" Height="48" />
            </Grid>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                        Visibility="{x:Bind ViewModel.HasNoData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <FontIcon Glyph="&#xE780;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="No customers found matching your search." 
                           Style="{StaticResource SubtitleTextBlockStyle}" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <Button Content="Clear Search" 
                        Command="{x:Bind ViewModel.RefreshCommand}" 
                        Style="{StaticResource DefaultButtonStyle}" 
                        HorizontalAlignment="Center"/>
            </StackPanel>

        </Grid>

        <Grid Grid.Row="2" 
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Padding="16,8">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Rows per page:" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.PageSizes}" 
                          SelectedItem="{x:Bind ViewModel.PageSize, Mode=TwoWay}"
                          Style="{StaticResource DefaultComboBoxStyle}"
                          MinWidth="80" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.PageSummary, Mode=OneWay}" 
                       Style="{StaticResource CaptionTextBlockStyle}" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.PreviousPageCommand}" IsEnabled="{x:Bind ViewModel.HasPreviousPage, Mode=OneWay}" ToolTipService.ToolTip="Previous Page">
                    <FontIcon Glyph="&#xE76B;" FontSize="12" />
                </Button>
                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.NextPageCommand}" IsEnabled="{x:Bind ViewModel.HasNextPage, Mode=OneWay}" ToolTipService.ToolTip="Next Page">
                    <FontIcon Glyph="&#xE76C;" FontSize="12" />
                </Button>
            </StackPanel>

        </Grid>
        
    </Grid>
</Page>
