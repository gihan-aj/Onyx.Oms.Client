<Page
    x:Name="RootPage"
    x:Class="Onyx.Oms.Client.Desktop.Features.Products.CreateProductPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Products"
    xmlns:controls="using:Onyx.Oms.Client.Desktop.Features.Products.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sharedConverters="using:Onyx.Oms.Client.Desktop.Shared.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
        <converters:EmptyCollectionToObjectConverter x:Key="EmptyListToVisibiltyConverter" EmptyValue="Visible" NotEmptyValue="Collapsed" />
        <sharedConverters:DecimalToDoubleConverter x:Key="DecimalToDoubleConverter" />
        <sharedConverters:StringListConverter x:Key="StringListConverter" />
        <sharedConverters:StringToBoolConverter x:Key="StringToBoolConverter" />

        <DataTemplate x:Key="TextSpecTemplate" x:DataType="local:SpecFieldViewModel">
            <TextBox Header="{x:Bind Label}" 
                     Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     PlaceholderText="Enter value..." 
                     Margin="0,0,0,12" />
        </DataTemplate>

        <DataTemplate x:Key="SelectSpecTemplate" x:DataType="local:SpecFieldViewModel">
            <ComboBox Header="{x:Bind Label}" 
                      ItemsSource="{x:Bind Options}" 
                      SelectedItem="{x:Bind Value, Mode=TwoWay}"
                      HorizontalAlignment="Stretch" 
                      Margin="0,0,0,12" />
        </DataTemplate>

        <DataTemplate x:Key="ToggleSpecTemplate" x:DataType="local:SpecFieldViewModel">
            <CheckBox Content="{x:Bind Label}" 
                      IsChecked="{x:Bind Value, Mode=TwoWay, Converter={StaticResource StringToBoolConverter}}" 
                      Margin="0,0,0,12" />
        </DataTemplate>

        <local:FormTemplateSelector x:Key="SpecSelector"
                                    TextTemplate="{StaticResource TextSpecTemplate}"
                                    ComboBoxTemplate="{StaticResource SelectSpecTemplate}"
                                    ToggleTemplate="{StaticResource ToggleSpecTemplate}" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <!-- Overlay Loading State -->
        <!--<Border Canvas.ZIndex="100" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Opacity="0.6" Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressRing IsActive="True" Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>-->

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Section 1: Sticky Header -->
        <Grid Grid.Row="0" Padding="24,16" BorderThickness="0,0,0,1" 
              BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" 
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <TextBlock Text="Create New Product" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center"/>
            
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="16">
                <TextBlock Text="Unsaved changes" 
                           Foreground="{ThemeResource SystemFillColorCautionBrush}" 
                           VerticalAlignment="Center" 
                           Visibility="{x:Bind ViewModel.HasUnsavedChanges, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Button Content="Cancel" Style="{StaticResource DefaultButtonStyle}" Command="{x:Bind ViewModel.CancelCommand}" />
                <Button Content="Save Product" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.SaveCommand}" />
            </StackPanel>
        </Grid>

        <!-- Scrollable Body -->
        <ScrollViewer Grid.Row="1" Padding="12" VerticalScrollBarVisibility="Auto">

            <StackPanel Grid.Column="1" MaxWidth="1200" HorizontalAlignment="Stretch" Spacing="12">
                
                <!-- Section 2: Split View -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" MinWidth="350" />
                        <ColumnDefinition Width="1.2*" MinWidth="350" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: Identity -->
                    <StackPanel Grid.Column="0" Style="{StaticResource CardStackStyle}">
                        <TextBlock Text="Basic Information" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />
                        <TextBox Header="Product Name *" PlaceholderText="e.g. Onyx Signature Tee" Text="{x:Bind ViewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                        <TextBox Header="Base SKU (Optional)" PlaceholderText="e.g. TEE-SIG-01" Text="{x:Bind ViewModel.BaseSku, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                        
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Category *" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                            <controls:LeafProductCategoryPicker x:Name="CategoryPicker" 
                                                                SelectedCategory="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}" 
                                                                HorizontalAlignment="Stretch" />
                        </StackPanel>
                        
                        <TextBox Header="Description" PlaceholderText="Detailed product description..." 
                                 Text="{x:Bind ViewModel.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="100" Margin="0,0,0,12" />
                                 
                        <!-- Dynamic Specifications -->
                        <ItemsControl ItemsSource="{x:Bind ViewModel.DynamicSpecs, Mode=OneWay}"
                                      ItemTemplateSelector="{StaticResource SpecSelector}"
                                      Margin="0,0,0,12">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <labs:TokenizingTextBox Margin="0,0,0,12"
                                    Header="Tags (Type and press Enter)"
                                    ItemsSource="{x:Bind ViewModel.Tags, Mode=OneWay}"
                                    TokenDelimiter="&#13;"
                                    PlaceholderText="e.g., Summer, Sale, New Arrival" />

                    </StackPanel>

                    <!-- Right Column: Logistics & Defaults -->
                    <StackPanel Grid.Column="1" Style="{StaticResource CardStackStyle}">
                        <TextBlock Text="Logistics &amp; Settings" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8"/>
                        
                        <!-- Pricing Grid -->
                        <Grid ColumnSpacing="12" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" /> 
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Base Cost" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" /> <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <NumberBox Value="{x:Bind ViewModel.BaseCostAmount, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}" Minimum="0" Grid.Column="0" />
                                    <TextBlock Text="{x:Bind ViewModel.BaseCurrency, Mode=OneWay}" VerticalAlignment="Center" Margin="12,0,0,0" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Base Price *" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" /> <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <NumberBox Value="{x:Bind ViewModel.BasePriceAmount, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}" Minimum="0" Grid.Column="0" />
                                    <TextBlock Text="{x:Bind ViewModel.BaseCurrency, Mode=OneWay}" VerticalAlignment="Center" Margin="12,0,0,0" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <CheckBox Content="This is a physical product (requires shipping)" IsChecked="{x:Bind ViewModel.IsPhysicalProduct, Mode=TwoWay}" Margin="0,0,0,8" />
                        
                        <!-- Weight field (hidden if digital) -->
                        <StackPanel Visibility="{x:Bind ViewModel.IsPhysicalProduct, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,16">
                            <TextBlock Text="Base Weight" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" /> <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <NumberBox Value="{x:Bind ViewModel.BaseWeightValue, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}" Minimum="0" Grid.Column="0" />
                                <TextBlock Text="{x:Bind ViewModel.BaseWeightUnit, Mode=OneWay}" VerticalAlignment="Center" Margin="12,0,0,0" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </StackPanel>
                        
                        <!-- Stock Tracker (Hidden if resolving variants) -->
                        <NumberBox Header="Initial Stock Available" Minimum="0" 
                                   Value="{x:Bind ViewModel.BaseStockOnHand, Mode=TwoWay}" 
                                   Visibility="{x:Bind ViewModel.HasVariants, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                                   
                    </StackPanel>
                </Grid>

                <!-- Section 3: Variants & Options Card -->
                <StackPanel Style="{StaticResource CardStackStyle}">
                    
                    <Grid Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Product Variations" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Define dynamic options like size, color, or material to generate unique variant SKUs." 
                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <ToggleSwitch Header="Product Has Variations" IsOn="{x:Bind ViewModel.HasVariants, Mode=TwoWay}" HorizontalAlignment="Right" />
                    </Grid>

                    <MenuFlyoutSeparator Visibility="{x:Bind ViewModel.HasVariants, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,16" />

                    <!-- Variants Builder -->
                    <StackPanel Visibility="{x:Bind ViewModel.HasVariants, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        
                        <TextBlock Text="1. Define Option Axes" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,12" />
                        
                        <!-- Add Option Row -->
                        <Grid ColumnSpacing="12" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <TextBox Grid.Column="0" Header="Option Name" PlaceholderText="e.g., Color" Text="{x:Bind ViewModel.DraftOptionName, Mode=TwoWay}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <labs:TokenizingTextBox 
                                    Header="Values (Type and press Enter)"
                                    ItemsSource="{x:Bind ViewModel.DraftOptionValues, Mode=OneWay}"
                                    TokenDelimiter="&#13;"
                                    PlaceholderText="e.g., Red, Blue" />
                            </StackPanel>
                            
                            <Button Grid.Column="2" Content="Add Option" VerticalAlignment="Bottom" 
                                    Command="{x:Bind ViewModel.AddOptionCommand}" Style="{StaticResource DefaultButtonStyle}" />
                        </Grid>

                        <!-- Existing Options List -->
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.ProductOptions, Mode=OneWay}" Margin="0,0,0,16">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="local:ProductOptionModel">
                                    <Grid Padding="12" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="4" Margin="0,0,0,8" BorderThickness="1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Values, Converter={StaticResource StringListConverter}}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <Button Grid.Column="2" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                                                Style="{StaticResource SubtleButtonStyle}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" ToolTipService.ToolTip="Remove Option"
                                                Command="{Binding ElementName=RootPage, Path=ViewModel.RemoveOptionCommand}"
                                                CommandParameter="{x:Bind}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                        
                        <!-- Generate Action -->
                        <Button Content="Generate Variant Matrix" Command="{x:Bind ViewModel.GenerateMatrixCommand}" 
                                Style="{StaticResource AccentButtonStyle}" Margin="0,0,0,24" HorizontalAlignment="Left" />

                        <MenuFlyoutSeparator Margin="0,0,0,24" />

                        <TextBlock Text="2. Configure Variant Logistics" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,12" />
                        
                        <!-- The Matrix -->
                        <toolkit:DataGrid ItemsSource="{x:Bind ViewModel.VariantDrafts, Mode=OneWay}" 
                                          AutoGenerateColumns="False"
                                          BorderThickness="1" 
                                          BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                          GridLinesVisibility="Horizontal" 
                                          RowBackground="Transparent"
                                          AlternatingRowBackground="{ThemeResource LayerFillColorDefaultBrush}"
                                          MinHeight="200"
                                          MaxHeight="400">
                            <toolkit:DataGrid.Columns>
                                <toolkit:DataGridTextColumn Header="Variant" Binding="{Binding DisplayAttributes}" IsReadOnly="True" Width="200" />
                                <toolkit:DataGridTextColumn Header="SKU Override" Binding="{Binding Sku, Mode=TwoWay}" Width="*" />
                                <toolkit:DataGridTextColumn Header="Price" Binding="{Binding PriceAmount, Mode=TwoWay}" Width="100" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                                <toolkit:DataGridTextColumn Header="Cost" Binding="{Binding CostAmount, Mode=TwoWay}" Width="100" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                                <toolkit:DataGridTextColumn Header="Weight" Binding="{Binding WeightValue, Mode=TwoWay}" Width="100" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                                <toolkit:DataGridTextColumn Header="Initial Stock" Binding="{Binding StockOnHand, Mode=TwoWay}" Width="120" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                            </toolkit:DataGrid.Columns>
                        </toolkit:DataGrid>
                        
                    </StackPanel>
                </StackPanel>

                <StackPanel Style="{StaticResource CardStackStyle}">

                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Product Media &amp; Tagging" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Upload product images and select the corresponding variant option. The first image is automatically set as the main display." 
                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                Style="{StaticResource DefaultButtonStyle}"
                                Command="{x:Bind ViewModel.UploadImageCommand}">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE898;" FontSize="16"/>
                                    <TextBlock Text="Upload Image" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                    </Grid>

                    <ListView ItemsSource="{x:Bind ViewModel.ProductImages, Mode=OneWay}"
                              SelectionMode="None"
                              Margin="0,16,0,0">

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Margin" Value="0,0,0,16" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ImagePreviewModel">

                                <Grid CornerRadius="8" BorderThickness="1"
                                      BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" 
                                      Background="{ThemeResource LayerFillColorAltBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                                        <Image Source="{x:Bind ImageSource}" Stretch="UniformToFill" Margin="1" MinHeight="180" HorizontalAlignment="Center" VerticalAlignment="Center" />

                                        <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                                Margin="8" Padding="8,4" CornerRadius="4"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                Visibility="{x:Bind IsMain, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="MAIN" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Column="1" Padding="20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,16">
                                            <RadioButton Content="Set as Main Image" 
                                                         IsChecked="{x:Bind IsMain, Mode=OneWay}"
                                                         Command="{Binding ElementName=RootPage, Path=ViewModel.SetMainImageCommand}"
                                                         CommandParameter="{x:Bind}"
                                                         Margin="0" />

                                            <Button HorizontalAlignment="Right"
                                                    Style="{StaticResource SubtleButtonStyle}" 
                                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}" 
                                                    ToolTipService.ToolTip="Delete Image"
                                                    Command="{Binding ElementName=RootPage, Path=ViewModel.DeleteImageCommand}"
                                                    CommandParameter="{x:Bind}">
                                                <Button.Content>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                                        <TextBlock Text="Remove" />
                                                    </StackPanel>
                                                </Button.Content>
                                            </Button>
                                        </Grid>

                                        <TextBlock Grid.Row="1" Text="Link to a Variant Option:"
                                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,0,8"/>

                                        <ItemsControl Grid.Row="2" ItemsSource="{x:Bind AvailableTags, Mode=OneWay}" Margin="0,0,0,8">

                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <labs:WrapPanel Orientation="Horizontal" HorizontalSpacing="8" VerticalSpacing="8" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="local:SelectableTagViewModel">

                                                    <ToggleButton Content="{x:Bind Tag.DisplayLabel}" 
                                                                  IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                                  CornerRadius="16"
                                                                  Padding="16,6" />

                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>

                                </Grid>

                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>

                    <StackPanel HorizontalAlignment="Center" Margin="0,32,0,32" Spacing="12"
                                Visibility="{x:Bind ViewModel.GetEmptyStateVisibility(ViewModel.ProductImages.Count), Mode=OneWay}">
                        <FontIcon Glyph="&#xE8B9;" FontSize="48" Foreground="{ThemeResource SurfaceStrokeColorDefaultBrush}" />
                        <TextBlock Text="No images uploaded yet." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    
                </StackPanel>

                <!-- Bottom Spacer -->
                <Rectangle Height="64" />
            </StackPanel>

        </ScrollViewer>
    </Grid>
</Page>
