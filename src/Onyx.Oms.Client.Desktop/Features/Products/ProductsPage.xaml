<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Products.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Products"
    xmlns:controls="using:Onyx.Oms.Client.Desktop.Features.Products.Controls"
    xmlns:shared="using:Onyx.Oms.Client.Desktop.Shared.Models"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Products" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,24" />

        <!-- Toolbar & Filters -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Filters -->
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <!-- Search Box -->
                <AutoSuggestBox PlaceholderText="Search products..."
                                QueryIcon="Find"
                                Width="250"
                                Text="{x:Bind ViewModel.SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                QuerySubmitted="OnQuerySubmitted" />
                                
                <!-- Vertical Slice Category Picker -->
                <controls:LeafProductCategoryPicker x:Name="CategoryPicker" 
                                                    Width="200" 
                                                    PlaceholderText="Select Category"
                                                    SelectedCategory="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}" />

                <!-- Status Filter -->
                <ComboBox ItemsSource="{x:Bind ViewModel.StatusOptions}" 
                          SelectedItem="{x:Bind ViewModel.SelectedStatus, Mode=TwoWay}"
                          Width="120" />
                
                <!-- Clear Filters -->
                <Button Content="Clear" Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.ClearFiltersCommand}" />
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Click="OnRefreshClick">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Refresh" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button x:Name="NewProductButton" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.NewProductCommand}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Add" />
                            <TextBlock Text="New" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>

        <!-- DataGrid -->
        <toolkit:DataGrid x:Name="ProductsDataGrid"
                          Grid.Row="2"
                          ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          CanUserSortColumns="True"
                          Sorting="OnDataGridSorting"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
            <toolkit:DataGrid.Columns>
                <!-- Name -->
                <toolkit:DataGridTextColumn Header="Name" Binding="{Binding Name}" Tag="name" Width="2*" MinWidth="200" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" ElementStyle="{StaticResource LeftAlignedCellStyle}" />
                <!-- SKU -->
                <toolkit:DataGridTextColumn Header="SKU" Binding="{Binding BaseSku}" Tag="baseSku" Width="*" MinWidth="120" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" ElementStyle="{StaticResource LeftAlignedCellStyle}" />
                <!-- Category -->
                <toolkit:DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Tag="category" Width="*" MinWidth="120" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" ElementStyle="{StaticResource LeftAlignedCellStyle}" />
                <!-- Brand -->
                <toolkit:DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Tag="brand" Width="*" MinWidth="120" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" ElementStyle="{StaticResource LeftAlignedCellStyle}" />
                
                <!-- Price -->
                <toolkit:DataGridTemplateColumn Header="Base Price" Tag="basePrice" Width="120" MinWidth="120" HeaderStyle="{StaticResource RightAlignedHeaderStyle}">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="shared:ProductDto">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4" Margin="0,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind BasePriceCurrency}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind BasePriceAmount}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>

                <!-- Stock -->
                <toolkit:DataGridTextColumn Header="Stock" Binding="{Binding TotalStock}" Width="100" MinWidth="100" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}" />

                <!-- Status Badge -->
                <toolkit:DataGridTemplateColumn Header="Status" Tag="isActive" Width="100" MinWidth="100" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="shared:ProductDto">
                            <Border Style="{StaticResource StatusBadgeStyle}" 
                                    Background="{x:Bind IsActive, Converter={StaticResource StatusBackgroundConverter}}">
                                <TextBlock Text="{x:Bind IsActive, Converter={StaticResource StatusTextConverter}}"
                                           Style="{StaticResource StatusBadgeTextStyle}"
                                           Foreground="{x:Bind IsActive, Converter={StaticResource StatusForegroundConverter}}" />
                            </Border>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>

                <!-- Row Actions -->
                <toolkit:DataGridTemplateColumn Header="Actions" Width="160" MinWidth="160" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                    <toolkit:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="shared:ProductDto">
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                <!-- Activate -->
                                <Button Content="&#xE73E;" FontFamily="Segoe MDL2 Assets" ToolTipService.ToolTip="Activate" Style="{StaticResource SubtleButtonStyle}" Click="OnActivateClick"
                                        IsEnabled="{x:Bind CanActivate, Mode=OneTime}"
                                        Visibility="{x:Bind IsActive, Mode=OneTime, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
                                <!-- Deactivate (Cannot Delete) -->
                                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" ToolTipService.ToolTip="Deactivate" Style="{StaticResource SubtleButtonStyle}" Click="OnDeactivateClick"
                                        IsEnabled="{x:Bind CanDeactivate, Mode=OneTime}"
                                        Visibility="{x:Bind IsActive, Mode=OneTime, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <AppBarSeparator />
                                <!-- View Details -->
                                <Button Content="&#xE890;" FontFamily="Segoe MDL2 Assets" ToolTipService.ToolTip="View Details" Style="{StaticResource SubtleButtonStyle}" Click="OnViewClick" />
                                <AppBarSeparator />
                                <!-- Edit -->
                                <Button Content="&#xE70F;" FontFamily="Segoe MDL2 Assets" ToolTipService.ToolTip="Edit" Style="{StaticResource SubtleButtonStyle}" Click="OnEditClick"
                                        IsEnabled="{x:Bind CanEdit, Mode=OneTime}" />
                            </StackPanel>
                        </DataTemplate>
                    </toolkit:DataGridTemplateColumn.CellTemplate>
                </toolkit:DataGridTemplateColumn>
            </toolkit:DataGrid.Columns>
        </toolkit:DataGrid>

        <!-- No Data Message -->
        <StackPanel Grid.Row="2"
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Spacing="16"
                    Visibility="{x:Bind ViewModel.HasNoData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <SymbolIcon Symbol="Shop" RenderTransformOrigin="0.5,0.5">
                <SymbolIcon.RenderTransform>
                    <ScaleTransform ScaleX="2" ScaleY="2" />
                </SymbolIcon.RenderTransform>
            </SymbolIcon>
            <TextBlock HorizontalAlignment="Center" Text="No products found." Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock HorizontalAlignment="Center" Text="Try adjusting your filters or add a new product." Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Loading Indicator -->
        <ProgressRing Grid.Row="2" 
                      IsActive="{x:Bind ViewModel.IsListLoading, Mode=OneWay}" 
                      Width="50" Height="50" 
                      HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- Pagination -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Rows Per Page (Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Rows per page:" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" />
                <ComboBox ItemsSource="{x:Bind ViewModel.PageSizes}" 
                          SelectedItem="{x:Bind ViewModel.PageSize, Mode=TwoWay}"
                          Width="80" />
            </StackPanel>

            <!-- Page Summary (Center) -->
            <TextBlock Grid.Column="1" 
                       Text="{x:Bind ViewModel.PageSummary, Mode=OneWay}" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       Style="{StaticResource CaptionTextBlockStyle}" />

            <!-- Navigation Buttons (Right) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16">
                <Button Content="Previous" Command="{x:Bind ViewModel.PreviousPageCommand}" IsEnabled="{x:Bind ViewModel.HasPreviousPage, Mode=OneWay}" />
                <Button Content="Next" Command="{x:Bind ViewModel.NextPageCommand}" IsEnabled="{x:Bind ViewModel.HasNextPage, Mode=OneWay}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
