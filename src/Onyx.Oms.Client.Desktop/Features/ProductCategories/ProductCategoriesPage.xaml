<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.ProductCategories.ProductCategoriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.ProductCategories"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Global Header -->
        <Grid Grid.Row="0" Padding="16,12"
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       Text="Product Categories" 
                       Style="{StaticResource SubtitleTextBlockStyle}" 
                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0"/>

            <StackPanel x:Name="NewRootCategoryButton" Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Style="{StaticResource SubtleButtonStyle}" 
                        Click="OnRefreshClick" ToolTipService.ToolTip="Refresh List">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                </Button>
                <AppBarSeparator />
                <Button Style="{StaticResource AccentButtonStyle}" 
                        Click="OnNewRootCategoryClick" ToolTipService.ToolTip="New Root Category">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="New Category" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content Split View -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="250" MaxWidth="500" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Master Pane -->
            <Grid Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}">

                <TreeView x:Name="CategoriesTreeView"
                          ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                          SelectionMode="Single"
                          Padding="0,8">

                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="local:ProductCategoryTreeDto">
                            <TreeViewItem ItemsSource="{x:Bind SubCategories, Mode=OneWay}" IsExpanded="True">
                                <StackPanel Orientation="Horizontal" Spacing="10" Padding="0,4">
                                    <FontIcon FontFamily="ms-appx:///Assets/Fonts/fa-solid-900.ttf#Font Awesome 6 Free" 
                                              Glyph="{x:Bind IconGlyph, TargetNullValue='&#xF07B;'}" 
                                              Foreground="{x:Bind IconColorBrush}" 
                                              FontSize="14" />

                                    <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyTextBlockStyle}" />

                                    <Ellipse Width="6" Height="6" Fill="{ThemeResource SystemFillColorCriticalBrush}" 
                                             Visibility="{x:Bind IsActive, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                             ToolTipService.ToolTip="Inactive"/>
                                </StackPanel>
                            </TreeViewItem>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <Grid Background="{ThemeResource LayerFillColorDefaultBrush}" Opacity="0.8" 
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressRing IsActive="True" />
                </Grid>

            </Grid>

            <!-- Detail Pane -->
            <Grid Grid.Column="1" Background="{ThemeResource LayerFillColorAltBrush}">

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16"
                            Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                    <FontIcon Glyph="&#xE8F4;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="Select a category to manage details" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <Grid Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Padding="16,12" 
                          CornerRadius="4,0,0,0"
                          Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind ViewModel.SelectedCategory.Name, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <Border Style="{StaticResource StatusBadgeStyle}" 
                                        Background="{x:Bind ViewModel.SelectedCategory.IsActive, Mode=OneWay, Converter={StaticResource StatusBackgroundConverter}}">

                                    <TextBlock Text="{x:Bind ViewModel.SelectedCategory.IsActive, Mode=OneWay, Converter={StaticResource StatusTextConverter}}"
                                               Style="{StaticResource StatusBadgeTextStyle}"
                                               Foreground="{x:Bind ViewModel.SelectedCategory.IsActive, Mode=OneWay, Converter={StaticResource StatusForegroundConverter}}" />
                                </Border>
                            </StackPanel>

                            <TextBlock Text="{x:Bind ViewModel.SelectedCategory.NamePath, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Click="OnEditCategoryClick" 
                                    Style="{StaticResource SubtleButtonStyle}"
                                    IsEnabled="{x:Bind ViewModel.SelectedCategory.CanEdit, Mode=OneWay}"
                                    ToolTipService.ToolTip="Edit Details">
                                <FontIcon Glyph="&#xE70F;" FontSize="16" />
                            </Button>

                            <Button Click="OnAddSubcategoryClick" 
                                    Style="{StaticResource SubtleButtonStyle}"
                                    IsEnabled="{x:Bind ViewModel.SelectedCategory.CanAddSubcategory, Mode=OneWay}"
                                    ToolTipService.ToolTip="Add Child Category">
                                <FontIcon Glyph="&#xE710;" FontSize="16" />
                            </Button>

                            <AppBarSeparator />

                            <Button Click="OnActivateCategoryClick" 
                                    Style="{StaticResource SubtleButtonStyle}"
                                    IsEnabled="{x:Bind ViewModel.SelectedCategory.CanToggleStatus, Mode=OneWay}" 
                                    Visibility="{x:Bind ViewModel.SelectedCategory.IsActive, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                    ToolTipService.ToolTip="Activate this Category">
                                <FontIcon Glyph="&#xE73E;" FontSize="16" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                            </Button>

                            <Button Click="OnDeactivateCategoryClick" 
                                    Style="{StaticResource SubtleButtonStyle}"
                                    IsEnabled="{x:Bind ViewModel.SelectedCategory.CanToggleStatus, Mode=OneWay}" 
                                    Visibility="{x:Bind ViewModel.SelectedCategory.IsActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                    ToolTipService.ToolTip="Deactivate this Category">
                                <FontIcon Glyph="&#xE711;" FontSize="16" Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                            </Button>
                            
                            <Button Click="OnDeleteCategoryClick" 
                                    Style="{StaticResource SubtleButtonStyle}"
                                    IsEnabled="{x:Bind ViewModel.SelectedCategory.CanDelete, Mode=OneWay}"
                                    ToolTipService.ToolTip="Delete this Category">
                                <FontIcon Glyph="&#xE74D;" FontSize="16" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                            </Button>
                        </StackPanel>

                    </Grid>

                    <ScrollViewer Grid.Row="1" Padding="16">

                        <Grid ColumnSpacing="16">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="16">

                                <Grid Style="{StaticResource CardGridStyle}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="General Information" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,16"/>

                                    <TextBlock Grid.Row="1" Text="Description" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="2" Text="{x:Bind ViewModel.SelectedCategory.Description, Mode=OneWay}" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}" />

                                </Grid>

                                <Grid Style="{StaticResource CardGridStyle}">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Metadata" Style="{StaticResource BodyStrongTextBlockStyle}" />

                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Display Order" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Text="{x:Bind ViewModel.SelectedCategory.DisplayOrder, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Color" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Ellipse Width="12" Height="12" Fill="{x:Bind ViewModel.SelectedCategory.IconColorBrush, Mode=OneWay}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedCategory.Color, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                            </StackPanel>

                            <StackPanel Grid.Column="1" Style="{StaticResource CardStackStyle}" Spacing="0" Padding="0">
                                <Grid CornerRadius="4" Padding="20,16" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <TextBlock Text="Defined Specifications" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                </Grid>
                                
                                <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedCategoryDetails.Specifications, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:SpecDefinition">
                                            <Grid Padding="20,12" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="1*" />
                                                    <ColumnDefinition Width="1*" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel>
                                                    <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{x:Bind Key}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontFamily="Consolas"/>
                                                </StackPanel>
                                                
                                                <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" VerticalAlignment="Center" HorizontalAlignment="Left" CornerRadius="4" Padding="8,2" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1">
                                                    <TextBlock Text="{x:Bind Type}" Style="{StaticResource CaptionTextBlockStyle}" />
                                                </Border>
                                                
                                                <Border Grid.Column="2" Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" CornerRadius="4" Padding="8,2" Visibility="{x:Bind IsRequired, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="Required" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            
                        </Grid>
                        
                    </ScrollViewer>
                    
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Page>
