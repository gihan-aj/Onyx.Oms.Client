<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Onyx.Oms.Client.Desktop.Shared.Shell.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- Background is Transparent to let Window's MicaBackdrop show through -->
        <Grid.Background>
            <SolidColorBrush Color="Transparent" />
        </Grid.Background>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <!-- Logo area -->
            <Image Source="/Assets/StoreLogo.png" Width="120" Height="120" />
            
            <TextBlock Text="Welcome to Onyx OMS" 
                       Style="{StaticResource TitleTextBlockStyle}" 
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

            <TextBlock x:Name="LoginText" Text="Please sign in to continue" 
                       Style="{StaticResource BodyTextBlockStyle}" 
                       HorizontalAlignment="Center" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            
            <TextBlock x:Name="LoadingText" Text="Authenticating..." 
                       Style="{StaticResource BodyTextBlockStyle}" 
                       HorizontalAlignment="Center" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <Grid Height="40">
                <Button x:Name="LoginButton" 
                        Content="Sign In with OpenID" 
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center" 
                        Width="200" 
                        Height="40"
                        CornerRadius="20"
                        Click="LoginButton_Click"/>

                <ProgressRing x:Name="LoadingSpinner" 
                              IsActive="False" 
                              Visibility="Collapsed" 
                              Width="32" 
                              Height="32" 
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
            </Grid>

            <!-- Error Message -->
            <TextBlock x:Name="ErrorMessageText"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"
                       MaxWidth="300" />
                       
            <!-- Create Account Button -->
            <Button x:Name="RegisterButton" 
                    Content="Create an Account" 
                    Style="{StaticResource SubtleButtonStyle}"
                    HorizontalAlignment="Center" 
                    Margin="0,8,0,0"
                    Click="RegisterButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
