<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Couriers.CouriersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Couriers"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header and Filters -->
        <Grid Grid.Row="0" Padding="16,12" 
              Background="{ThemeResource LayerFillColorDefaultBrush}" 
              ColumnSpacing="8" RowSpacing="12">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Top Row: Title, Search, Actions -->
            <TextBlock Grid.Row="0" Grid.Column="0" 
                       Text="Couriers" 
                       Style="{StaticResource SubtitleTextBlockStyle}" 
                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0"/>

            <AutoSuggestBox Grid.Row="0" Grid.Column="1" 
                            PlaceholderText="Search couriers..."
                            QueryIcon="Find"
                            Width="320"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QuerySubmitted="OnQuerySubmitted" />

            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Click="OnRefreshClick" Style="{StaticResource SubtleButtonStyle}" ToolTipService.ToolTip="Refresh Data">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                </Button>

                <AppBarSeparator />

                <Button x:Name="NewCourierButton" Style="{StaticResource AccentButtonStyle}" Click="OnNewClick">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="New Courier" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Filters -->
            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="16">
                <ComboBox ItemsSource="{x:Bind ViewModel.StatusOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedStatus, Mode=TwoWay}"
                          PlaceholderText="Status"
                          Width="120"/>

                <Button Content="Clear Filters" Style="{StaticResource SubtleButtonStyle}"
                        Command="{x:Bind ViewModel.ClearFiltersCommand}"/>
            </StackPanel>

        </Grid>

        <!-- DataGrid Container -->
        <Grid Grid.Row="1" x:Name="TableContainer">
            
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Enabled"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Disabled">

                <toolkit:DataGrid x:Name="CouriersDataGrid"
                                  Width="{Binding ActualWidth, ElementName=TableContainer}"
                                  MinWidth="880"
                                  ItemsSource="{x:Bind ViewModel.Couriers, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{ThemeResource LayerFillColorDefaultBrush}"
                                  HeadersVisibility="Column"
                                  CanUserSortColumns="True"
                                  Sorting="OnDataGridSorting"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Hidden">
                                  
                    <toolkit:DataGrid.RowStyle>
                        <Style TargetType="toolkit:DataGridRow">
                            <Setter Property="ContextFlyout">
                                <Setter.Value>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="View Details" Icon="ContactInfo" Click="OnContextViewClick" IsEnabled="{Binding CanView, Mode=OneTime}" />
                                        
                                        <MenuFlyoutSeparator />
                                        
                                        <MenuFlyoutItem Text="Edit" Icon="Edit" Click="OnContextEditClick" IsEnabled="{Binding CanEdit, Mode=OneTime}" />
                                        <MenuFlyoutItem Text="Activate" Icon="Play" Click="OnContextActivateClick" 
                                                        IsEnabled="{Binding CanToggleStatus, Mode=OneTime}"
                                                        Visibility="{Binding IsActive, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
                                        <MenuFlyoutItem Text="Deactivate" Icon="Pause" Click="OnContextDeactivateClick" 
                                                        IsEnabled="{Binding CanToggleStatus, Mode=OneTime}"
                                                        Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        
                                        <MenuFlyoutSeparator />
                                        
                                        <MenuFlyoutItem Text="Delete" Icon="Delete" Foreground="Red" Click="OnContextDeleteClick" IsEnabled="{Binding CanDelete, Mode=OneTime}" />
                                    </MenuFlyout>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </toolkit:DataGrid.RowStyle>
                    <toolkit:DataGrid.Columns>
                        <toolkit:DataGridTextColumn Header="Name" Binding="{Binding Name}" Tag="name" Width="*" MinWidth="150" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" ElementStyle="{StaticResource LeftAlignedCellStyle}" />
                        <toolkit:DataGridTextColumn Header="Contact Person" Binding="{Binding ContactPerson}" Tag="contactPerson" Width="200" MinWidth="150" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" ElementStyle="{StaticResource LeftAlignedCellStyle}" />
                        <toolkit:DataGridTextColumn Header="Phone" Binding="{Binding PrimaryPhone}" Tag="primaryPhone" Width="150" MinWidth="130" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}" />
                        <toolkit:DataGridTextColumn Header="Website" Binding="{Binding WebsiteUrl}" Tag="websiteUrl" Width="200" MinWidth="150" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" ElementStyle="{StaticResource LeftAlignedCellStyle}" />
                
                        <toolkit:DataGridTemplateColumn Header="Status" Tag="isActive" Width="100" MinWidth="100" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                            <toolkit:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StatusBadgeStyle}" 
                                            Background="{Binding IsActive, Converter={StaticResource StatusBackgroundConverter}}">
                                        <TextBlock Text="{Binding IsActive, Converter={StaticResource StatusTextConverter}}"
                                                   Style="{StaticResource StatusBadgeTextStyle}"
                                                   Foreground="{Binding IsActive, Converter={StaticResource StatusForegroundConverter}}" />
                                    </Border>
                                </DataTemplate>
                            </toolkit:DataGridTemplateColumn.CellTemplate>
                        </toolkit:DataGridTemplateColumn>

                        <toolkit:DataGridTemplateColumn Width="80" MinWidth="80" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                            <toolkit:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="local:CourierDto">
                                    <Button Style="{StaticResource SubtleButtonStyle}" 
                                            Background="Transparent"
                                            HorizontalAlignment="Stretch" 
                                            VerticalAlignment="Stretch"
                                            ToolTipService.ToolTip="Actions"
                                            Tapped="OnActionButtonTapped">

                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE712;" />

                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="View Details" Icon="ContactInfo" Click="OnViewClick" IsEnabled="{Binding CanView, Mode=OneTime}" />
                                        
                                                <MenuFlyoutSeparator />
                                        
                                                <MenuFlyoutItem Text="Edit" Icon="Edit" Click="OnEditClick" IsEnabled="{Binding CanEdit, Mode=OneTime}" />
                                                <MenuFlyoutItem Text="Activate" Icon="Play" Click="OnActivateClick" 
                                                                IsEnabled="{Binding CanToggleStatus, Mode=OneTime}"
                                                                Visibility="{Binding IsActive, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
                                                <MenuFlyoutItem Text="Deactivate" Icon="Pause" Click="OnDeactivateClick" 
                                                                IsEnabled="{Binding CanToggleStatus, Mode=OneTime}"
                                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        
                                                <MenuFlyoutSeparator />
                                        
                                                <MenuFlyoutItem Text="Delete" Icon="Delete" Foreground="Red" Click="OnDeleteClick" IsEnabled="{Binding CanDelete, Mode=OneTime}" />
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </DataTemplate>
                            </toolkit:DataGridTemplateColumn.CellTemplate>
                        </toolkit:DataGridTemplateColumn>
                    </toolkit:DataGrid.Columns>
                </toolkit:DataGrid>
            </ScrollViewer>
        </Grid>

        <!-- Loading Indicator -->
        <Grid Grid.Row="1" Background="{ThemeResource LayerFillColorAltBrush}" Opacity="0.8" 
              Visibility="{x:Bind ViewModel.IsListLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressRing IsActive="True" Width="48" Height="48" />
        </Grid>

        <!-- No Data Message -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Spacing="16"
                    Visibility="{x:Bind ViewModel.HasNoData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <FontIcon Glyph="&#xF163;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock HorizontalAlignment="Center" Text="No couriers found." Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Button Content="Clear Search" 
                    Command="{x:Bind ViewModel.RefreshCommand}" 
                    Style="{StaticResource DefaultButtonStyle}" 
                    HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Pagination -->
        <Grid Grid.Row="2" 
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Padding="16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Rows Per Page (Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Rows per page:" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ComboBox ItemsSource="{x:Bind ViewModel.PageSizes}" 
                          SelectedItem="{x:Bind ViewModel.PageSize, Mode=TwoWay}"
                          Style="{StaticResource DefaultComboBoxStyle}"
                          MinWidth="80" 
                          VerticalAlignment="Center" />
            </StackPanel>

            <!-- Page Summary (Center) -->
            <TextBlock Grid.Column="1" 
                       Text="{x:Bind ViewModel.PageSummary, Mode=OneWay}" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       Style="{StaticResource CaptionTextBlockStyle}" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <!-- Navigation Buttons (Right) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.PreviousPageCommand}" IsEnabled="{x:Bind ViewModel.HasPreviousPage, Mode=OneWay}" ToolTipService.ToolTip="Previous Page">
                    <FontIcon Glyph="&#xE76B;" FontSize="12" />
                </Button>
                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.NextPageCommand}" IsEnabled="{x:Bind ViewModel.HasNextPage, Mode=OneWay}" ToolTipService.ToolTip="Next Page">
                    <FontIcon Glyph="&#xE76C;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
