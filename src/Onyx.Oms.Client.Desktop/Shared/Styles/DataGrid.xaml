<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives">

    <!-- 
        Centered Header Style 
        Note: DataGridColumnHeader has default Padding. The sort icon appears on the right.
        To center text visualy, we might need to adjust padding or margin.
        If Sort icon is reserved space, text might look off-center.
    -->
    <Style x:Key="CenteredHeaderStyle" TargetType="primitives:DataGridColumnHeader">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="30,0,0,0" />
    </Style>
    
    <Style x:Key="LeftAlignedHeaderStyle" TargetType="primitives:DataGridColumnHeader">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    
    <Style x:Key="RightAlignedHeaderStyle" TargetType="primitives:DataGridColumnHeader">
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="Padding" Value="0,0,12,0" /> 
    </Style>

    <!-- Cell Content Styles (for DataGridTextColumn ElementStyle) -->
    <Style x:Key="LeftAlignedCellStyle" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CenteredCellStyle" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="RightAlignedCellStyle" TargetType="TextBlock">
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Padding" Value="0,0,12,0" />
    </Style>

</ResourceDictionary>
