<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Products.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Products"
    xmlns:controls="using:Onyx.Oms.Client.Desktop.Features.Products.Controls"
    xmlns:shared="using:Onyx.Oms.Client.Desktop.Shared.Models"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header & Filters (Row 0) -->
        <Grid Grid.Row="0" Padding="16,12" 
              Background="{ThemeResource LayerFillColorDefaultBrush}" 
              BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
              ColumnSpacing="8" RowSpacing="12">
              
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Top Row: Title, Search, Actions -->
            <TextBlock Grid.Row="0" Grid.Column="0" 
                       Text="Products" 
                       Style="{StaticResource SubtitleTextBlockStyle}" 
                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0"/>

            <AutoSuggestBox Grid.Row="0" Grid.Column="1" 
                            PlaceholderText="Search products by SKU or Name..."
                            QueryIcon="Find"
                            Width="320"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QuerySubmitted="OnQuerySubmitted" />

            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.RefreshCommand}" Style="{StaticResource SubtleButtonStyle}" ToolTipService.ToolTip="Refresh Data">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                </Button>

                <AppBarSeparator />

                <Button x:Name="NewProductButton" Command="{x:Bind ViewModel.NewProductCommand}" Style="{StaticResource AccentButtonStyle}" IsEnabled="{x:Bind ViewModel.CanCreateProduct}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="New Product" />
                    </StackPanel>
                </Button>
            </StackPanel>
            
            <!-- Bottom Row: Additional Filters -->
            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="16">
                 <!-- Vertical Slice Category Picker -->
                <controls:LeafProductCategoryPicker x:Name="CategoryPicker" 
                                                    Width="200" 
                                                    PlaceholderText="Select Category"
                                                    SelectedCategory="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}" />

                <!-- Status Filter -->
                <ComboBox ItemsSource="{x:Bind ViewModel.StatusOptions}" 
                          SelectedItem="{x:Bind ViewModel.SelectedStatus, Mode=TwoWay}"
                          PlaceholderText="Status"
                          Width="120" />

                <!-- Has Variants Filter -->
                <!--<ComboBox ItemsSource="{x:Bind ViewModel.HasVariantsOptions}" 
                          SelectedItem="{x:Bind ViewModel.SelectedHasVariants, Mode=TwoWay}"
                          PlaceholderText="Has Variants"
                          Width="120" />-->
                
                <!-- Clear Filters -->
                <Button Content="Clear Filters" Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.ClearFiltersCommand}" />
            </StackPanel>
        </Grid>

        <!-- DataGrid & Content (Row 1) -->
        <Grid Grid.Row="1" Background="{ThemeResource LayerFillColorAltBrush}">

            <toolkit:DataGrid x:Name="ProductsDataGrid"
                              ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              CanUserSortColumns="True"
                              Sorting="OnDataGridSorting"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              BorderThickness="0"
                              RowBackground="Transparent"
                              AlternatingRowBackground="{ThemeResource LayerFillColorDefaultBrush}">
                              
                <toolkit:DataGrid.Columns>
                    <!-- Name -->
                    <toolkit:DataGridTextColumn Header="Name" 
                                                Binding="{Binding Name}" Tag="name" 
                                                Width="2*" MinWidth="200" 
                                                FontWeight="SemiBold"
                                                HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" 
                                                ElementStyle="{StaticResource LeftAlignedCellStyle}" />
                    <!-- SKU -->
                    <toolkit:DataGridTextColumn Header="SKU" Binding="{Binding BaseSku}" Tag="baseSku" Width="*" MinWidth="120" FontFamily="Consolas" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" ElementStyle="{StaticResource LeftAlignedCellStyle}" />
                    <!-- Category -->
                    <toolkit:DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Tag="category" Width="*" MinWidth="120" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" ElementStyle="{StaticResource LeftAlignedCellStyle}" />
                    
                    <!-- Price -->
                    <toolkit:DataGridTemplateColumn Header="Base Price" Tag="basePrice" Width="120" MinWidth="120" HeaderStyle="{StaticResource RightAlignedHeaderStyle}">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="local:ProductDto">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind BasePriceCurrency}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind BasePriceAmount}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>

                    <!-- Variants -->
                    <toolkit:DataGridTextColumn Header="Variants" Binding="{Binding HasVariantsText}" Tag="hasVariants" Width="100" MinWidth="100" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" ElementStyle="{StaticResource LeftAlignedCellStyle}" />

                    <!-- Status Badge -->
                    <toolkit:DataGridTemplateColumn Header="Status" Tag="isActive" Width="100" MinWidth="100" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="local:ProductDto">
                                <Border Style="{StaticResource StatusBadgeStyle}" 
                                        HorizontalAlignment="Center"
                                        Background="{x:Bind IsActive, Converter={StaticResource StatusBackgroundConverter}}">
                                    <TextBlock Text="{x:Bind IsActive, Converter={StaticResource StatusTextConverter}}"
                                               Style="{StaticResource StatusBadgeTextStyle}"
                                               Foreground="{x:Bind IsActive, Converter={StaticResource StatusForegroundConverter}}" />
                                </Border>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>

                    <!-- Row Actions "Meatballs" Menu -->
                    <toolkit:DataGridTemplateColumn Width="80" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="local:ProductDto">
                                 <Button Content="&#xE712;" FontFamily="Segoe MDL2 Assets" 
                                        Style="{StaticResource SubtleButtonStyle}" 
                                        HorizontalAlignment="Center"
                                        ToolTipService.ToolTip="Actions">

                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="View Details" Icon="View" Click="OnViewClick" />

                                            <MenuFlyoutSeparator />

                                            <MenuFlyoutItem Text="Edit" Icon="Edit" Click="OnEditClick" 
                                                            IsEnabled="{x:Bind CanEdit}" />

                                            <MenuFlyoutItem Text="Activate" Icon="Play" Click="OnActivateClick" 
                                                            Visibility="{x:Bind IsActive, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                                            IsEnabled="{x:Bind CanActivate}" />

                                            <MenuFlyoutItem Text="Deactivate" Icon="Pause" Click="OnDeactivateClick" 
                                                            Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                                            IsEnabled="{x:Bind CanDeactivate}" />
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>
                </toolkit:DataGrid.Columns>
            </toolkit:DataGrid>

            <!-- Loading Indicator -->
             <Grid Background="{ThemeResource LayerFillColorAltBrush}" Opacity="0.8" 
                  Visibility="{x:Bind ViewModel.IsListLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ProgressRing IsActive="True" Width="48" Height="48" />
            </Grid>

            <!-- No Data Message -->
             <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                        Visibility="{x:Bind ViewModel.HasNoData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <FontIcon Glyph="&#xE719;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock HorizontalAlignment="Center" Text="No products found matching your filters." Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Content="Clear Filters" 
                        Command="{x:Bind ViewModel.ClearFiltersCommand}" 
                        Style="{StaticResource DefaultButtonStyle}" 
                        HorizontalAlignment="Center"/>
            </StackPanel>

        </Grid>

        <!-- Pagination (Row 2) -->
        <Grid Grid.Row="2" 
              Background="{ThemeResource LayerFillColorDefaultBrush}" 
              BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" 
              Padding="16,8">
              
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Rows Per Page (Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Rows per page:" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.PageSizes}" 
                          SelectedItem="{x:Bind ViewModel.PageSize, Mode=TwoWay}"
                          Style="{StaticResource DefaultComboBoxStyle}"
                          MinWidth="80" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Page Summary (Center) -->
            <TextBlock Grid.Column="1" 
                       Text="{x:Bind ViewModel.PageSummary, Mode=OneWay}" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}" />

            <!-- Navigation Buttons (Right) -->
             <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.PreviousPageCommand}" IsEnabled="{x:Bind ViewModel.HasPreviousPage, Mode=OneWay}" ToolTipService.ToolTip="Previous Page">
                    <FontIcon Glyph="&#xE76B;" FontSize="12" />
                </Button>
                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.NextPageCommand}" IsEnabled="{x:Bind ViewModel.HasNextPage, Mode=OneWay}" ToolTipService.ToolTip="Next Page">
                    <FontIcon Glyph="&#xE76C;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
