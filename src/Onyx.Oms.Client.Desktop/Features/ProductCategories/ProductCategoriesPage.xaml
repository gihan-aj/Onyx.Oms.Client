<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.ProductCategories.ProductCategoriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.ProductCategories"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Product Categories" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,24" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Pane: TreeView -->
            <Border Grid.Column="0" CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Inner Left Header -->
                    <Grid Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Categories" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                        <Button x:Name="RefreshButton" HorizontalAlignment="Right" Style="{StaticResource SubtleButtonStyle}" Click="OnRefreshClick">
                            <SymbolIcon Symbol="Refresh" />
                        </Button>
                    </Grid>

                    <TreeView x:Name="CategoriesTreeView"
                              Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                              SelectionMode="Single"
                              Margin="8">
                        <TreeView.ItemTemplate>
                            <DataTemplate x:DataType="local:ProductCategoryTreeDto">
                                <TreeViewItem   ItemsSource="{x:Bind SubCategories, Mode=OneWay}" IsExpanded="True">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontFamily="ms-appx:///Assets/Fonts/fa-solid-900.ttf#Font Awesome 6 Free" 
                                                  Glyph="{x:Bind IconGlyph, TargetNullValue='&#xF07B;'}" 
                                                  Foreground="{x:Bind IconColorBrush}" 
                                                  VerticalAlignment="Center" />
                                        <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" />
                                        <TextBlock Text="(Inactive)" 
                                                   Foreground="{ThemeResource TextFillColorDisabledBrush}" 
                                                   VerticalAlignment="Center" 
                                                   Visibility="{x:Bind IsActive, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </TreeViewItem>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                    
                    <!-- Empty State for Left Pane -->
                    <StackPanel Grid.Row="1" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center"
                                Spacing="16"
                                Visibility="{x:Bind ViewModel.HasNoCategories, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <SymbolIcon Symbol="Library" RenderTransformOrigin="0.5,0.5">
                            <SymbolIcon.RenderTransform>
                                <ScaleTransform ScaleX="2" ScaleY="2" />
                            </SymbolIcon.RenderTransform>
                        </SymbolIcon>
                        <TextBlock HorizontalAlignment="Center" Text="No categories found." Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Loading Indicator -->
                    <ProgressRing Grid.Row="1" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                                  Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Right Pane: Details -->
            <Grid Grid.Column="1">
                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" 
                            HorizontalAlignment="Center"
                            Spacing="16"
                            Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                    <SymbolIcon Symbol="List" RenderTransformOrigin="0.5,0.5">
                        <SymbolIcon.RenderTransform>
                            <ScaleTransform ScaleX="2" ScaleY="2" />
                        </SymbolIcon.RenderTransform>
                    </SymbolIcon>
                    <TextBlock HorizontalAlignment="Center" Text="Select a category to view details." Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Button x:Name="NewRootCategoryButton" Style="{StaticResource AccentButtonStyle}" Click="OnNewRootCategoryClick" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Add" />
                            <TextBlock Text="Add New Root Category" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Details Card -->
                <Border CornerRadius="8" 
                        Background="{ThemeResource LayerFillColorDefaultBrush}" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                        BorderThickness="1"
                        Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        VerticalAlignment="Top">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- CommandBar -->
                        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" CornerRadius="8,8,0,0">
                            <AppBarButton x:Name="EditCategoryButton" Icon="Edit" Label="Edit" Click="OnEditCategoryClick" IsEnabled="{x:Bind ViewModel.SelectedCategory.CanEdit, Mode=OneWay}" />
                            <AppBarButton x:Name="AddSubcategoryButton" Icon="Add" Label="Add Sub-category" Click="OnAddSubcategoryClick" IsEnabled="{x:Bind ViewModel.SelectedCategory.CanAddSubcategory, Mode=OneWay}" />
                            <AppBarButton x:Name="ActivateCategoryButton" Icon="Play" Label="Activate" Click="OnActivateCategoryClick" IsEnabled="{x:Bind ViewModel.SelectedCategory.CanToggleStatus, Mode=OneWay}" Visibility="{x:Bind ViewModel.SelectedCategory.IsActive, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
                            <AppBarButton x:Name="DeactivateCategoryButton" Icon="Stop" Label="Deactivate" Click="OnDeactivateCategoryClick" IsEnabled="{x:Bind ViewModel.SelectedCategory.CanToggleStatus, Mode=OneWay}" Visibility="{x:Bind ViewModel.SelectedCategory.IsActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <AppBarButton x:Name="DeleteCategoryButton" Icon="Delete" Label="Delete" Click="OnDeleteCategoryClick" IsEnabled="{x:Bind ViewModel.SelectedCategory.CanDelete, Mode=OneWay}" Foreground="Red" />
                        </CommandBar>

                        <!-- Content -->
                        <StackPanel Grid.Row="1" Padding="24" Spacing="16">
                            <!-- Basic Info -->
                            <TextBlock Text="{x:Bind ViewModel.SelectedCategory.Name, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" />
                            
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Style="{StaticResource StatusBadgeStyle}" 
                                        Background="{x:Bind ViewModel.SelectedCategory.IsActive, Mode=OneWay, Converter={StaticResource StatusBackgroundConverter}}">
                                    <TextBlock Text="{x:Bind ViewModel.SelectedCategory.IsActive, Mode=OneWay, Converter={StaticResource StatusTextConverter}}"
                                               Style="{StaticResource StatusBadgeTextStyle}"
                                               Foreground="{x:Bind ViewModel.SelectedCategory.IsActive, Mode=OneWay, Converter={StaticResource StatusForegroundConverter}}" />
                                </Border>
                                <TextBlock Text="Level:" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="8,0,0,0"/>
                                <TextBlock Text="{x:Bind ViewModel.SelectedCategory.Level, Mode=OneWay}" VerticalAlignment="Center" />
                            </StackPanel>

                            <Line Stroke="{ThemeResource DividerStrokeColorDefaultBrush}" X2="400" StrokeThickness="1" Margin="0,8"/>

                            <!-- Details Grid -->
                            <Grid RowSpacing="12" ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Path:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCategory.NamePath, Mode=OneWay, FallbackValue='N/A'}" TextWrapping="Wrap" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Display Order:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.SelectedCategory.DisplayOrder, Mode=OneWay}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Color Code:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="16" Height="16" Fill="{x:Bind ViewModel.SelectedCategory.IconColorBrush, Mode=OneWay}" Stroke="{ThemeResource CardStrokeColorDefaultBrush}" StrokeThickness="1" />
                                    <TextBlock Text="{x:Bind ViewModel.SelectedCategory.Color, Mode=OneWay, FallbackValue='None'}" />
                                </StackPanel>
                            </Grid>
                            
                            <Line Stroke="{ThemeResource DividerStrokeColorDefaultBrush}" X2="400" StrokeThickness="1" Margin="0,8"/>
                            
                            <TextBlock Text="Description" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedCategory.Description, Mode=OneWay, FallbackValue='No description provided.'}" TextWrapping="Wrap" />
                            
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
