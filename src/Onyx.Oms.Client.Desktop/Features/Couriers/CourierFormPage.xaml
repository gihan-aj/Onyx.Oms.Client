<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Couriers.CourierFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Couriers"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToObjectConverter x:Key="InvertedBoolConverter" TrueValue="False" FalseValue="True" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
        <converters:EmptyStringToObjectConverter x:Key="StringToVisibilityConverter" EmptyValue="Collapsed" NotEmptyValue="Visible" />

        <!-- Zone rate row column widths -->
        <x:Double x:Key="ZoneNameColumnWidth">180</x:Double>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header / Toolbar -->
        <Grid Grid.Row="0" Padding="16,12" 
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{x:Bind ViewModel.CancelCommand}" 
                    Style="{StaticResource SubtleButtonStyle}" Margin="0,0,16,0">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}" 
                           Style="{StaticResource SubtitleTextBlockStyle}" 
                           FontWeight="SemiBold" />

                <!-- Badge -->
                <Border Style="{StaticResource StatusBadgeStyle}" 
                        Background="{x:Bind ViewModel.IsActive, Mode=OneWay, Converter={StaticResource StatusBackgroundConverter}}"
                        Visibility="{x:Bind ViewModel.IsEditMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{x:Bind ViewModel.IsActive, Mode=OneWay, Converter={StaticResource StatusTextConverter}}"
                               Style="{StaticResource StatusBadgeTextStyle}"
                               Foreground="{x:Bind ViewModel.IsActive, Mode=OneWay, Converter={StaticResource StatusForegroundConverter}}" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.SaveCommand}" Style="{StaticResource AccentButtonStyle}" 
                        IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" FontSize="14" />
                            <TextBlock Text="Save Changes" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Progress Bar (Saving) -->
        <ProgressBar Grid.Row="0"
                     VerticalAlignment="Bottom"
                     HorizontalAlignment="Stretch"
                     IsIndeterminate="True"
                     Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                     Canvas.ZIndex="100"/>

        <!-- Form Scrolling Region -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            
            <!-- Hide form completely while primarily loading -->
            <Grid Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10000*" MaxWidth="1200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" Spacing="16">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" MinWidth="350" />
                            <ColumnDefinition Width="1.2*" MinWidth="350" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="16">
                            
                            <!-- Identity Card -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <TextBlock Text="Company Details" Style="{StaticResource BodyStrongTextBlockStyle}" />

                                <StackPanel>
                                    <TextBox Header="Name*" Text="{x:Bind ViewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             PlaceholderText="Enter courier name" />
                                    <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}" 
                                               Text="{x:Bind ViewModel.NameError, Mode=OneWay}"
                                               Visibility="{x:Bind ViewModel.NameError, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"
                                               Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" />
                                </StackPanel>

                                <TextBox Header="Contact Person" Text="{x:Bind ViewModel.ContactPerson, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         PlaceholderText="Enter contact person" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Column -->
                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="16">
                            
                            <!-- Contact Card -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <TextBlock Text="Contact Information" Style="{StaticResource BodyStrongTextBlockStyle}" />

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0" Header="Primary Phone" Text="{x:Bind ViewModel.PrimaryPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             InputScope="TelephoneNumber"
                                             FontFamily="Consolas"
                                             PlaceholderText="Enter primary phone" />

                                    <TextBox Grid.Column="1" Header="Secondary Phone" Text="{x:Bind ViewModel.SecondaryPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             InputScope="TelephoneNumber"
                                             FontFamily="Consolas"
                                             PlaceholderText="Enter secondary phone" />
                                </Grid>

                                <TextBox Header="Website URL" Text="{x:Bind ViewModel.WebsiteUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         InputScope="Url"
                                         PlaceholderText="https://" />
                            </StackPanel>
                        </StackPanel>
                        
                    </Grid>

                    <!-- ═══════════════════════════════════════════════════════════════ -->
                    <!-- Zone Rates Card (full width below the two-column details grid) -->
                    <!-- ═══════════════════════════════════════════════════════════════ -->
                    <Grid Style="{StaticResource CardGridStyle}" RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Card Header -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="2">
                                <TextBlock Text="Zone Rates" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Configure the pricing matrix for each delivery zone."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    x:Name="AddZoneRateButton"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="OnAddZoneRateClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                                    <TextBlock Text="Add Zone Rate" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Column Header Row -->
                        <Grid Grid.Row="1" ColumnSpacing="8"
                              Visibility="{x:Bind ViewModel.HasZoneRates, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="76" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Zone" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Column="1" Text="Base Fee" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Column="2" Text="Base Wt (kg)" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Column="3" Text="Excess/kg" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Column="4" Text="COD %" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Column="5" Text="Districts" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>

                        <!-- Zone Rate Rows -->
                        <ListView Grid.Row="2"
                                  x:Name="ZoneRatesListView"
                                  ItemsSource="{x:Bind ViewModel.ZoneRates, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  Visibility="{x:Bind ViewModel.HasZoneRates, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,2" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:ZoneRateFormItem">
                                    <Grid ColumnSpacing="8" Padding="0,6"
                                          Background="{ThemeResource LayerFillColorDefaultBrush}"
                                          CornerRadius="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="76" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Zone Name + Default badge -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Padding="8,0,0,0">
                                            <TextBlock Text="{x:Bind ZoneName, Mode=OneWay}"
                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                                    BorderBrush="{ThemeResource SystemFillColorSuccessBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="5,2"
                                                    VerticalAlignment="Center"
                                                    Visibility="{x:Bind IsDefault, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="Default"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                            </Border>
                                        </StackPanel>

                                        <!-- Base Fee -->
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                   Text="{x:Bind BaseFee, Mode=OneWay}"
                                                   Style="{StaticResource BodyTextBlockStyle}" />

                                        <!-- Base Weight -->
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                   Text="{x:Bind BaseWeight, Mode=OneWay}"
                                                   Style="{StaticResource BodyTextBlockStyle}" />

                                        <!-- Excess Fee -->
                                        <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                                   Text="{x:Bind ExcessFeePerWeightUnit, Mode=OneWay}"
                                                   Style="{StaticResource BodyTextBlockStyle}" />

                                        <!-- COD % -->
                                        <TextBlock Grid.Column="4" VerticalAlignment="Center"
                                                   Text="{x:Bind CodPercentage, Mode=OneWay}"
                                                   Style="{StaticResource BodyTextBlockStyle}" />

                                        <!-- Districts summary -->
                                        <TextBlock Grid.Column="5" VerticalAlignment="Center"
                                                   Text="{x:Bind DistrictsSummary, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   ToolTipService.ToolTip="{x:Bind DistrictsSummary, Mode=OneWay}" />

                                        <!-- Action Buttons -->
                                        <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="0,0,4,0">
                                            <Button Style="{StaticResource SubtleButtonStyle}"
                                                    ToolTipService.ToolTip="Edit Zone"
                                                    Click="OnEditZoneRateClick"
                                                    Tag="{x:Bind}">
                                                <FontIcon Glyph="&#xE70F;" FontSize="13" />
                                            </Button>
                                            <Button Style="{StaticResource SubtleButtonStyle}"
                                                    ToolTipService.ToolTip="Remove Zone"
                                                    Click="OnRemoveZoneRateClick"
                                                    Tag="{x:Bind}">
                                                <FontIcon Glyph="&#xE74D;" FontSize="13"
                                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Empty State -->
                        <StackPanel Grid.Row="2"
                                    HorizontalAlignment="Center"
                                    Spacing="8"
                                    Padding="0,16"
                                    Visibility="{x:Bind ViewModel.HasZoneRates, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                            <FontIcon Glyph="&#xE8B9;" FontSize="32" Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="No zone rates configured."
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Add at least one zone rate before saving."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                    </Grid>
                    <!-- End Zone Rates Card -->

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Initial Load Spinner -->
        <Grid Grid.RowSpan="2" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" Opacity="0.8" 
              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
              Canvas.ZIndex="101">
            <ProgressRing IsActive="True" Width="64" Height="64" />
        </Grid>

    </Grid>
</Page>
