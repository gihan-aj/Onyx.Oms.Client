<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.FulfillmentTasks.Create.CreateFulfillmentTaskPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.FulfillmentTasks.Create"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
        <converters:EmptyStringToObjectConverter x:Key="StringToVisibilityConverter" EmptyValue="Collapsed" NotEmptyValue="Visible" />
        <converters:BoolNegationConverter x:Key="InvertedBoolConverter" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Command="{x:Bind ViewModel.CancelCommand}" Style="{StaticResource SubtleButtonStyle}" Margin="0,0,16,0">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.SaveCommand}" Style="{StaticResource AccentButtonStyle}" 
                        IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" FontSize="14" />
                            <TextBlock Text="Create Task" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>

        <ProgressBar Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                     IsIndeterminate="True" Canvas.ZIndex="100"
                     Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <Grid Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10000*" MaxWidth="1200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" Spacing="16">

                    <StackPanel Style="{StaticResource CardStackStyle}" HorizontalAlignment="Center" Padding="16,12" Background="Transparent" BorderThickness="0">
                        <toolkit:Segmented x:Name="TaskTypeSegmented" 
                                           SelectedIndex="{x:Bind ViewModel.SelectedTaskTypeIndex, Mode=TwoWay}"
                                           MinHeight="36">
                            <toolkit:SegmentedItem Content="Internal Production" FontSize="18"/>
                            <toolkit:SegmentedItem Content="External Procurement" FontSize="18"/>
                        </toolkit:Segmented>
                    </StackPanel>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" MinWidth="350" />
                            <ColumnDefinition Width="1*" MinWidth="350" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="16">

                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <TextBlock Text="Task Details" Style="{StaticResource BodyStrongTextBlockStyle}" />

                                <StackPanel>
                                    <TextBlock Text="Product Variant*" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{x:Bind ViewModel.ProductVariantName, Mode=OneWay}" IsReadOnly="True" PlaceholderText="Select a product..."/>
                                        <Button Grid.Column="1" Content="..." ToolTipService.ToolTip="Select Product" Command="{x:Bind ViewModel.ShowProductPickerCommand}" />
                                    </Grid>
                                    <TextBlock Text="{x:Bind ViewModel.ProductVariantIdError, Mode=OneWay}" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                               Visibility="{x:Bind ViewModel.ProductVariantIdError, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"
                                               Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" />
                                </StackPanel>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <NumberBox Header="Quantity*" Value="{x:Bind ViewModel.RequestedQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                   Minimum="1" SpinButtonPlacementMode="Compact" />
                                        <TextBlock Text="{x:Bind ViewModel.RequestedQuantityError, Mode=OneWay}" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                   Visibility="{x:Bind ViewModel.RequestedQuantityError, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"
                                                   Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" />
                                    </StackPanel>

                                    <ComboBox Grid.Column="1" Header="Priority" ItemsSource="{x:Bind ViewModel.Priorities}"
                                              SelectedItem="{x:Bind ViewModel.SelectedPriority, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                                </Grid>

                                <CalendarDatePicker Header="Expected Completion Date" 
                                                    Date="{x:Bind ViewModel.ExpectedCompletionDate, Mode=TwoWay}" 
                                                    HorizontalAlignment="Stretch" />
                            </StackPanel>

                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="16">

                            <StackPanel Style="{StaticResource CardStackStyle}" 
                                        Visibility="{x:Bind ViewModel.IsProductionFormVisible, Mode=OneWay}">
                                <TextBlock Text="Production Assignment" Style="{StaticResource BodyStrongTextBlockStyle}" />

                                <ComboBox Header="Assign To Worker (Optional)" ItemsSource="{x:Bind ViewModel.AvailableUsers}"
                                          DisplayMemberPath="FullName" SelectedValuePath="Id"
                                          SelectedValue="{x:Bind ViewModel.AssignedUserId, Mode=TwoWay}" 
                                          HorizontalAlignment="Stretch" PlaceholderText="Unassigned"/>
                            </StackPanel>

                            <StackPanel Style="{StaticResource CardStackStyle}" 
                                        Visibility="{x:Bind ViewModel.IsProcurementFormVisible, Mode=OneWay}">
                                <TextBlock Text="Procurement Details" Style="{StaticResource BodyStrongTextBlockStyle}" />

                                <StackPanel>
                                    <TextBox Header="Purchase Order Number*" Text="{x:Bind ViewModel.PurchaseOrderNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{x:Bind ViewModel.PurchaseOrderNumberError, Mode=OneWay}" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                               Visibility="{x:Bind ViewModel.PurchaseOrderNumberError, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"
                                               Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Estimated Cost*"
                                               Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind ViewModel.BaseCurrency, Mode=OneWay}"
                                                   VerticalAlignment="Center" Grid.Column="0"/>
                                        <NumberBox Value="{x:Bind ViewModel.CostAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                   Minimum="0" SpinButtonPlacementMode="Compact" Grid.Column="1" />
                                    </Grid>
                                    <TextBlock Text="{x:Bind ViewModel.CostAmountError, Mode=OneWay}" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                               Visibility="{x:Bind ViewModel.CostAmountError, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"
                                               Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <TextBlock Text="Task Notes" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBox Text="{x:Bind ViewModel.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         PlaceholderText="Add instructions, material details, or supplier notes..."
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"/>
                            </StackPanel>

                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Grid Grid.RowSpan="2" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" Opacity="0.7" 
              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressRing IsActive="True" Width="64" Height="64" />
        </Grid>

    </Grid>
</Page>
