<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="RootPage"
    x:Class="Onyx.Oms.Client.Desktop.Features.Products.Create.CreateProductPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Products.Create"
    xmlns:parent="using:Onyx.Oms.Client.Desktop.Features.Products"
    xmlns:controls="using:Onyx.Oms.Client.Desktop.Features.Products.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:sharedConverters="using:Onyx.Oms.Client.Desktop.Shared.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
        <converters:EmptyObjectToObjectConverter x:Key="NullToVisibilityConverter" EmptyValue="Visible" NotEmptyValue="Collapsed" />
        <converters:EmptyCollectionToObjectConverter x:Key="EmptyListToVisibiltyConverter" EmptyValue="Visible" NotEmptyValue="Collapsed" />
        <sharedConverters:DecimalToDoubleConverter x:Key="DecimalToDoubleConverter" />
        <sharedConverters:StringListConverter x:Key="StringListConverter" />
        <sharedConverters:StringToBoolConverter x:Key="StringToBoolConverter" />

        <DataTemplate x:Key="TextSpecTemplate" x:DataType="parent:SpecFieldViewItem">
            <TextBox Header="{x:Bind Label}"
                     Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Enter value..."
                     Margin="0,0,0,12"/>
        </DataTemplate>
        
        <DataTemplate x:Key="SelectSpecTemplate" x:DataType="parent:SpecFieldViewItem">
            <ComboBox Header="{x:Bind Label}"
                      ItemsSource="{x:Bind Options}"
                      SelectedItem="{x:Bind Value, Mode=TwoWay}"
                      PlaceholderText="Select value..."
                      HorizontalAlignment="Stretch"
                      Margin="0,0,0,12"/>
        </DataTemplate>
        
        <DataTemplate x:Key="ToggleSpecTemplate" x:DataType="parent:SpecFieldViewItem">
            <CheckBox Content="{x:Bind Label}"
                      IsChecked="{x:Bind Value, Mode=TwoWay, Converter={StaticResource StringToBoolConverter}}"
                      Margin="0,0,0,12"/>
        </DataTemplate>

        <parent:FormTemplateSelector x:Key="SpecSelector"
                                     TextTemplate="{StaticResource TextSpecTemplate}"
                                     ComboBoxTemplate="{StaticResource SelectSpecTemplate}"
                                     ToggleTemplate="{StaticResource ToggleSpecTemplate}"/>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--Header-->
        <Grid Grid.Row="0" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <Button Style="{StaticResource SubtleButtonStyle}"
                        Command="{x:Bind ViewModel.CancelCommand}">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                </Button>
            </StackPanel>
            
            <TextBlock Text="Create New Product" Grid.Column="1"
                       Style="{StaticResource SubtitleTextBlockStyle}" 
                       FontWeight="SemiBold" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                <Button Content="Save Product" Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.SaveCommand}"/>
            </StackPanel>
        </Grid>
        
        <!-- Progress Bar -->
        <ProgressBar Grid.Row="0"
                     VerticalAlignment="Bottom"
                     HorizontalAlignment="Stretch"
                     IsIndeterminate="True"
                     Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                     Canvas.ZIndex="100"/>

        <!-- Scrollable Body -->
        <ScrollViewer Grid.Row="1" Padding="16" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10000*" MaxWidth="1200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Split View -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" Spacing="16">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" MinWidth="350" />
                            <ColumnDefinition Width="1*" MinWidth="350" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left Column -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="16">
                            
                            <!-- Basic Information Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <StackPanel>
                                    <TextBlock Text="Basic Information" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Product name, description, category, and base SKU." 
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               Margin="0,0,0,12" />
                                </StackPanel>

                                <TextBox Header="Product Name *" 
                                         PlaceholderText="e.g. Onyx Signature Tee" 
                                         Text="{x:Bind ViewModel.Draft.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,0,0,12" />
                                
                                <TextBox Header="Base SKU (Optional)" 
                                         PlaceholderText="e.g. TEE-SIG-01" 
                                         Text="{x:Bind ViewModel.Draft.BaseSku, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,0,0,12" />

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Category *" 
                                               Style="{StaticResource BodyTextBlockStyle}" 
                                               Margin="0,0,0,8"/>
                                    <controls:ProductCategoryPicker x:Name="CategoryPicker" 
                                                                    IsLeafOnly="True"
                                                                    SelectedCategory="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}" 
                                                                    HorizontalAlignment="Stretch" />
                                </StackPanel>

                                <TextBox Header="Description" PlaceholderText="Detailed product description..." 
                                        Text="{x:Bind ViewModel.Draft.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                        TextWrapping="Wrap" AcceptsReturn="True" MinHeight="100" Margin="0,0,0,12" />
                            </StackPanel>

                            <!-- Tags -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <StackPanel>
                                    <TextBlock Text="Tags" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock Text="Keywords for search index and grouping."
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,12" />
                                </StackPanel>

                                <labs:TokenizingTextBox Header="Tags (Type and press Enter"
                                                        ItemsSource="{x:Bind ViewModel.Tags}"
                                                        TokenDelimiter="&#13;"
                                                        PlaceholderText="e.g. Summer, Sale, New Arrival" />
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Right Column -->
                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="16">
                            <!-- Right Column: Logistics & Defaults -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <StackPanel>
                                    <TextBlock Text="Logistics &amp; Settings" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Pricing, inventory, and physical shipping details." 
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               Margin="0,0,0,12" />
                                </StackPanel>

                                <!-- Pricing Grid -->
                                <Grid ColumnSpacing="12" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Base Cost"
                                                   Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{x:Bind ViewModel.BaseCurrency, Mode=OneWay}"
                                                       VerticalAlignment="Center" Grid.Column="0"/>
                                            <NumberBox Value="{x:Bind ViewModel.Draft.BaseCostAmount, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}"
                                                       Minimum="0" Grid.Column="1"/>
                                        </Grid>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Base Price"
                                                   Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{x:Bind ViewModel.BaseCurrency, Mode=OneWay}"
                                                       VerticalAlignment="Center" Grid.Column="0"/>
                                            <NumberBox Value="{x:Bind ViewModel.Draft.BasePriceAmount, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}"
                                                       Minimum="0" Grid.Column="1"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <CheckBox Content="This is a physical product (requires shipping)" 
                                          IsChecked="{x:Bind ViewModel.IsPhysicalProduct, Mode=TwoWay}"
                                          Margin="0,0,0,8"/>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Weight field (hidden if digital) -->
                                    <StackPanel Grid.Column="0"
                                                Visibility="{x:Bind ViewModel.IsPhysicalProduct, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Base Weight"
                                                   Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <NumberBox Value="{x:Bind ViewModel.Draft.BaseWeightAmount, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}"
                                                       Minimum="0" Grid.Column="0"/>
                                            <TextBlock Text="{x:Bind ViewModel.BaseWeightUnit, Mode=OneWay}"
                                                       VerticalAlignment="Center" Grid.Column="1"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                                
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Stock (hidden if has variants) -->
                                    <NumberBox Header="Initial Stock Available"
                                               Value="{x:Bind ViewModel.Draft.BaseStockOnHand, Mode=TwoWay}"
                                               Visibility="{x:Bind ViewModel.HasVariants, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                               Minimum="0" Grid.Column="0"/>

                                </Grid>
                            </StackPanel>
                            
                            <!-- Specifications -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <StackPanel>
                                    <TextBlock Text="Specifications" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock Text="Product attributes specific to its category."
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,12" />
                                </StackPanel>

                                <TextBlock Text="Select a category to view specifications."
                                           FontStyle="Italic"
                                           Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                           Visibility="{x:Bind ViewModel.SelectedCategory, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"/>

                                <!-- Dynamic Specifications -->
                                <ItemsControl ItemsSource="{x:Bind ViewModel.DynamicSpecs, Mode=OneWay}"
                                              ItemTemplateSelector="{StaticResource SpecSelector}"
                                              Visibility="{x:Bind ViewModel.DynamicSpecs, Mode=OneWay,Converter={StaticResource EmptyListToVisibiltyConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Section 3: Variants & Options Card -->
                    <StackPanel Style="{StaticResource CardStackStyle}">
                        <Grid Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Product Variations" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Define dynamic options like size, color, or material to generate unique variant SKUs." 
                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch Header="Product Has Variations"
                                          IsOn="{x:Bind ViewModel.HasVariants, Mode=TwoWay}"
                                          HorizontalAlignment="Right"/>
                        </Grid>

                        <MenuFlyoutSeparator Visibility="{x:Bind ViewModel.HasVariants, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                             Margin="0,0,0,16"/>

                        <!-- Variants Builder -->
                        <StackPanel Visibility="{x:Bind ViewModel.HasVariants, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="1. Define Option Axes" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,12" />

                            <!-- Add Option Row -->
                            <Grid ColumnSpacing="12" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Header="Option Name"
                                         PlaceholderText="e.g., Color"
                                         Text="{x:Bind ViewModel.DraftOptionName, Mode=TwoWay}"/>

                                <StackPanel Grid.Column="1">
                                    <labs:TokenizingTextBox Header="Values (Type and press Enter)"
                                                            ItemsSource="{x:Bind ViewModel.DraftOptionValues, Mode=OneWay}"
                                                            TokenDelimiter="&#13;"
                                                            PlaceholderText="e.g., Red, Blue"/>
                                </StackPanel>

                                <Button Grid.Column="2" Content="Add Option" VerticalAlignment="Bottom"
                                        Style="{StaticResource DefaultButtonStyle}"
                                        Command="{x:Bind ViewModel.AddOptionCommand}"/>
                            </Grid>

                            <!-- Options List -->
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.ProductOptions, Mode=OneWay}" Margin="0,0,0,16">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="local:CreateProductOptionDraftModel">
                                        <Grid Padding="8"
                                              Background="{ThemeResource LayerFillColorAltBrush}"
                                              CornerRadius="4"
                                              Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" 
                                                       Text="{x:Bind Values, Converter={StaticResource StringListConverter}}" 
                                                       VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="2" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" 
                                                    Style="{StaticResource SubtleButtonStyle}" 
                                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}" 
                                                    ToolTipService.ToolTip="Remove Option"
                                                    Command="{Binding ElementName=RootPage, Path=ViewModel.RemoveOptionCommand}"
                                                    CommandParameter="{x:Bind}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <!-- Generate Action -->
                            <Button Content="Generate Variant Matrix"
                                    Command="{x:Bind ViewModel.GenerateMatrixCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Margin="0,0,0,16" HorizontalAlignment="Left"/>

                            <MenuFlyoutSeparator Margin="0,0,0,16"/>

                            <TextBlock Text="2. Configure Variant Logistics"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       Margin="0,0,0,12"/>

                            <!-- The Matrix -->
                            <toolkit:DataGrid ItemsSource="{x:Bind ViewModel.VariantDrafts, Mode=OneWay}"
                                              AutoGenerateColumns="False"
                                              RowBackground="Transparent"
                                              AlternatingRowBackground="{ThemeResource LayerFillColorDefaultBrush}"
                                              MinHeight="200"
                                              MaxHeight="400"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                <toolkit:DataGrid.Columns>
                                    <toolkit:DataGridTextColumn Header="Variant" Binding="{Binding DisplayAttributes}" IsReadOnly="True" MinWidth="180" Width="Auto" />
                                    <toolkit:DataGridTextColumn Header="SKU Override" Binding="{Binding Sku, Mode=TwoWay}" Width="*" />
                                    <toolkit:DataGridTextColumn Binding="{Binding ElementName=RootPage, Path=ViewModel.BaseCurrency}" Width="50" />
                                    <toolkit:DataGridTextColumn Header="Price" Binding="{Binding PriceAmount, Mode=TwoWay}" MinWidth="100" Width="Auto" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                                    <toolkit:DataGridTextColumn Binding="{Binding ElementName=RootPage, Path=ViewModel.BaseCurrency}" Width="50" />
                                    <toolkit:DataGridTextColumn Header="Cost" Binding="{Binding CostAmount, Mode=TwoWay}" MinWidth="100" Width="Auto" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                                    <toolkit:DataGridTextColumn Header="Weight" Binding="{Binding WeightValue, Mode=TwoWay}" MinWidth="100" Width="Auto" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                                    <toolkit:DataGridTextColumn Binding="{Binding ElementName=RootPage, Path=ViewModel.BaseWeightUnit}" Width="50" />
                                    <toolkit:DataGridTextColumn Header="Initial Stock" Binding="{Binding StockOnHand, Mode=TwoWay}" MinWidth="120" Width="Auto" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                                </toolkit:DataGrid.Columns>
                            </toolkit:DataGrid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Section 04: Images -->
                    <StackPanel Style="{StaticResource CardStackStyle}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Product Media &amp; Tagging" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Upload product images and select the corresponding variant option. The first image is automatically set as the main display." 
                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Style="{StaticResource DefaultButtonStyle}"
                                    Command="{x:Bind ViewModel.UploadImageCommand}">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE898;" FontSize="16"/>
                                        <TextBlock Text="Upload Image" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </Grid>

                        <ListView ItemsSource="{x:Bind ViewModel.ProductImageDrafts, Mode=OneWay}"
                                  SelectionMode="None"
                                  Margin="0,16,0,0">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0,0,0,16" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:CreateProductImageDraftModel">
                                    <Grid CornerRadius="8"
                                          Background="{ThemeResource LayerFillColorDefaultBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                                            <Image Source="{x:Bind ImageSource}" 
                                                   Stretch="UniformToFill" 
                                                   Margin="1" MinHeight="180" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />

                                            <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                                Margin="8" Padding="8,4" CornerRadius="4"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                Visibility="{x:Bind IsMain, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="MAIN" FontSize="10" FontWeight="Bold" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                                            </Border>
                                        </Grid>

                                        <Grid Grid.Column="1" Padding="16">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                                <RadioButton Content="Set as Main Image"
                                                             IsChecked="{x:Bind IsMain, Mode=OneWay}"
                                                             Command="{Binding ElementName=RootPage, Path=ViewModel.SetMainImageCommand}"
                                                             CommandParameter="{x:Bind}"
                                                             Margin="0"/>

                                                <Button HorizontalAlignment="Right"
                                                        Style="{StaticResource SubtleButtonStyle}"
                                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                        ToolTipService.ToolTip="Delete Image"
                                                        Command="{Binding ElementName=RootPage, Path=ViewModel.DeleteImageCommand}"
                                                        CommandParameter="{x:Bind}">
                                                    <Button.Content>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                                            <TextBlock Text="Remove" />
                                                        </StackPanel>
                                                    </Button.Content>
                                                </Button>
                                            </Grid>

                                            <TextBlock Grid.Row="1"
                                                           Text="Link to a Variant Option:"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource AccentTextFillColorSecondaryBrush}"
                                                           Margin="0,0,0,8"/>

                                            <ItemsControl Grid.Row="2" ItemsSource="{x:Bind AvailableTags, Mode=OneWay}"
                                                              Margin="0,0,0,8">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <labs:WrapPanel Orientation="Horizontal"
                                                                            HorizontalSpacing="8" VerticalSpacing="8"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="local:SelectableTagViewItem">
                                                        <ToggleButton Content="{x:Bind Tag.DisplayLabel}"
                                                                          IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                                          CornerRadius="16"
                                                                          Padding="16,6"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel HorizontalAlignment="Center"
                                    Margin="0,32,0,32" Spacing="12"
                                    Visibility="{x:Bind GetProductImagesEmptyState(ViewModel.ProductImageDrafts.Count), Mode=OneWay}">
                            <FontIcon Glyph="&#xE8B9;" FontSize="48" Foreground="{ThemeResource SurfaceStrokeColorDefaultBrush}" />
                            <TextBlock Text="No images uploaded yet." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Rectangle Height="64"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
