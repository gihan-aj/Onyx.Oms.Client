<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Onyx.Oms.Client.Desktop.Features.Orders.Edit.AddPaymentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Orders.Edit"
    xmlns:converters="using:Onyx.Oms.Client.Desktop.Shared.Converters"
    Title="Add Payment Transaction"
    PrimaryButtonText="Add Payment"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    Style="{StaticResource DefaultContentDialogStyle}">

    <ContentDialog.Resources>
        <converters:DecimalToDoubleConverter x:Key="DecimalToDoubleConverter" />
    </ContentDialog.Resources>

    <StackPanel Spacing="16" Width="350">
        
        <StackPanel>
            <TextBlock Text="Amount"
               Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Bind BaseCurrency, Mode=OneWay}"
                            VerticalAlignment="Center" Grid.Column="0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <NumberBox Value="{x:Bind PaymentAmount, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}" 
                           SpinButtonPlacementMode="Inline" 
                           Grid.Column="1"/>
            </Grid>
        </StackPanel>

        <!--<Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <DatePicker Grid.Column="0" Header="Payment Date" 
                Date="{x:Bind PaymentDate, Mode=TwoWay}" 
                HorizontalAlignment="Stretch" />

            <TimePicker Grid.Column="1" Header="Time" 
                Time="{x:Bind PaymentTime, Mode=TwoWay}" 
                HorizontalAlignment="Stretch" />
        </Grid>-->

        <DatePicker Header="Payment Date" 
                    Date="{x:Bind PaymentDate, Mode=TwoWay}" 
                    HorizontalAlignment="Stretch" />

        <TimePicker Header="Time" 
                    Time="{x:Bind PaymentTime, Mode=TwoWay}" 
                    HorizontalAlignment="Stretch" />

        <ComboBox Header="Payment Method" 
                  ItemsSource="{x:Bind PaymentMethods}" 
                  SelectedItem="{x:Bind SelectedMethod, Mode=TwoWay}"
                  HorizontalAlignment="Stretch" />
        
        <TextBox Header="Reference Number / Notes" 
                 Text="{x:Bind ReferenceNumber, Mode=TwoWay}" 
                 PlaceholderText="e.g. Check #1234 or Courier Receipt" />
        
    </StackPanel>
    
</ContentDialog>
