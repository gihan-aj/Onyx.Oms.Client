<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Expenses.List.ExpensesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Expenses.List"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:sharedConverters="using:Onyx.Oms.Client.Desktop.Shared.Converters"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
        <sharedConverters:DecimalToDoubleConverter x:Key="DecimalToDoubleConverter" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Row: Title, Search, Actions -->
        <Grid Grid.Row="0" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       Text="Expenses" 
                       Style="{StaticResource SubtitleTextBlockStyle}" 
                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0"/>

            <AutoSuggestBox Grid.Column="1"
                            PlaceholderText="Search expenses..."
                            QueryIcon="Find"
                            Width="320"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QuerySubmitted="AutoSuggestBox_QuerySubmitted"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Style="{StaticResource SubtleButtonStyle}" ToolTipService.ToolTip="Refresh Data"
                        Command="{x:Bind ViewModel.RefreshCommand}">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                </Button>

                <AppBarSeparator/>

                <Button Style="{StaticResource AccentButtonStyle}" 
                        Command="{x:Bind ViewModel.NewExpenseCommand}"
                        IsEnabled="{x:Bind ViewModel.CanCreate}"
                        Visibility="{x:Bind ViewModel.CanCreate, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="New Expense" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>

        </Grid>

        <!-- Filters -->
        <Grid Grid.Row="1" Padding="16,0,16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">

            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="16" Padding="0,0,0,4">
                    
                    <StackPanel>
                        <TextBlock Text="From Date" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <CalendarDatePicker Date="{x:Bind ViewModel.FromDate, Mode=TwoWay}" Width="140"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="To Date" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <CalendarDatePicker Date="{x:Bind ViewModel.ToDate, Mode=TwoWay}" Width="140"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Category" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.Categories}"
                                  SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                                  PlaceholderText="Select a Category"
                                  Width="180"/>
                    </StackPanel>
                    
                    <StackPanel>
                        <TextBlock Text="Min Amount" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <NumberBox Value="{x:Bind ViewModel.MinAmount, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}" 
                                   SpinButtonPlacementMode="Inline" Width="120"/>
                    </StackPanel>
                    
                    <StackPanel>
                        <TextBlock Text="Max Amount" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                        <NumberBox Value="{x:Bind ViewModel.MaxAmount, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}" 
                                SpinButtonPlacementMode="Inline" Width="120"/>
                    </StackPanel>

                    <Button Content="Clear" Style="{StaticResource SubtleButtonStyle}" VerticalAlignment="Bottom"
                            Command="{x:Bind ViewModel.ClearFiltersCommand}"/>

                </StackPanel>
            </ScrollViewer>
            
        </Grid>

        <ProgressBar Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" 
                     IsIndeterminate="True" 
                     Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" 
                     Canvas.ZIndex="100" />

        <!-- DataGrid Constraints Wrapper -->
        <Grid Grid.Row="2" x:Name="TableContainer">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Enabled"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Disabled">

                <toolkit:DataGrid x:Name="ExpensesDataGrid"
                                  Width="{Binding ActualWidth, ElementName=TableContainer}"
                                  MinWidth="640"
                                  ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  CanUserSortColumns="True"
                                  Sorting="OrdersDataGrid_Sorting"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Hidden"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{ThemeResource LayerFillColorDefaultBrush}">

                    <toolkit:DataGrid.RowStyle>
                        <Style TargetType="toolkit:DataGridRow">
                            <Setter Property="ContextFlyout">
                                <Setter.Value>
                                    <MenuFlyout>

                                        <MenuFlyoutItem Text="Edit" IsEnabled="{Binding CanEdit}" Click="EditMenuItem_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE70F;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                        <MenuFlyoutSeparator Visibility="{Binding CanDelete, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <MenuFlyoutItem Text="Delete" 
                                                        Visibility="{Binding CanDelete, Converter={StaticResource BoolToVisibilityConverter}}" 
                                                        Click="DeleteMenuItem_Click" Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74D;" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>

                                    </MenuFlyout>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </toolkit:DataGrid.RowStyle>

                    <toolkit:DataGrid.Columns>

                        <toolkit:DataGridTextColumn Header="Category" 
                                                    Binding="{Binding Category}" Tag="category" 
                                                    Width="160" MinWidth="120" 
                                                    FontWeight="SemiBold"
                                                    HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" 
                                                    ElementStyle="{StaticResource LeftAlignedCellStyle}" CanUserSort="True" />

                        <toolkit:DataGridTextColumn Header="Date Incurred" 
                                                    Binding="{Binding DateIncurredDisplay}" Tag="dateincurred" 
                                                    Width="140" MinWidth="120" 
                                                    HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" 
                                                    ElementStyle="{StaticResource LeftAlignedCellStyle}" CanUserSort="True" />

                        <toolkit:DataGridTextColumn Header="Amount" 
                                                    Binding="{Binding FormattedAmount}" Tag="amount" 
                                                    Width="140" MinWidth="100" 
                                                    HeaderStyle="{StaticResource RightAlignedHeaderStyle}" 
                                                    ElementStyle="{StaticResource RightAlignedCellStyle}" CanUserSort="True" />

                        <toolkit:DataGridTextColumn Header="Reference" 
                                                    Binding="{Binding Reference}" Tag="reference" 
                                                    Width="140" MinWidth="100" 
                                                    HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" 
                                                    ElementStyle="{StaticResource LeftAlignedCellStyle}" CanUserSort="False" />

                        <toolkit:DataGridTextColumn Header="Notes" 
                                                    Binding="{Binding Notes}" Tag="notes" 
                                                    Width="*" MinWidth="120" 
                                                    HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" 
                                                    ElementStyle="{StaticResource LeftAlignedCellStyle}" CanUserSort="False" />

                        <!-- Row Actions -->
                        <toolkit:DataGridTemplateColumn Width="80" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                            <toolkit:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="local:ExpenseGridItem">

                                    <Button Style="{StaticResource SubtleButtonStyle}" 
                                            Background="Transparent"
                                            HorizontalAlignment="Stretch" 
                                            VerticalAlignment="Stretch"
                                            ToolTipService.ToolTip="Actions"
                                            Tapped="OnActionButtonTapped">

                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE712;" />

                                        <Button.Flyout>
                                            <MenuFlyout>

                                                <MenuFlyoutItem x:Name="EditMenuItem" 
                                                                Text="Edit" 
                                                                Click="EditMenuItem_Click" 
                                                                IsEnabled="{x:Bind CanEdit}"
                                                                Tag="{x:Bind}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE70F;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutSeparator Visibility="{x:Bind CanDelete, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                <MenuFlyoutItem x:Name="DeleteMenuItem" Text="Delete" Click="DeleteMenuItem_Click" 
                                                                Visibility="{x:Bind CanDelete, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE74D;" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                            </MenuFlyout>
                                        </Button.Flyout>
                                        
                                    </Button>
                                    
                                </DataTemplate>
                            </toolkit:DataGridTemplateColumn.CellTemplate>
                        </toolkit:DataGridTemplateColumn>

                    </toolkit:DataGrid.Columns>
                    
                </toolkit:DataGrid>
                
            </ScrollViewer>

            <!-- Loading Indicator -->
            <Grid Opacity="0.8" 
                  Visibility="{x:Bind ViewModel.IsListLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ProgressRing IsActive="True" Width="48" Height="48" />
            </Grid>

            <!-- No Data Message -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                        Visibility="{x:Bind ViewModel.HasNoData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <FontIcon Glyph="&#xE8EF;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock HorizontalAlignment="Center" Text="No expenses found." 
                            Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Content="Clear Filters" 
                        Command="{x:Bind ViewModel.ClearFiltersCommand}" 
                        Style="{StaticResource DefaultButtonStyle}" 
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Pagination -->
        <Grid Grid.Row="3"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Padding="16,8">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Rows Per Page (Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Rows per page:" VerticalAlignment="Center" 
                           Style="{StaticResource CaptionTextBlockStyle}" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.PageSizes}" 
                          SelectedItem="{x:Bind ViewModel.PageSize, Mode=TwoWay}"
                          Style="{StaticResource DefaultComboBoxStyle}"
                          MinWidth="80" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Page Summary (Center) -->
            <TextBlock Grid.Column="1" 
                       Text="{x:Bind ViewModel.PageSummary, Mode=OneWay}" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}" />

            <!-- Navigation Buttons (Right) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button Style="{StaticResource SubtleButtonStyle}" 
                        Command="{x:Bind ViewModel.PreviousPageCommand}" 
                        IsEnabled="{x:Bind ViewModel.HasPreviousPage, Mode=OneWay}" 
                        ToolTipService.ToolTip="Previous Page">
                    <FontIcon Glyph="&#xE76B;" FontSize="12" />
                </Button>
                <Button Style="{StaticResource SubtleButtonStyle}" 
                        Command="{x:Bind ViewModel.NextPageCommand}" 
                        IsEnabled="{x:Bind ViewModel.HasNextPage, Mode=OneWay}" 
                        ToolTipService.ToolTip="Next Page">
                    <FontIcon Glyph="&#xE76C;" FontSize="12" />
                </Button>
            </StackPanel>

        </Grid>
    </Grid>
</Page>
