<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Orders.Create.CreateOrderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Orders.Create"
    xmlns:parent="using:Onyx.Oms.Client.Desktop.Features.Orders"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
        <converters:EmptyStringToObjectConverter x:Key="StringToVisibilityConverter" EmptyValue="Collapsed" NotEmptyValue="Visible" />
        <converters:BoolNegationConverter x:Key="InvertedBoolConverter" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Command="{x:Bind ViewModel.CancelCommand}" Style="{StaticResource SubtleButtonStyle}" Margin="0,0,16,0">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.SaveCommand}" Style="{StaticResource AccentButtonStyle}" 
                IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" FontSize="14" />
                            <TextBlock Text="Create Order" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>

        <ProgressBar Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
             IsIndeterminate="True" Canvas.ZIndex="100"
             Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10000*" MaxWidth="1200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" Spacing="16">

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" MinWidth="350" />
                            <ColumnDefinition Width="2*" MinWidth="350" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="16">

                            <!-- Customer Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <StackPanel>
                                    <TextBlock Text="Customer Details" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Select a return customer or add and select a new customer." 
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               Margin="0,0,0,12" />
                                </StackPanel>

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="350" />
                                        <ColumnDefinition Width="Auto" MinWidth="20" />
                                        <ColumnDefinition Width="Auto" MinWidth="20" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <parent:CustomerPicker x:Name="CustomerPicker"
                                                           Grid.Column="0"
                                                           Width="Auto"
                                                           SelectedCustomer="{x:Bind ViewModel.SelectedCustomer, Mode=TwoWay}"
                                                           PlaceholderText="Search a Customer by Name, Phone, Email or Last Order Number..."/>

                                    <Button Click="OnAddNewCustomerClick" 
                                            Grid.Column="1"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            ToolTipService.ToolTip="Add a New Customer">
                                        <FontIcon Glyph="&#xE710;" FontSize="16" />
                                    </Button>

                                    <Button Command="{x:Bind ViewModel.ClearCustomerCommand}"
                                            Grid.Column="2"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Visibility="{x:Bind ViewModel.HasSelectedCustomer, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                            ToolTipService.ToolTip="Clear selected customer">
                                        <FontIcon Glyph="&#xE711;" FontSize="16" />
                                    </Button>
                                </Grid>

                                <!-- Customer Details Display -->
                                <StackPanel Visibility="{x:Bind ViewModel.HasSelectedCustomer, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="{ThemeResource LayerFillColorAltBrush}"
                                            Padding="16" CornerRadius="8" Margin="0,12,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <FontIcon Glyph="&#xE77B;" FontSize="32" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind ViewModel.SelectedCustomer.Name, Mode=OneWay, TargetNullValue='', FallbackValue=''}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{x:Bind ViewModel.SelectedCustomer.PrimaryPhone, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}, FallbackValue='Collapsed'}">
                                                    <FontIcon Glyph="&#xE717;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedCustomer.PrimaryPhone, Mode=OneWay, TargetNullValue='', FallbackValue=''}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                                
                                                <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{x:Bind ViewModel.SelectedCustomer.Email, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}, FallbackValue='Collapsed'}">
                                                    <FontIcon Glyph="&#xE715;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedCustomer.Email, Mode=OneWay, TargetNullValue='', FallbackValue=''}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                            </StackPanel>

                        </StackPanel>
                    </Grid>
                    
                </StackPanel>
            </Grid>
            
        </ScrollViewer>

    </Grid>
</Page>
