<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Onyx.Oms.Client.Desktop.Features.Orders.ReceiveReturnDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Receive Return"
    PrimaryButtonText="Receive"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    Style="{StaticResource DefaultContentDialogStyle}">

    <StackPanel Spacing="16" Width="400">
        <TextBlock Text="Has the returned package been received?" TextWrapping="Wrap" />
        <CheckBox Content="Package Received" 
                  IsChecked="{x:Bind IsReceived, Mode=TwoWay}" />
        <TextBox Header="Reason/Notes (Optional)" 
                 Text="{x:Bind Reason, Mode=TwoWay}"
                 PlaceholderText="e.g. Package damaged, received by John"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 MinHeight="80" />
    </StackPanel>
</ContentDialog>
