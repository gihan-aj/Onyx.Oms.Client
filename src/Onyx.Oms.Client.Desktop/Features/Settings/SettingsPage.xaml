<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="RootPage"
    x:Class="Onyx.Oms.Client.Desktop.Features.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    xmlns:models="using:Microsoft.UI.Xaml"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:sharedConverters="using:Onyx.Oms.Client.Desktop.Shared.Converters"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Settings"
    mc:Ignorable="d">
    
    <Page.Resources>
        <sharedConverters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    <!--  Spacing between cards  -->
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>

        <!--  Style of a section header  -->
        <Style
            x:Key="SettingsSectionHeaderTextBlockStyle"
            BasedOn="{StaticResource BodyStrongTextBlockStyle}"
            TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" MaxWidth="1064" Style="{StaticResource TitleTextBlockStyle}" Margin="36,24,36,12" Grid.Row="0"/>

        <SelectorBar x:Name="SettingsSelectorBar" MaxWidth="1064" Margin="36,0,36,0" Grid.Row="1" SelectionChanged="OnSelectorBarSelectionChanged">
            <SelectorBarItem Text="General" Tag="General" />
            <SelectorBarItem Text="Regional Settings" Tag="Regional" />
            <SelectorBarItem Text="Sequences" Tag="Sequences" />
            <SelectorBarItem Text="Appearance" Tag="Appearance" />
            <SelectorBarItem Text="About" Tag="About" />
        </SelectorBar>

        <ScrollViewer Grid.Row="2" Padding="36,0,36,24" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
            <Border>
                <StackPanel Spacing="{StaticResource SettingsCardSpacing}" MaxWidth="1064">
                    <StackPanel.ChildrenTransitions>
                        <RepositionThemeTransition />
                    </StackPanel.ChildrenTransitions>

                    <!-- Loading Indicator -->
                    <!--<ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" HorizontalAlignment="Center" Margin="0,10,0,10" />-->

                    <!-- 1. General Settings Form -->
                    <Grid x:Name="GeneralSettingsGrid" Visibility="Visible">
                        <StackPanel Spacing="{StaticResource SettingsCardSpacing}">
                            <TextBlock Text="Store Information" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                            
                            <labs:SettingsCard Header="Store Name">
                                <TextBox Text="{x:Bind ViewModel.Profile.StoreName, Mode=TwoWay}" Width="300" 
                                         IsReadOnly="{x:Bind ViewModel.IsEditingStoreInfo,Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}" />
                            </labs:SettingsCard>
                            <labs:SettingsCard Header="Legal Name">
                                <TextBox Text="{x:Bind ViewModel.Profile.LegalName, Mode=TwoWay}" Width="300" 
                                         IsReadOnly="{x:Bind ViewModel.IsEditingStoreInfo, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}" />
                            </labs:SettingsCard>
                            <labs:SettingsCard Header="Tax Registration Number">
                                <TextBox Text="{x:Bind ViewModel.Profile.TaxRegistrationNumber, Mode=TwoWay}" Width="300" 
                                         IsReadOnly="{x:Bind ViewModel.IsEditingStoreInfo, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}" />
                            </labs:SettingsCard>
                            <labs:SettingsCard Header="Contact Email">
                                <TextBox Text="{x:Bind ViewModel.Profile.ContactEmail, Mode=TwoWay}" Width="300" 
                                         IsReadOnly="{x:Bind ViewModel.IsEditingStoreInfo, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}" />
                            </labs:SettingsCard>
                            <labs:SettingsCard Header="Contact Phone" Margin="0,0,0,16">
                                <TextBox Text="{x:Bind ViewModel.Profile.ContactPhone, Mode=TwoWay}" Width="300" 
                                         IsReadOnly="{x:Bind ViewModel.IsEditingStoreInfo, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}" />
                            </labs:SettingsCard>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Content="Edit" Command="{x:Bind ViewModel.EditStoreInfoCommand}" Visibility="{x:Bind ViewModel.StoreInfoEditButtonVisible, Mode=OneWay}" />
                                <Button Content="Save" Command="{x:Bind ViewModel.SaveStoreInfoCommand}" Style="{StaticResource AccentButtonStyle}" Visibility="{x:Bind ViewModel.StoreInfoSaveCancelVisible, Mode=OneWay}" />
                                <Button Content="Cancel" Command="{x:Bind ViewModel.CancelEditStoreInfoCommand}" Visibility="{x:Bind ViewModel.StoreInfoSaveCancelVisible, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Style="{StaticResource CardStackStyle}" Margin="0,16,0,0">
                                <TextBlock Text="Store Address" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,16" />

                                <TextBox Header="Street Address" 
                                         Text="{x:Bind ViewModel.Profile.StoreAddress.Street, Mode=TwoWay}" 
                                         IsReadOnly="{x:Bind ViewModel.IsEditingStoreAddress, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}"/>

                                <Grid ColumnSpacing="12" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="1.5*" />
                                        <ColumnDefinition Width="1.5*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Header="City" 
                                             Text="{x:Bind ViewModel.Profile.StoreAddress.City, Mode=TwoWay}" 
                                             IsReadOnly="{x:Bind ViewModel.IsEditingStoreAddress, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}"/>

                                    <ComboBox Grid.Column="1" Header="State / Province" 
                                              ItemsSource="{x:Bind ViewModel.Provinces}"
                                              SelectedItem="{x:Bind ViewModel.Profile.StoreAddress.State, Mode=TwoWay}"
                                              SelectionChanged="OnStateSelectionChanged"
                                              IsEnabled="{x:Bind ViewModel.IsEditingStoreAddress, Mode=OneWay}"
                                              HorizontalAlignment="Stretch" />

                                    <ComboBox Grid.Column="2" Header="District" 
                                              ItemsSource="{x:Bind ViewModel.Districts, Mode=OneWay}"
                                              SelectedItem="{x:Bind ViewModel.Profile.StoreAddress.District, Mode=TwoWay}"
                                              IsEnabled="{x:Bind ViewModel.IsEditingStoreAddress, Mode=OneWay}"
                                              HorizontalAlignment="Stretch" />
                                </Grid>

                                <Grid ColumnSpacing="12" Margin="0,12,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Header="Zip / Postal" 
                                             Text="{x:Bind ViewModel.Profile.StoreAddress.PostalCode, Mode=TwoWay}" 
                                             IsReadOnly="{x:Bind ViewModel.IsEditingStoreAddress, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}"/>

                                    <TextBox Grid.Column="1" Header="Country" 
                                             Text="{x:Bind ViewModel.Profile.StoreAddress.Country, Mode=TwoWay}" 
                                             IsReadOnly="{x:Bind ViewModel.IsEditingStoreAddress, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                    <Button Content="Edit" Command="{x:Bind ViewModel.EditStoreAddressCommand}" Visibility="{x:Bind ViewModel.StoreAddressEditButtonVisible, Mode=OneWay}" />
                                    <Button Content="Save" Command="{x:Bind ViewModel.SaveStoreAddressCommand}" Style="{StaticResource AccentButtonStyle}" Visibility="{x:Bind ViewModel.StoreAddressSaveCancelVisible, Mode=OneWay}" />
                                    <Button Content="Cancel" Command="{x:Bind ViewModel.CancelEditStoreAddressCommand}" Visibility="{x:Bind ViewModel.StoreAddressSaveCancelVisible, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                    </Grid>

                    <!-- 2. Regional Settings -->
                    <Grid x:Name="RegionalSettingsGrid" Visibility="Collapsed">
                        <StackPanel Spacing="{StaticResource SettingsCardSpacing}">
                            <TextBlock Text="Regional Settings" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                            <InfoBar IsOpen="True" Severity="Warning" Message="Changing the currency does not retroactively convert historical order financial records." Margin="0,0,0,16" />

                            <labs:SettingsCard Header="Base Currency (Code)">
                                <TextBox Text="{x:Bind ViewModel.Profile.DefaultCurrency, Mode=TwoWay}" MaxLength="3" Width="30" 
                                         IsReadOnly="{x:Bind ViewModel.IsEditingRegionalSettings, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}" />
                            </labs:SettingsCard>
                            <labs:SettingsCard Header="Time Zone (Code)">
                                <TextBox Text="{x:Bind ViewModel.Profile.TimeZone, Mode=TwoWay}" MaxLength="3" Width="30" 
                                         IsReadOnly="{x:Bind ViewModel.IsEditingRegionalSettings, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}" />
                            </labs:SettingsCard>
                            <labs:SettingsCard Header="Weight Unit" Margin="0,0,0,16">
                                <TextBox Text="{x:Bind ViewModel.Profile.WeightUnit, Mode=TwoWay}" MaxLength="10" Width="30" 
                                         IsReadOnly="{x:Bind ViewModel.IsEditingRegionalSettings, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}" />
                            </labs:SettingsCard>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Content="Edit" Command="{x:Bind ViewModel.EditRegionalSettingsCommand}" Visibility="{x:Bind ViewModel.RegionalSettingsEditButtonVisible, Mode=OneWay}" />
                                <Button Content="Save" Command="{x:Bind ViewModel.SaveRegionalSettingsCommand}" Style="{StaticResource AccentButtonStyle}" Visibility="{x:Bind ViewModel.RegionalSettingsSaveCancelVisible, Mode=OneWay}" />
                                <Button Content="Cancel" Command="{x:Bind ViewModel.CancelEditRegionalSettingsCommand}" Visibility="{x:Bind ViewModel.RegionalSettingsSaveCancelVisible, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- 3. Sequences -->
                    <Grid x:Name="SequencesGrid" Visibility="Collapsed">
                        <StackPanel Spacing="{StaticResource SettingsCardSpacing}">
                            <TextBlock Text="Application Sequences" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Sequences, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:AppSequenceViewModel">
                                        <labs:SettingsCard Header="{x:Bind DisplayName}" Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                            <NumberBox Value="{x:Bind CurrentValue, Mode=TwoWay}" Minimum="1" SpinButtonPlacementMode="Compact" Width="150" 
                                                       IsEnabled="{x:Bind IsEditing, Mode=OneWay}" />
                                            <Button Content="Edit" Command="{x:Bind EditCommand}" Visibility="{x:Bind EditButtonVisible, Mode=OneWay}" />
                                            <Button Content="Save" 
                                                    Command="{Binding ElementName=RootPage, Path=ViewModel.SaveSequenceCommand}" 
                                                    CommandParameter="{x:Bind Mode=OneWay}" 
                                                    Style="{StaticResource AccentButtonStyle}" 
                                                    Visibility="{x:Bind SaveCancelVisible, Mode=OneWay}" />
                                            <Button Content="Cancel" Command="{x:Bind CancelEditCommand}" Visibility="{x:Bind SaveCancelVisible, Mode=OneWay}" />
                                        </StackPanel>
                                        </labs:SettingsCard>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <!-- 4. Appearance -->
                    <Grid x:Name="AppearanceGrid" Visibility="Collapsed">
                        <StackPanel Spacing="{StaticResource SettingsCardSpacing}">
                            <TextBlock Text="Appearance and Behavior" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                            <labs:SettingsCard Header="App Theme" Description="Select which app theme to display">
                                <labs:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE790;"/>
                                </labs:SettingsCard.HeaderIcon>
                                <ComboBox x:Name="ThemeSelector"
                                          SelectedItem="{x:Bind ViewModel.CurrentTheme, Mode=OneWay}"
                                          SelectionChanged="OnThemeSelectionChanged"
                                          Width="200">
                                    <ComboBoxItem Content="Light" Tag="Light" />
                                    <ComboBoxItem Content="Dark" Tag="Dark" />
                                    <ComboBoxItem Content="Use System Setting" Tag="Default" />
                                </ComboBox>
                            </labs:SettingsCard>
                        </StackPanel>
                    </Grid>

                    <!-- 5. About -->
                    <Grid x:Name="AboutGrid" Visibility="Collapsed">
                        <StackPanel Spacing="{StaticResource SettingsCardSpacing}">
                            <TextBlock Text="About" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />
                            <labs:SettingsExpander Header="Onyx OMS Client" 
                                                   Description="{x:Bind ViewModel.VersionDescription, Mode=OneWay}">
                                <labs:SettingsExpander.HeaderIcon>
                                    <FontIcon Glyph="&#xE8A5;"/>
                                </labs:SettingsExpander.HeaderIcon>
                                <labs:SettingsExpander.Items>
                                    <labs:SettingsCard Content="Privacy Policy" IsClickEnabled="True">
                                         <labs:SettingsCard.ActionIcon>
                                            <FontIcon Glyph="&#xE8A7;"/>
                                        </labs:SettingsCard.ActionIcon>
                                    </labs:SettingsCard>
                                    <labs:SettingsCard Content="Terms of Use" IsClickEnabled="True">
                                        <labs:SettingsCard.ActionIcon>
                                            <FontIcon Glyph="&#xE8A7;"/>
                                        </labs:SettingsCard.ActionIcon>
                                    </labs:SettingsCard>
                                </labs:SettingsExpander.Items>
                            </labs:SettingsExpander>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
