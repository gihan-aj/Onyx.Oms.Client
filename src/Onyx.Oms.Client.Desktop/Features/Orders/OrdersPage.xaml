<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Orders.OrdersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Orders"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header and Filters -->
        <Grid Grid.Row="0" Padding="16,12"
              ColumnSpacing="8" RowSpacing="12"
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Top Row: Title, Search, Actions -->
            <TextBlock Grid.Row="0" Grid.Column="0" 
                       Text="Orders" 
                       Style="{StaticResource SubtitleTextBlockStyle}" 
                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0"/>

            <AutoSuggestBox Grid.Row="0" Grid.Column="1"
                            PlaceholderText="Search orders by number..."
                            QueryIcon="Find"
                            Width="320"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QuerySubmitted="AutoSuggestBox_QuerySubmitted"/>

            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Style="{StaticResource SubtleButtonStyle}" ToolTipService.ToolTip="Refresh Data"
                        Command="{x:Bind ViewModel.RefreshCommand}">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                </Button>

                <AppBarSeparator/>

                <Button Style="{StaticResource AccentButtonStyle}" 
                        Command="{x:Bind ViewModel.NewOrderCommand}"
                        IsEnabled="{x:Bind ViewModel.CanCreateOrders}"
                        Visibility="{x:Bind ViewModel.CanCreateOrders, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="New Order" />
                        </StackPanel>
                    </Button.Content> 
                </Button>
            </StackPanel>

            <!-- Filters -->
            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="16">
                <local:CustomerPicker x:Name="CustomerPicker"
                                      Width="300"
                                      SelectedCustomer="{x:Bind ViewModel.SelectedCustomer, Mode=TwoWay}"
                                      PlaceholderText="Filter by Customer..."/>

                <ComboBox ItemsSource="{x:Bind ViewModel.StatusOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedStatus, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          PlaceholderText="Status"
                          Width="150"/>

                <ComboBox ItemsSource="{x:Bind ViewModel.PaymentStatusOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedPaymentStatus, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          PlaceholderText="Payment Status"
                          Width="180"/>

                <Button Content="Clear Filters" Style="{StaticResource SubtleButtonStyle}"
                        Command="{x:Bind ViewModel.ClearFiltersCommand}"/>
            </StackPanel>
        </Grid>

        <!-- DataGrid Constraints Wrapper -->
        <Grid Grid.Row="1" x:Name="TableContainer">

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Enabled"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Disabled">
                          
                <toolkit:DataGrid x:Name="OrdersDataGrid"
                                  Width="{Binding ActualWidth, ElementName=TableContainer}"
                                  MinWidth="1150"
                                  ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  CanUserSortColumns="True"
                                  Sorting="OrdersDataGrid_Sorting"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Hidden"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{ThemeResource LayerFillColorDefaultBrush}">

                    <toolkit:DataGrid.RowStyle>
                        <Style TargetType="toolkit:DataGridRow">
                            <Setter Property="ContextFlyout">
                                <Setter.Value>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="View Details" Icon="View" Click="ViewMenuItem_Click" 
                                                        IsEnabled="{Binding CanView}" />
                                        
                                        <MenuFlyoutSeparator />

                                        <MenuFlyoutItem Text="Edit" Icon="Edit" Click="EditMenuItem_Click"
                                                        IsEnabled="{Binding CanEdit}" />
                                    </MenuFlyout>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </toolkit:DataGrid.RowStyle>

                <toolkit:DataGrid.Columns>

                    <!-- Order Number -->
                    <toolkit:DataGridTextColumn Header="Order #" 
                                                Binding="{Binding OrderNumber}" Tag="orderNumber" 
                                                Width="Auto" MinWidth="120" 
                                                FontWeight="SemiBold"
                                                HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" 
                                                ElementStyle="{StaticResource LeftAlignedCellStyle}" />

                    <!-- Date -->
                    <toolkit:DataGridTextColumn Header="Date" 
                                                Binding="{Binding OrderDateDisplay}" Tag="orderDate" 
                                                Width="Auto" MinWidth="160" 
                                                HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" 
                                                ElementStyle="{StaticResource LeftAlignedCellStyle}" />

                    <!-- Customer -->
                    <toolkit:DataGridTemplateColumn Header="Customer" Tag="customerName" Width="*" MinWidth="200" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="local:OrderGridItem">
                                <StackPanel VerticalAlignment="Center" Margin="12,4">
                                    <TextBlock Text="{x:Bind CustomerName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind CustomerEmail, TargetNullValue=''}" FontSize="12" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>

                    <!-- Status -->
                    <toolkit:DataGridTextColumn Header="Status" 
                                                Binding="{Binding Status}" Tag="status" 
                                                Width="140" MinWidth="140" 
                                                HeaderStyle="{StaticResource CenteredHeaderStyle}" 
                                                ElementStyle="{StaticResource CenteredCellStyle}" />

                    <!-- Payment Status -->
                    <toolkit:DataGridTextColumn Header="Payment" 
                                                Binding="{Binding PaymentStatus}" Tag="paymentStatus" 
                                                Width="140" MinWidth="140" 
                                                HeaderStyle="{StaticResource CenteredHeaderStyle}" 
                                                ElementStyle="{StaticResource CenteredCellStyle}" />

                    <!-- Total -->
                    <toolkit:DataGridTextColumn Header="Total" 
                                                Binding="{Binding GrandTotalDisplay}" Tag="grandTotalAmount" 
                                                Width="Auto" MinWidth="120" 
                                                HeaderStyle="{StaticResource RightAlignedHeaderStyle}" 
                                                ElementStyle="{StaticResource RightAlignedCellStyle}" />

                    <!-- Row Actions -->
                    <toolkit:DataGridTemplateColumn Width="80" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="local:OrderGridItem">
                                <Button Style="{StaticResource SubtleButtonStyle}" 
                                        Background="Transparent"
                                        HorizontalAlignment="Stretch" 
                                        VerticalAlignment="Stretch"
                                        ToolTipService.ToolTip="Actions"
                                        Tapped="OnActionButtonTapped">

                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE712;" />

                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem x:Name="ViewMenuItem" Text="View Details" Icon="View" Click="ViewMenuItem_Click"
                                                            IsEnabled="{x:Bind CanView}" />

                                            <MenuFlyoutSeparator />

                                            <MenuFlyoutItem x:Name="EditMenuItem" Text="Edit" Icon="Edit" Click="EditMenuItem_Click"
                                                            IsEnabled="{x:Bind CanEdit}" />
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>

                </toolkit:DataGrid.Columns>
                
            </toolkit:DataGrid>
            </ScrollViewer>

            <!-- Loading Indicator -->
            <Grid Opacity="0.8" 
                  Visibility="{x:Bind ViewModel.IsListLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ProgressRing IsActive="True" Width="48" Height="48" />
            </Grid>

            <!-- No Data Message -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                        Visibility="{x:Bind ViewModel.HasNoData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <FontIcon Glyph="&#xE719;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock HorizontalAlignment="Center" Text="No orders found." 
                           Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Content="Clear Filters" 
                        Command="{x:Bind ViewModel.ClearFiltersCommand}" 
                        Style="{StaticResource DefaultButtonStyle}" 
                        HorizontalAlignment="Center"/>
            </StackPanel>
            
        </Grid>

        <!-- Pagination -->
        <Grid Grid.Row="2"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Padding="16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Rows Per Page (Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Rows per page:" VerticalAlignment="Center" 
                           Style="{StaticResource CaptionTextBlockStyle}" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.PageSizes}" 
                          SelectedItem="{x:Bind ViewModel.PageSize, Mode=TwoWay}"
                          Style="{StaticResource DefaultComboBoxStyle}"
                          MinWidth="80" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Page Summary (Center) -->
            <TextBlock Grid.Column="1" 
                       Text="{x:Bind ViewModel.PageSummary, Mode=OneWay}" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}" />

            <!-- Navigation Buttons (Right) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button Style="{StaticResource SubtleButtonStyle}" 
                        Command="{x:Bind ViewModel.PreviousPageCommand}" 
                        IsEnabled="{x:Bind ViewModel.HasPreviousPage, Mode=OneWay}" 
                        ToolTipService.ToolTip="Previous Page">
                    <FontIcon Glyph="&#xE76B;" FontSize="12" />
                </Button>
                <Button Style="{StaticResource SubtleButtonStyle}" 
                        Command="{x:Bind ViewModel.NextPageCommand}" 
                        IsEnabled="{x:Bind ViewModel.HasNextPage, Mode=OneWay}" 
                        ToolTipService.ToolTip="Next Page">
                    <FontIcon Glyph="&#xE76C;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
