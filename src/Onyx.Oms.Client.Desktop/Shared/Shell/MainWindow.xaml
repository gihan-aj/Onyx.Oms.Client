<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Onyx.Oms.Client.Desktop.Shared.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Shared.Shell"
    xmlns:onboarding="using:Onyx.Oms.Client.Desktop.Features.Users.UserOnboarding"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" SizeChanged="Window_SizeChanged">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <TitleBar x:Name="AppTitleBar"
                  Title="ONYX OMS"
                  Grid.Row="0"
                  IsPaneToggleButtonVisible="False"
                  BackRequested="AppTitleBar_BackRequested"
                  PaneToggleRequested="AppTitleBar_PaneToggleRequested"
                  Canvas.ZIndex="0">

            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/StoreLogo.png" />
            </TitleBar.IconSource>

            <TitleBar.RightHeader>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,12,0">

                    <!-- User Profile Picture -->
                    <PersonPicture x:Name="UserAvatar" 
                                   Width="32" 
                                   DisplayName="John Doe" 
                                   Initials="JD" 
                                   Visibility="Collapsed" />

                    <!-- Sign In / Sign Out Buttons -->
                    <Button x:Name="SignInBtn" Content="Sign In" Click="SignInBtn_Click" Visibility="Collapsed" Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Name="SignOutBtn" Content="Sign Out" Click="SignOutBtn_Click" Visibility="Collapsed" Style="{StaticResource SubtleButtonStyle}" />
                    
                </StackPanel>
            </TitleBar.RightHeader>
        </TitleBar>

        <!-- Navigation View -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            Grid.RowSpan="2"
            Visibility="Collapsed"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            PaneDisplayMode="Left"
            SelectionChanged="NavView_SelectionChanged"
            Canvas.ZIndex="0">

            <NavigationView.MenuItems>
                <NavigationViewItemHeader Content="Overview" />
                <NavigationViewItem Icon="Home" Content="Dashboard" Tag="Onyx.Oms.Client.Desktop.Features.Dashboard.DashboardPage" />
                
                <NavigationViewItemHeader Content="Sales" />
                <NavigationViewItem Icon="Shop" Content="Orders" Tag="Onyx.Oms.Client.Desktop.Features.Orders.List.OrdersPage" />
                <NavigationViewItem Icon="Contact" Content="Customers" Tag="Onyx.Oms.Client.Desktop.Features.Customers.CustomersPage" />
                
                <NavigationViewItemHeader Content="Operations" />
                <NavigationViewItem Icon="List" Content="Fulfillment" Tag="Onyx.Oms.Client.Desktop.Features.FulfillmentTasks.List.FulfillmentTasksPage" />
                <NavigationViewItem Icon="Library" Content="Catalog" Tag="Onyx.Oms.Client.Desktop.Features.Catalog.CatalogPage">
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="Categories" Tag="Onyx.Oms.Client.Desktop.Features.ProductCategories.ProductCategoriesPage" />
                        <NavigationViewItem Content="Products" Tag="Onyx.Oms.Client.Desktop.Features.Products.List.ProductsPage" />
                        <!--<NavigationViewItem Content="Variants" Tag="Onyx.Oms.Client.Desktop.Features.ProductVariants.ProductVariantsPage" />-->
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
                <NavigationViewItem Icon="Send" Content="Couriers" Tag="Onyx.Oms.Client.Desktop.Features.Couriers.CouriersPage" />

                <NavigationViewItemHeader Content="Finance" />
                <NavigationViewItem Icon="Calculator" Content="Expenses" Tag="Onyx.Oms.Client.Desktop.Features.Expenses.List.ExpensesPage" />
                <NavigationViewItem Icon="Document" Content="Financial Report" Tag="Onyx.Oms.Client.Desktop.Features.Reports.FinancialReportPage" />

                <!--<NavigationViewItemHeader Content="Administration" />
                <NavigationViewItem Icon="ContactInfo" Content="Users" Tag="Onyx.Oms.Client.Desktop.Features.Users.UsersPage" />
                <NavigationViewItem Icon="People" Content="Roles" Tag="Onyx.Oms.Client.Desktop.Features.Roles.RolesPage" />-->
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" ScrollViewer.VerticalScrollBarVisibility="Disabled" />
        </NavigationView>

        <!-- Login View Overlay -->
        <local:LoginView x:Name="LoginView"
                         Grid.Row="1"
                         Grid.RowSpan="2"
                         Visibility="Visible"
                         Canvas.ZIndex="10" />

        <!-- License Validation Overlay -->
        <local:LicenseValidationView x:Name="LicenseValidation"
                                     Grid.Row="1"
                                     Grid.RowSpan="2"
                                     Visibility="Collapsed"
                                     Canvas.ZIndex="12" />

        <local:RestoreView x:Name="RestoreView"
                   Grid.Row="1"
                   Grid.RowSpan="2"
                   Visibility="Collapsed"
                   Canvas.ZIndex="13" />

        <!-- User Onboarding Overlay -->
        <onboarding:UserOnboarding x:Name="UserOnboardingView"
                                   Grid.Row="1"
                                   Grid.RowSpan="2"
                                   Visibility="Collapsed"
                                   Canvas.ZIndex="11" />

        <!-- Notification Overlay -->
        <InfoBar x:Name="ShellInfoBar"
                 Grid.Row="1"
                 Grid.RowSpan="2"
                 VerticalAlignment="Bottom"
                 HorizontalAlignment="Right"
                 Margin="24"
                 Canvas.ZIndex="9999"
                 IsOpen="False" />

    </Grid>

</Window>
