<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Dashboard.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Dashboard"
    xmlns:controls="using:Onyx.Oms.Client.Desktop.Shared.Controls"
    xmlns:sharedConerters="using:Onyx.Oms.Client.Desktop.Shared.Converters"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <sharedConerters:ThemeResourceConverter x:Key="ThemeResourceConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
        <AcrylicBrush x:Key="GlassCardAcrylicBrush" TintColor="{ThemeResource SystemAltHighColor}" TintOpacity="0.4" FallbackColor="{ThemeResource SolidBackgroundFillColorBase}" />
        <Style x:Key="GlassQuickActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GlassCardAcrylicBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="110" />
            <Setter Property="Height" Value="90" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="BackgroundBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}" />

                            <Border x:Name="DisabledOverlay"
                            Background="{ThemeResource ControlFillColorDisabledBrush}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Opacity="0" />

                            <Border x:Name="HighlightOverlay"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Opacity="0" />

                            <ContentPresenter x:Name="ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />

                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HighlightOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.7" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>

                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HighlightOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.3" Duration="0:0:0.05" />
                                        </Storyboard>
                                    </VisualState>

                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.35" Duration="0" />

                                            <DoubleAnimation Storyboard.TargetName="DisabledOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.5" Duration="0" />

                                            <DoubleAnimation Storyboard.TargetName="BackgroundBorder"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.8" Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DashboardTileButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource SurfaceStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,14,16,16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="120"/>
        </Style>
        <Style x:Key="ChipBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ProgressBar Grid.Row="0" 
                     VerticalAlignment="Bottom" 
                     HorizontalAlignment="Stretch" 
                     IsIndeterminate="True" 
                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" 
                     Canvas.ZIndex="100" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Hero Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Quick Actions -->
                    <RowDefinition Height="Auto"/>
                    <!-- Today at a glance -->
                    <RowDefinition Height="Auto"/>
                    <!-- Action Required & In Motion Panels -->
                </Grid.RowDefinitions>

                <!-- 1. Hero Header -->
                <Grid Grid.Row="0" Height="160">

                    <controls:OpacityMaskView Height="160" VerticalAlignment="Stretch">
                        <controls:OpacityMaskView.OpacityMask>
                            <Rectangle>
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                        <GradientStop Color="#00000000" Offset="0.0" />
                                        <GradientStop Color="#80FFFFFF" Offset="0.25" />
                                        <GradientStop Color="{ThemeResource SolidBackgroundFillColorBase}" Offset="0.5" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </controls:OpacityMaskView.OpacityMask>
                        <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                            <Image Source="ms-appx:///Assets/hero_bg.jpg" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </controls:OpacityMaskView>

                    <!-- Greeting Content -->
                    <StackPanel VerticalAlignment="Bottom" Margin="40,0,0,50">
                        <TextBlock Text="{x:Bind ViewModel.Greeting, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.UserName, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" Foreground="{ThemeResource AccentTextFillColorTertiaryBrush}" FontWeight="Bold" Margin="0,2,0,0" />
                        <TextBlock Text="{x:Bind ViewModel.HeroSubLabel, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Refresh Button -->
                    <Button Command="{x:Bind ViewModel.RefreshCommand}" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Top" 
                            Margin="24,24" Background="Transparent" BorderThickness="0" Padding="8" ToolTipService.ToolTip="Refresh Dashboard">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Button>

                </Grid>

                <!-- 2. Quick Actions -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="40,-48,40,24" HorizontalAlignment="Right" VerticalAlignment="Top">

                    <Button Style="{StaticResource GlassQuickActionButtonStyle}" Command="{x:Bind ViewModel.NavigateToCreateOrderCommand}">
                        <StackPanel VerticalAlignment="Center" Spacing="6">
                            <FontIcon Glyph="&#xE710;" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontSize="24" />
                            <TextBlock Text="New order" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource GlassQuickActionButtonStyle}" Command="{x:Bind ViewModel.NavigateToShipOrdersCommand}">
                        <StackPanel VerticalAlignment="Center" Spacing="6">
                            <FontIcon Glyph="&#xE701;" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontSize="24" />
                            <TextBlock Text="Ship orders" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource GlassQuickActionButtonStyle}" Command="{x:Bind ViewModel.NavigateToTasksCommand}">
                        <StackPanel VerticalAlignment="Center" Spacing="6">
                            <FontIcon Glyph="&#xE9D5;" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontSize="24" />
                            <TextBlock Text="Task backlog" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource GlassQuickActionButtonStyle}" Command="{x:Bind ViewModel.NavigateToCreateProductCommand}">
                        <StackPanel VerticalAlignment="Center" Spacing="6">
                            <FontIcon Glyph="&#xECCD;" Foreground="{ThemeResource AccentFillColorDefaultBrush}" FontSize="24" />
                            <TextBlock Text="Add product" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- 3. Today at a glance -->
                <StackPanel Grid.Row="2" Padding="40,0" Spacing="10" Margin="0,0,0,24">

                    <TextBlock Text="TODAY AT A GLANCE" 
                               FontSize="11" FontWeight="SemiBold" CharacterSpacing="80" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>

                    <Grid ColumnSpacing="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Pending Orders -->
                        <Button Grid.Column="0" Command="{x:Bind ViewModel.NavigateToPendingOrdersCommand}" Style="{StaticResource DashboardTileButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Pending confirmation" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{x:Bind ViewModel.Summary.Stats.PendingOrders, Mode=OneWay, TargetNullValue='--'}" FontSize="28" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                    <TextBlock Text="awaiting payment" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource ChipBorderStyle}" Background="{ThemeResource SystemFillColorCautionBackgroundBrush}">
                                    <TextBlock Text="View orders" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Ready to Pack -->
                        <Button Grid.Column="1" Command="{x:Bind ViewModel.NavigateToReadyToPackCommand}" Style="{StaticResource DashboardTileButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Ready to pack" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{x:Bind ViewModel.Summary.Stats.ReadyToPack, Mode=OneWay, TargetNullValue='--'}" FontSize="28" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                    <TextBlock Text="all items fulfilled" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource ChipBorderStyle}" Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}">
                                    <TextBlock Text="Start packing" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Tasks Completed -->
                        <Button Grid.Column="2" Command="{x:Bind ViewModel.NavigateToTasksCompletedCommand}" Style="{StaticResource DashboardTileButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Tasks completed" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{x:Bind ViewModel.Summary.Stats.TasksCompletedUnallocated, Mode=OneWay, TargetNullValue='--'}" FontSize="28" FontWeight="Medium"/>
                                    <TextBlock Text="ready to allocate" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource ChipBorderStyle}" Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}">
                                    <TextBlock Text="View tasks" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Shipped Today -->
                        <Button Grid.Column="3" Command="{x:Bind ViewModel.NavigateToShippedTodayCommand}" Style="{StaticResource DashboardTileButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Shipped today" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{x:Bind ViewModel.Summary.Stats.ShippedToday, Mode=OneWay, TargetNullValue='--'}" FontSize="28" FontWeight="Medium"/>
                                    <TextBlock Text="with courier" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource ChipBorderStyle}" Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}">
                                    <TextBlock Text="Track" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </Border>
                            </Grid>
                        </Button>

                    </Grid>

                </StackPanel>

                <!-- 4. Action Required & In Motion -->
                <StackPanel Grid.Row="3" Padding="40,0" Spacing="10" Margin="0,0,0,40">

                    <TextBlock Text="NEEDS ATTENTION · IN MOTION" 
                               FontSize="11" FontWeight="SemiBold" CharacterSpacing="80" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>

                    <Grid ColumnSpacing="16">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Action Required Panel -->
                        <Border Grid.Column="0" 
                                Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" 
                                BorderThickness="0" CornerRadius="12">

                            <StackPanel>

                                <Grid Padding="16,12" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE783;" FontSize="14" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                        <TextBlock Text="Action required" FontWeight="Medium" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="View all" FontSize="11" 
                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>

                                <ItemsControl ItemsSource="{x:Bind ViewModel.ActionRequiredItems, Mode=OneWay}">

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:ActionRequiredUIItem">
                                            <!-- To navigate, bind Command on this Button -->
                                            <Button Background="Transparent" 
                                                    BorderThickness="0" Padding="16,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" 
                                                            Background="{Binding SemanticBackgroundName, Converter={StaticResource ThemeResourceConverter}}" 
                                                            Margin="0,0,12,0">
                                                        <FontIcon Glyph="{x:Bind IconGlyph}" FontSize="16" Foreground="{Binding SemanticBrushName, Converter={StaticResource ThemeResourceConverter}}"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                                        <TextBlock Text="{x:Bind Data.OrderNumber}" FontWeight="Medium" FontSize="13" TextTrimming="CharacterEllipsis">
                                                            <Run Text=" · "/>
                                                            <Run Text="{x:Bind Data.CustomerName}"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{x:Bind Data.ReasonLabel}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                        <TextBlock Text="{x:Bind Data.TotalAmount}" FontWeight="Medium" FontSize="13" HorizontalAlignment="Right">
                                                            <Run Text=" "/>
                                                            <Run Text="{x:Bind Data.Currency}" FontSize="11"/>
                                                        </TextBlock>
                                                        <Border Background="{Binding SemanticBackgroundName, Converter={StaticResource ThemeResourceConverter}}" CornerRadius="12" Padding="8,2" Margin="0,4,0,0" HorizontalAlignment="Right">
                                                            <TextBlock Text="{x:Bind Data.Status}" FontSize="10" FontWeight="Medium" Foreground="{Binding SemanticBrushName, Converter={StaticResource ThemeResourceConverter}}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>

                            </StackPanel>
                            
                        </Border>

                        <!-- In Motion Panel -->
                        <Border Grid.Column="1" 
                                Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0" CornerRadius="12">

                            <StackPanel>

                                <Grid Padding="16,12" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE9D5;" FontSize="14" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                        <TextBlock Text="In motion" FontWeight="Medium" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="View all" FontSize="11" 
                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>

                                <ItemsControl ItemsSource="{x:Bind ViewModel.InMotionItems, Mode=OneWay}">

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:InMotionUIItem">
                                            <!-- To navigate, bind Command on this Button -->
                                            <Button Background="Transparent" BorderThickness="0" Padding="16,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Colored dot -->
                                                    <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,12,0" VerticalAlignment="Center"
                                                             Fill="{Binding DotBrushName, Converter={StaticResource ThemeResourceConverter}}" />
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                                        <TextBlock FontWeight="Medium" FontSize="13" TextTrimming="CharacterEllipsis">
                                                            <Run Text="{x:Bind Data.VariantLabel}"/>
                                                            <Run Text=" · "/>
                                                            <Run Text="{x:Bind Data.TaskType}"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{x:Bind Data.ContextLabel}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" FontWeight="Medium" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                        <Run Text="{x:Bind Data.Quantity}"/>
                                                        <Run Text=" units"/>
                                                    </TextBlock>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>

                            </StackPanel>
                            
                        </Border>

                    </Grid>

                </StackPanel>

            </Grid>
            
        </ScrollViewer>

    </Grid>
</Page>
