<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Onyx.Oms.Client.Desktop.Features.FulfillmentTasks.ProductPicker.ProductPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.FulfillmentTasks.ProductPicker"
    xmlns:parent="using:Onyx.Oms.Client.Desktop.Features.FulfillmentTasks"
    xmlns:controls="using:Onyx.Oms.Client.Desktop.Features.FulfillmentTasks.ProductCategoryPicker"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Select a Product"
    PrimaryButtonText="Select"
    SecondaryButtonText="Cancel"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    SecondaryButtonClick="ContentDialog_SecondaryButtonClick"
    DefaultButton="Primary"
    Style="{StaticResource DefaultContentDialogStyle}" IsPrimaryButtonEnabled="{x:Bind ViewModel.HasSelection, Mode=OneWay}">

    <ContentDialog.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </ContentDialog.Resources>

    <Grid Width="500" Height="Auto" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filters -->
        <Grid Grid.Row="0" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <AutoSuggestBox Grid.Column="0"
                            PlaceholderText="Search by SKU or Name..."
                            QueryIcon="Find"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QuerySubmitted="AutoSuggestBox_QuerySubmitted"/>

            <controls:ProductCategoryPicker x:Name="CategoryPicker"
                                            Grid.Column="1"
                                            IsLeafOnly="False"
                                            HorizontalAlignment="Stretch"
                                            SelectedCategory="{x:Bind ViewModel.SelectedProductCategory, Mode=TwoWay}"/>

            <Button Grid.Column="2" Style="{StaticResource SubtleButtonStyle}" ToolTipService.ToolTip="Refresh Data"
                    Command="{x:Bind ViewModel.RefreshCommand}">
                <FontIcon Glyph="&#xE72C;" FontSize="16"/>
            </Button>
        </Grid>

        <Grid Grid.Row="1" x:Name="TableContainer" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" CornerRadius="4">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Disabled">

                <ListView ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                          SelectionMode="Single"
                          SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                          Visibility="{x:Bind ViewModel.IsListLoading, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}">

                    <ListView.ItemTemplate>
                        <!--<DataTemplate x:DataType="local:ProductPickerGridItem">

                            <StackPanel Padding="0,8" Orientation="Horizontal" Spacing="8">
                                <StackPanel Orientation="Vertical" Spacing="8" HorizontalAlignment="Left">
                                    <Grid HorizontalAlignment="Left" Width="84" Height="84" CornerRadius="4" Background="{ThemeResource LayerFillColorAltBrush}" BorderThickness="1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" >
                                        <FontIcon Glyph="&#xE8B9;" FontSize="16" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <Image Source="{x:Bind ImageSource, Mode=OneWay}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>

                                    <StackPanel Orientation="Vertical" Spacing="4">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind BaseSku}" Style="{StaticResource CaptionTextBlockStyle}" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind CategoryPath}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                            </StackPanel>
                            
                        </DataTemplate>-->
                        <DataTemplate x:DataType="local:ProductPickerGridItem">
                            <Grid Padding="0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="84" Height="84" CornerRadius="4" 
                                      Background="{ThemeResource LayerFillColorAltBrush}" BorderThickness="1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}">
                                    <FontIcon Glyph="&#xE8B9;" FontSize="16" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <Image Source="{x:Bind ImageSource, Mode=OneWay}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>

                                <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="8" Margin="16,0,0,0">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Vertical" Spacing="2">
                                            <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{x:Bind CategoryPath}" Style="{StaticResource CaptionTextBlockStyle}" 
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{x:Bind BaseSku}" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind AvailableQuantity}" Style="{StaticResource CaptionTextBlockStyle}" 
                                                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                       Visibility="{x:Bind HasVariants, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Grid>

                                    <ItemsControl ItemsSource="{x:Bind UiOptions}" 
                                                  Visibility="{x:Bind HasVariants, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:UiOption">
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,4">

                                                    <TextBlock Text="{x:Bind Name}" Width="60" VerticalAlignment="Center" 
                                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                                    <ItemsControl ItemsSource="{x:Bind Values}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <!--<VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="5"/>-->
                                                                <labs:WrapPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="local:UiOptionValue">

                                                                <ToggleButton Content="{x:Bind Value}" 
                                                                              IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                                              Margin="0,0,4,4"
                                                                              Padding="12,4"
                                                                              CornerRadius="14"
                                                                              MinHeight="28"/>

                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    
                </ListView>
                
            </ScrollViewer>

            <!-- Loading Indicator -->
            <!--<Grid Opacity="0.8" 
                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ProgressRing IsActive="True" Width="48" Height="48" />
            </Grid>-->

            <!-- No Data Message -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                        Visibility="{x:Bind ViewModel.HasNoData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <FontIcon Glyph="&#xE719;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock HorizontalAlignment="Center" Text="No products found." 
                           Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Content="Clear Filters" 
                        Command="{x:Bind ViewModel.ClearFiltersCommand}" 
                        Style="{StaticResource DefaultButtonStyle}" 
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Pagination -->
        <Grid Grid.Row="2" Padding="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Rows:" VerticalAlignment="Center" 
                           Style="{StaticResource CaptionTextBlockStyle}" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.PageSizes}" 
                          SelectedItem="{x:Bind ViewModel.PageSize, Mode=TwoWay}"
                          Style="{StaticResource DefaultComboBoxStyle}"
                          MinWidth="70" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Column="1" 
                       Text="{x:Bind ViewModel.PageSummary, Mode=OneWay}" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button Style="{StaticResource SubtleButtonStyle}" 
                        Command="{x:Bind ViewModel.PreviousPageCommand}" 
                        IsEnabled="{x:Bind ViewModel.HasPreviousPage, Mode=OneWay}" 
                        ToolTipService.ToolTip="Previous Page">
                    <FontIcon Glyph="&#xE76B;" FontSize="12" />
                </Button>
                <Button Style="{StaticResource SubtleButtonStyle}" 
                        Command="{x:Bind ViewModel.NextPageCommand}" 
                        IsEnabled="{x:Bind ViewModel.HasNextPage, Mode=OneWay}" 
                        ToolTipService.ToolTip="Next Page">
                    <FontIcon Glyph="&#xE76C;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>

    </Grid>
</ContentDialog>
