<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Onyx.Oms.Client.Desktop.Features.Customers.CustomerDetailsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Customers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d"
    Title="Customer Details"
    CloseButtonText="Close"
    DefaultButton="Close"
    CornerRadius="8"
    CloseButtonStyle="{StaticResource AccentButtonStyle}"
    Style="{StaticResource DefaultContentDialogStyle}">

    <ContentDialog.Resources>
        <converters:EmptyStringToObjectConverter x:Key="StringToVisibilityConverter" EmptyValue="Collapsed" NotEmptyValue="Visible" />
    </ContentDialog.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel MinWidth="350" MaxWidth="550" Spacing="20" Padding="0,8,0,0">

            <Grid ColumnSpacing="16">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <PersonPicture DisplayName="{x:Bind Customer.Name, Mode=OneTime}" Height="64" Width="64" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                    <TextBlock Text="{x:Bind Customer.Name, Mode=OneTime}" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" IsTextSelectionEnabled="True" />

                    <Border Style="{StaticResource StatusBadgeStyle}" 
                            HorizontalAlignment="Left"
                            Background="{x:Bind Customer.IsActive, Mode=OneTime, Converter={StaticResource StatusBackgroundConverter}}">
                        <TextBlock Text="{x:Bind Customer.IsActive, Mode=OneTime, Converter={StaticResource StatusTextConverter}}"
                                   Style="{StaticResource StatusBadgeTextStyle}"
                                   Foreground="{x:Bind Customer.IsActive, Mode=OneTime, Converter={StaticResource StatusForegroundConverter}}" />
                    </Border>
                </StackPanel>

            </Grid>

            <MenuFlyoutSeparator />

            <Grid RowSpacing="16" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Email" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind Customer.Email, Mode=OneTime}" Style="{StaticResource BodyTextBlockStyle}" IsTextSelectionEnabled="True" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Primary Phone" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind Customer.PrimaryPhone, Mode=OneTime}" Style="{StaticResource BodyTextBlockStyle}" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Last Order" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind Customer.LastOrderNumber, Mode=OneTime}" Style="{StaticResource BodyTextBlockStyle}" IsTextSelectionEnabled="True" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Visibility="{x:Bind Customer.SecondaryPhone, Mode=OneTime, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="Secondary Phone" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind Customer.SecondaryPhone, Mode=OneTime}" Style="{StaticResource BodyTextBlockStyle}" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                </StackPanel>
            </Grid>

            <StackPanel Spacing="16">
                <StackPanel>
                    <TextBlock Text="Shipping Address" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind FullAddress, Mode=OneTime}" Style="{StaticResource BodyTextBlockStyle}" IsTextSelectionEnabled="True" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Visibility="{x:Bind Customer.DeliveryInstructions, Mode=OneTime, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="Delivery Instructions" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="4" Padding="12" Margin="0,4,0,0">
                        <TextBlock Text="{x:Bind Customer.DeliveryInstructions, Mode=OneTime}" 
                                   Style="{StaticResource BodyTextBlockStyle}" 
                                   FontStyle="Italic"
                                   TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                    </Grid>
                </StackPanel>
                
                <StackPanel Visibility="{x:Bind Customer.Notes, Mode=OneTime, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="Internal Notes" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="4" Padding="12" Margin="0,4,0,0">
                        <TextBlock Text="{x:Bind Customer.Notes, Mode=OneTime}" 
                                   Style="{StaticResource BodyTextBlockStyle}" 
                                   FontStyle="Italic"
                                   TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                    </Grid>
                </StackPanel>
            </StackPanel>

        </StackPanel>
        
    </ScrollViewer>
    
</ContentDialog>
