<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Catalog.CatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Catalog"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Global Header -->
        <Grid Grid.Row="0" Padding="16,12" 
              Background="{ThemeResource LayerFillColorDefaultBrush}" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="8">
                <TextBlock Text="Catalog Dashboard" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                <TextBlock Text="Overview of your inventory, products, and categories." 
                           Style="{StaticResource BodyTextBlockStyle}" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <ProgressRing Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" 
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                          Width="24" Height="24" Margin="0,4,0,0"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="24,32" Spacing="32" MaxWidth="1400" HorizontalAlignment="Left">

                <!-- KPI Section -->
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource KpiCardStyle}" BorderBrush="{ThemeResource AccentFillColorDefaultBrush}" BorderThickness="0,4,0,0">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE719;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="Total Products" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.Summary.TotalProducts, Mode=OneWay, TargetNullValue='--'}" 
                                       Style="{StaticResource TitleLargeTextBlockStyle}" 
                                       FontWeight="Bold"/>
                            <Border Style="{StaticResource StatusBadgeStyle}" Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}" HorizontalAlignment="Left">
                                <TextBlock Text="{x:Bind ViewModel.ActiveProductsText, Mode=OneWay}" 
                                       Style="{StaticResource StatusBadgeTextStyle}" 
                                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource KpiCardStyle}" BorderBrush="{ThemeResource SystemFillColorCautionBrush}" BorderThickness="0,4,0,0">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE81E;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="Total Categories" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.Summary.TotalCategories, Mode=OneWay, TargetNullValue='--'}" 
                                       Style="{StaticResource TitleLargeTextBlockStyle}" 
                                       FontWeight="Bold"/>
                            <TextBlock Text="Organized hierarchies" 
                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource KpiCardStyle}" BorderBrush="{ThemeResource SystemFillColorCriticalBrush}" BorderThickness="0,4,0,0">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7BA;" FontSize="16" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                <TextBlock Text="Inventory Alerts" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.Summary.OutOfStockVariants, Mode=OneWay, TargetNullValue='--'}" 
                                       Style="{StaticResource TitleLargeTextBlockStyle}" 
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       FontWeight="Bold"/>
                            <Border Style="{StaticResource StatusBadgeStyle}" Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}" HorizontalAlignment="Left" Visibility="{x:Bind ViewModel.HasLowStockAlert, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{x:Bind ViewModel.LowStockText, Mode=OneWay}" 
                                       Style="{StaticResource StatusBadgeTextStyle}" 
                                       Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                </Grid>

                <StackPanel Spacing="16">
                    <TextBlock Text="Manage Catalog" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />

                    <GridView ItemsSource="{x:Bind ViewModel.NavigationItems, Mode=OneWay}"
                              SelectionMode="None"
                              IsItemClickEnabled="False">

                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,16,16"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </GridView.ItemContainerStyle>

                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="local:CatalogNavigationItem">

                                <Button Style="{StaticResource NavigationCardButtonStyle}" 
                                        Width="380" MinHeight="120"
                                        Command="{x:Bind Command}"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                                    <Grid ColumnSpacing="16" Padding="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" 
                                                Width="56" Height="56" 
                                                CornerRadius="28" 
                                                Background="{ThemeResource LayerFillColorAltBrush}" 
                                                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                VerticalAlignment="Top">
                                            <FontIcon FontFamily="Segoe MDL2 Assets" 
                                                      Glyph="{x:Bind IconGlyph}" 
                                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}" 
                                                      FontSize="20"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                            <TextBlock Text="{x:Bind Title}" 
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" 
                                                       FontSize="16" />

                                            <TextBlock Text="{x:Bind Description}" 
                                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </GridView.ItemTemplate>

                    </GridView>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
