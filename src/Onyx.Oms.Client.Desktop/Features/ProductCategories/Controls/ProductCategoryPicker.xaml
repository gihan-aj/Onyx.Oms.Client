<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Onyx.Oms.Client.Desktop.Features.ProductCategories.Controls.ProductCategoryPicker"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.ProductCategories"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- Trigger Button -->
        <Button x:Name="PickerButton" 
                Click="PickerButton_Click" 
                HorizontalAlignment="Stretch" 
                HorizontalContentAlignment="Left">
            <Button.Content>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="HeaderButtonText" 
                               Text="{x:Bind PlaceholderText, Mode=OneWay}" 
                               TextTrimming="CharacterEllipsis"/>
                    <FontIcon Grid.Column="1" 
                              FontFamily="Segoe MDL2 Assets" 
                              Glyph="&#xE70D;" 
                              FontSize="12" 
                              Margin="8,0,0,0" />
                </Grid>
            </Button.Content>
            
            <Button.Flyout>
                <Flyout Placement="Bottom" 
                        Opened="Flyout_Opened" 
                        Closed="Flyout_Closed">
                    <Grid Width="350" MaxHeight="200">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Search Box -->
                        <TextBox x:Name="SearchBox" 
                                 PlaceholderText="Search categories..." 
                                 TextChanged="SearchBox_TextChanged" 
                                 Margin="0,0,0,8" />

                        <!-- List -->
                        <ListView x:Name="ItemsListView" 
                                  Grid.Row="1" 
                                  ItemsSource="{x:Bind Items, Mode=OneWay}"
                                  SelectionMode="Single" 
                                  SelectionChanged="ItemsListView_SelectionChanged"
                                  Loaded="ItemsListView_Loaded"
                                  Unloaded="ItemsListView_Unloaded">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:ProductCategoryDto">
                                    <TextBlock Text="{x:Bind NamePath, TargetNullValue='Unnamed Category'}" TextTrimming="CharacterEllipsis" Margin="0,8"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Loading Indicators -->
                        <!-- Initial Loading Spinner -->
                        <ProgressRing Grid.Row="1" 
                                      IsActive="{x:Bind IsLoading, Mode=OneWay}" 
                                      Width="30" Height="30" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center" 
                                      Visibility="{x:Bind HasItemsToHideRing(Items.Count), Mode=OneWay}" />

                        <!-- Lazy Loading Indeterminate Bar -->
                        <ProgressBar Grid.Row="2" 
                                     IsIndeterminate="True" 
                                     Visibility="{x:Bind IsLoadingNextPageVisibility(IsLoading, Items.Count), Mode=OneWay}" 
                                     Margin="0,8,0,0" />

                    </Grid>
                </Flyout>
            </Button.Flyout>
        </Button>
    </Grid>
</UserControl>
