<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Onyx.Oms.Client.Desktop.Shared.Shell.LicenseValidationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="UserControl_Loaded">

    <Grid>
        <!-- Background is Transparent to let Window's MicaBackdrop show through -->
        <Grid.Background>
            <SolidColorBrush Color="Transparent" />
        </Grid.Background>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" MaxWidth="500">
            <!-- Logo area -->
            <Image Source="/Assets/StoreLogo.scale-400.png" Width="100" Height="100" HorizontalAlignment="Center" />
            
            <TextBlock Text="Activation Required" 
                       Style="{StaticResource TitleTextBlockStyle}" 
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

            <TextBlock Text="A valid license key is required to use Onyx OMS on this device. Please send the Hardware ID below to your software provider." 
                       Style="{StaticResource BodyTextBlockStyle}" 
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- Hardware ID Section -->
            <StackPanel Spacing="8" Margin="0,12,0,12">
                <TextBlock Text="Hardware ID" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="HardwareIdBox" 
                             Grid.Column="0" 
                             IsReadOnly="True" 
                             FontFamily="Consolas" />
                             
                    <Button Grid.Column="1"  
                            Click="CopyHardwareId_Click" 
                            ToolTipService.ToolTip="Copy to Clipboard">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                <TextBlock Text="Copy" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Error Message -->
            <InfoBar x:Name="ErrorBanner"
                     Severity="Error"
                     Title="Validation Failed"
                     Message="The uploaded license key is invalid for this device."
                     IsOpen="False"
                     IsClosable="True" />

            <!-- Success Message -->
            <InfoBar x:Name="SuccessBanner"
                     Severity="Success"
                     Title="Validation Success"
                     Message="License activated successfully. Starting application..."
                     IsOpen="False"
                     IsClosable="False" />

            <Grid Height="40" Margin="0,12,0,0">
                <Button x:Name="UploadButton" 
                        Content="Upload License File" 
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center" 
                        Width="220" 
                        Height="40"
                        CornerRadius="20"
                        Click="UploadButton_Click"/>

                <ProgressRing x:Name="LoadingSpinner" 
                              IsActive="False" 
                              Visibility="Collapsed" 
                              Width="32" 
                              Height="32" 
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
