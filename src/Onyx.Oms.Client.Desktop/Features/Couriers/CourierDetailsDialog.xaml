<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Onyx.Oms.Client.Desktop.Features.Couriers.CourierDetailsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Couriers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Courier Details"
    CloseButtonText="Close"
    DefaultButton="Close"
    CornerRadius="8"
    CloseButtonStyle="{StaticResource AccentButtonStyle}"
    Style="{StaticResource DefaultContentDialogStyle}">

    <ContentDialog.Resources>
        <converters:EmptyStringToObjectConverter x:Key="StringToVisibilityConverter" EmptyValue="Collapsed" NotEmptyValue="Visible" />
    </ContentDialog.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MinWidth="350" MaxWidth="500" Spacing="20" Padding="0,8,0,0">
            <!-- Header Grid: Initials Circle + Name/Status -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <PersonPicture DisplayName="{x:Bind Courier.Name, Mode=OneTime}" Height="64" Width="64" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                    <TextBlock Text="{x:Bind Courier.Name, Mode=OneTime}" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" IsTextSelectionEnabled="True" />

                    <Border Style="{StaticResource StatusBadgeStyle}" 
                            HorizontalAlignment="Left"
                            Background="{x:Bind Courier.IsActive, Mode=OneTime, Converter={StaticResource StatusBackgroundConverter}}">
                        <TextBlock Text="{x:Bind Courier.IsActive, Mode=OneTime, Converter={StaticResource StatusTextConverter}}"
                                   Style="{StaticResource StatusBadgeTextStyle}"
                                   Foreground="{x:Bind Courier.IsActive, Mode=OneTime, Converter={StaticResource StatusForegroundConverter}}" />
                    </Border>
                </StackPanel>
            </Grid>

            <MenuFlyoutSeparator />

            <!-- Details Grid -->
            <Grid RowSpacing="16" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Contact Person -->
                <StackPanel Visibility="{x:Bind Courier.ContactPerson, Mode=OneTime, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="Contact Person" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind Courier.ContactPerson, Mode=OneTime}" Style="{StaticResource BodyTextBlockStyle}" IsTextSelectionEnabled="True" />
                </StackPanel>

                <!-- Website -->
                <StackPanel Grid.Column="1" Visibility="{x:Bind Courier.WebsiteUrl, Mode=OneTime, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="Website" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <HyperlinkButton Content="{x:Bind Courier.WebsiteUrl, Mode=OneTime}" 
                                     NavigateUri="{x:Bind WebsiteUri, Mode=OneTime}" 
                                     Padding="0" Margin="0" MinWidth="0" MinHeight="0" />
                </StackPanel>

                <!-- Primary Phone -->
                <StackPanel Grid.Row="1" Visibility="{x:Bind Courier.PrimaryPhone, Mode=OneTime, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="Primary Phone" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind Courier.PrimaryPhone, Mode=OneTime}" Style="{StaticResource BodyTextBlockStyle}" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                </StackPanel>

                <!-- Secondary Phone -->
                <StackPanel Grid.Row="1" Grid.Column="1" Visibility="{x:Bind Courier.SecondaryPhone, Mode=OneTime, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="Secondary Phone" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind Courier.SecondaryPhone, Mode=OneTime}" Style="{StaticResource BodyTextBlockStyle}" FontFamily="Consolas" IsTextSelectionEnabled="True" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
