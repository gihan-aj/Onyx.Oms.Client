<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="RootPage"
    x:Class="Onyx.Oms.Client.Desktop.Features.Products.Edit.EditProductPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Products.Edit"
    xmlns:parent="using:Onyx.Oms.Client.Desktop.Features.Products"
    xmlns:controls="using:Onyx.Oms.Client.Desktop.Features.Products.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:sharedConverters="using:Onyx.Oms.Client.Desktop.Shared.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
        <converters:EmptyObjectToObjectConverter x:Key="NullToVisibilityConverter" EmptyValue="Visible" NotEmptyValue="Collapsed" />
        <converters:EmptyCollectionToObjectConverter x:Key="EmptyListToVisibiltyConverter" EmptyValue="Visible" NotEmptyValue="Collapsed" />
        <sharedConverters:DecimalToDoubleConverter x:Key="DecimalToDoubleConverter" />
        <sharedConverters:StringListConverter x:Key="StringListConverter" />
        <sharedConverters:StringToBoolConverter x:Key="StringToBoolConverter" />

        <DataTemplate x:Key="TextSpecTemplate" x:DataType="parent:SpecFieldViewItem">
            <TextBox Header="{x:Bind Label}"
                 Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Enter value..."
                 Margin="0,0,0,12"/>
        </DataTemplate>

        <DataTemplate x:Key="SelectSpecTemplate" x:DataType="parent:SpecFieldViewItem">
            <ComboBox Header="{x:Bind Label}"
                  ItemsSource="{x:Bind Options}"
                  SelectedItem="{x:Bind Value, Mode=TwoWay}"
                  PlaceholderText="Select value..."
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,12"/>
        </DataTemplate>

        <DataTemplate x:Key="ToggleSpecTemplate" x:DataType="parent:SpecFieldViewItem">
            <CheckBox Content="{x:Bind Label}"
                  IsChecked="{x:Bind Value, Mode=TwoWay, Converter={StaticResource StringToBoolConverter}}"
                  Margin="0,0,0,12"/>
        </DataTemplate>

        <parent:FormTemplateSelector x:Key="SpecSelector"
                                 TextTemplate="{StaticResource TextSpecTemplate}"
                                 ComboBoxTemplate="{StaticResource SelectSpecTemplate}"
                                 ToggleTemplate="{StaticResource ToggleSpecTemplate}"/>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Sticky Header with Back Button -->
        <Grid Grid.Row="0" Padding="24,16"
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{x:Bind ViewModel.GoBackCommand}" 
                    Style="{StaticResource SubtleButtonStyle}" Margin="0,0,16,0">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>

            <TextBlock Grid.Column="1" 
                       Text="{x:Bind ViewModel.PageTitle, Mode=OneWay}" 
                       Style="{StaticResource SubtitleTextBlockStyle}" 
                       FontWeight="SemiBold" VerticalAlignment="Center" />
        </Grid>

        <ProgressBar Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" 
                     IsIndeterminate="True" 
                     Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" 
                     Canvas.ZIndex="100" />

        <!-- Scrollable Body -->
        <ScrollViewer Grid.Row="1" Padding="16" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10000*" MaxWidth="1200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" Spacing="16">
                    <!-- Section 2: Split View -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" MinWidth="350" />
                            <ColumnDefinition Width="1*" MinWidth="350" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="12">
                            <!-- Basic Information Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Basic Information" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="Product name, description, category, and base SKU." 
                                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <CommandBar Grid.Column="1" 
                                                Background="Transparent" 
                                                IsOpen="False" 
                                                DefaultLabelPosition="Right" 
                                                IsSticky="True">
                                        <AppBarButton Icon="Edit" Label="Edit" 
                                                      Visibility="{x:Bind ViewModel.BasicInfo.IsReadonly, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.BasicInfo.BeginEditCommand, Mode=OneWay}" />

                                        <AppBarButton Icon="Save" Label="Save" 
                                                      AllowFocusOnInteraction="True"
                                                      Visibility="{x:Bind ViewModel.BasicInfo.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.SaveBasicInfoCommand}" />

                                        <AppBarButton Icon="Cancel" Label="Cancel" 
                                                      Visibility="{x:Bind ViewModel.BasicInfo.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.BasicInfo.CancelEditCommand, Mode=OneWay}" />

                                    </CommandBar>
                                </Grid>

                                <!-- READONLY MODE -->
                                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.BasicInfo.IsReadonly, Mode=OneWay}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Product Name" 
                                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="{x:Bind ViewModel.BasicInfo.Name, Mode=OneWay}" 
                                                       Style="{StaticResource BodyTextBlockStyle}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Base SKU" 
                                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="{x:Bind ViewModel.BasicInfo.BaseSku, Mode=OneWay}" 
                                                       Style="{StaticResource BodyTextBlockStyle}" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel>
                                        <TextBlock Text="Category" 
                                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{x:Bind ViewModel.BasicInfo.SelectedCategory.NamePath, Mode=OneWay}" 
                                                   Style="{StaticResource BodyTextBlockStyle}" />
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Description" Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="{x:Bind ViewModel.BasicInfo.Description, Mode=OneWay}" 
                                                   Style="{StaticResource BodyTextBlockStyle}" 
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- EDIT MODE -->
                                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.BasicInfo.IsEditing, Mode=OneWay}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0" Header="Product Name *" Text="{x:Bind ViewModel.BasicInfo.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="1" Header="Base SKU" Text="{x:Bind ViewModel.BasicInfo.BaseSku, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <StackPanel>
                                        <TextBlock Text="Category *" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                        <controls:ProductCategoryPicker x:Name="CategoryPicker"
                                                                        IsLeafOnly="True"
                                                                        SelectedCategory="{x:Bind ViewModel.BasicInfo.SelectedCategory, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <TextBox Header="Description" 
                                             Text="{x:Bind ViewModel.BasicInfo.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             AcceptsReturn="True" 
                                             TextWrapping="Wrap" 
                                             Height="100" />
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Tags Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Tags" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="Keywords for search index and grouping." 
                                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <CommandBar Grid.Column="1" 
                                                Background="Transparent" 
                                                IsOpen="False" 
                                                DefaultLabelPosition="Right" 
                                                IsSticky="True">
                                        <AppBarButton Icon="Edit" Label="Edit" 
                                                      Visibility="{x:Bind ViewModel.Tags.IsReadonly, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.Tags.BeginEditCommand, Mode=OneWay}" />

                                        <AppBarButton Icon="Save" Label="Save" 
                                                      AllowFocusOnInteraction="True"
                                                      Visibility="{x:Bind ViewModel.Tags.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.SaveTagsCommand}" />

                                        <AppBarButton Icon="Cancel" Label="Cancel" 
                                                      Visibility="{x:Bind ViewModel.Tags.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.Tags.CancelEditCommand, Mode=OneWay}" />

                                    </CommandBar>
                                </Grid>

                                <!-- READONLY MODE -->
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Tags.Tags, Mode=OneWay}"
                                              Visibility="{x:Bind ViewModel.Tags.IsReadonly, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <labs:WrapPanel Orientation="Horizontal"
                                                            VerticalSpacing="8" HorizontalSpacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                    CornerRadius="14"
                                                    Padding="12,4"
                                                    Margin="0,0,8,8">
                                                <TextBlock Text="{x:Bind}" FontFamily="Consolas" FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- EDIT MODE -->
                                <labs:TokenizingTextBox Visibility="{x:Bind ViewModel.Tags.IsEditing, Mode=OneWay}"
                                                        Header="Tags (Type and press Enter)"
                                                        ItemsSource="{x:Bind ViewModel.Tags.Tags, Mode=OneWay}"
                                                        TokenDelimiter="&#13;"
                                                        PlaceholderText="e.g., Summer, Sale, New Arrival"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Column -->
                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="12">
                            <!-- Base Logistics Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Base Logistics" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="Fallback pricing and physical weight." 
                                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <CommandBar Grid.Column="1" 
                                                Background="Transparent" 
                                                IsOpen="False" 
                                                DefaultLabelPosition="Right" 
                                                IsSticky="True">
                                        <AppBarButton Icon="Edit" Label="Edit" 
                                                      Visibility="{x:Bind ViewModel.BaseLogistics.IsReadonly, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.BaseLogistics.BeginEditCommand, Mode=OneWay}" />

                                        <AppBarButton Icon="Save" Label="Save" 
                                                      AllowFocusOnInteraction="True"
                                                      Visibility="{x:Bind ViewModel.BaseLogistics.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.SaveBaseLogisticsCommand}" />

                                        <AppBarButton Icon="Cancel" Label="Cancel" 
                                                      Visibility="{x:Bind ViewModel.BaseLogistics.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.BaseLogistics.CancelEditCommand, Mode=OneWay}" />

                                    </CommandBar>
                                </Grid>

                                <!-- READONLY MODE -->
                                <StackPanel Visibility="{x:Bind ViewModel.BaseLogistics.IsReadonly, Mode=OneWay}" Spacing="12">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Base Cost:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{x:Bind ViewModel.BaseLogistics.BaseCostCurrency, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Bind ViewModel.BaseLogistics.BaseCostAmount, Mode=OneWay}" 
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Base Price:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{x:Bind ViewModel.BaseLogistics.BasePriceCurrency, Mode=OneWay}" 
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Bind ViewModel.BaseLogistics.BasePriceAmount, Mode=OneWay}" 
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnSpacing="16" Visibility="{x:Bind ViewModel.BaseLogistics.IsPhysycalProduct, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Base Weight:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{x:Bind ViewModel.BaseLogistics.BaseWeightAmount, Mode=OneWay}" VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Bind ViewModel.BaseLogistics.BaseWeightUnit, Mode=OneWay}" 
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnSpacing="16" Visibility="{x:Bind ViewModel.BaseLogistics.ShowStockFields, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Stock On Hand:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.BaseLogistics.StockOnHand, Mode=OneWay}" VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>

                                <!-- EDIT MODE -->
                                <StackPanel Visibility="{x:Bind ViewModel.BaseLogistics.IsEditing, Mode=OneWay}" Spacing="12">
                                    <Grid ColumnSpacing="12" Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Base Cost"
                                                       Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind ViewModel.BaseLogistics.BaseCostCurrency, Mode=OneTime}"
                                                           VerticalAlignment="Center" Grid.Column="0"/>
                                                <NumberBox Value="{x:Bind ViewModel.BaseLogistics.BaseCostAmount, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}"
                                                           Minimum="0" Grid.Column="1"/>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Base Price"
                                                       Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind ViewModel.BaseLogistics.BasePriceCurrency, Mode=OneTime}"
                                                            VerticalAlignment="Center" Grid.Column="0"/>
                                                <NumberBox Value="{x:Bind ViewModel.BaseLogistics.BasePriceAmount, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}"
                                                           Minimum="0" Grid.Column="1"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <CheckBox Content="This is a physical product (requires shipping)" 
                                              IsChecked="{x:Bind ViewModel.BaseLogistics.IsPhysycalProduct, Mode=TwoWay}"
                                              Margin="0,0,0,8"/>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Weight field (hidden if digital) -->
                                        <StackPanel Grid.Column="0"
                                                    Visibility="{x:Bind ViewModel.BaseLogistics.IsPhysycalProduct, Mode=OneWay}">
                                            <TextBlock Text="Base Weight"
                                                       Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <NumberBox Value="{x:Bind ViewModel.BaseLogistics.BaseWeightAmount, Mode=TwoWay, Converter={StaticResource DecimalToDoubleConverter}}"
                                                           Minimum="0" Grid.Column="0"/>
                                                <TextBlock Text="{x:Bind ViewModel.BaseLogistics.BaseWeightUnit, Mode=OneWay}"
                                                           VerticalAlignment="Center" Grid.Column="1"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Stock (hidden if has variants) -->
                                        <NumberBox Header="Stock On Hand"
                                                   Value="{x:Bind ViewModel.BaseLogistics.StockOnHand, Mode=TwoWay}"
                                                   Visibility="{x:Bind ViewModel.BaseLogistics.ShowStockFields, Mode=OneWay}"
                                                   Minimum="0" Grid.Column="0"/>

                                    </Grid>
                                </StackPanel>

                            </StackPanel>
                            
                            <!-- Specifications Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Specifications" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="Product attributes specific to its category." 
                                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <CommandBar Grid.Column="1" 
                                                Background="Transparent" 
                                                IsOpen="False" 
                                                DefaultLabelPosition="Right" 
                                                IsSticky="True">
                                        <AppBarButton Icon="Edit" Label="Edit" 
                                                      Visibility="{x:Bind ViewModel.Specifications.IsReadonly, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.Specifications.BeginEditCommand, Mode=OneWay}" />

                                        <AppBarButton Icon="Save" Label="Save" 
                                                      AllowFocusOnInteraction="True"
                                                      Visibility="{x:Bind ViewModel.Specifications.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.SaveSpecificationsCommand}" />

                                        <AppBarButton Icon="Cancel" Label="Cancel" 
                                                      Visibility="{x:Bind ViewModel.Specifications.IsEditing, Mode=OneWay}"
                                                      Command="{x:Bind ViewModel.Specifications.CancelEditCommand, Mode=OneWay}" />

                                    </CommandBar>
                                </Grid>

                                <!-- READONLY MODE -->
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Specifications.SpecFields, Mode=OneWay}"
                                               Visibility="{x:Bind ViewModel.Specifications.IsReadonly, Mode=OneWay}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="parent:SpecFieldViewItem">
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{x:Bind Label}" 
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{x:Bind Value}" 
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                                <!-- EDIT MODE -->
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Specifications.SpecFields, Mode=OneWay}"
                                              ItemTemplateSelector="{StaticResource SpecSelector}"
                                              Margin="0,0,0,12"
                                              Visibility="{x:Bind ViewModel.Specifications.IsEditing, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="12" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                            
                        </StackPanel>
                    </Grid>

                    <StackPanel Style="{StaticResource CardStackStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Product Variations" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Does this product come in multiple options like size or color?" 
                                           Style="{StaticResource CaptionTextBlockStyle}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <ToggleSwitch x:Name="HasVariantsToggleSwitch" 
                                          Grid.Column="1"
                                          IsOn="{x:Bind ViewModel.HasVariants, Mode=OneWay}"
                                          Toggled="HasVariantsToggleSwitch_Toggled"
                                          OnContent="Has Variants"
                                          OffContent="Single Product"/>
                        </Grid>
                    </StackPanel>

                    <!-- Options Section -->
                    <StackPanel Style="{StaticResource CardStackStyle}" Visibility="{x:Bind ViewModel.HasVariants, Mode=OneWay}">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Product Options" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Define dynamic options like size, color, or material to generate unique variant SKUs." 
                                           Style="{StaticResource CaptionTextBlockStyle}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <CommandBar Grid.Column="1" 
                                        Background="Transparent" 
                                        IsOpen="False" 
                                        DefaultLabelPosition="Right" 
                                        IsSticky="True">
                                <AppBarButton Icon="Edit" Label="Edit" 
                                              Visibility="{x:Bind ViewModel.Options.IsReadonly, Mode=OneWay}"
                                              Command="{x:Bind ViewModel.Options.BeginEditCommand, Mode=OneWay}" />

                                <AppBarButton Icon="Save" Label="Save" 
                                              AllowFocusOnInteraction="True"
                                              Visibility="{x:Bind ViewModel.Options.IsEditing, Mode=OneWay}"
                                              Command="{x:Bind ViewModel.SaveOptionsCommand}" />

                                <AppBarButton Icon="Cancel" Label="Cancel" 
                                              Visibility="{x:Bind ViewModel.Options.IsEditing, Mode=OneWay}"
                                              Command="{x:Bind ViewModel.Options.CancelEditCommand, Mode=OneWay}" />

                            </CommandBar>
                        </Grid>

                        <!-- READONLY MODE -->
                        <StackPanel Visibility="{x:Bind ViewModel.Options.IsReadonly, Mode=OneWay}" Spacing="16">

                            <ItemsControl ItemsSource="{x:Bind ViewModel.Options.Options, Mode=OneWay}">

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="12" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:EditProductOptionViewModel">
                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{x:Bind Name, Mode=OneWay}" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                       VerticalAlignment="Top" 
                                                       Margin="0,6,0,0"/>

                                            <ItemsControl Grid.Column="1" ItemsSource="{x:Bind Values, Mode=OneWay}">

                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <labs:WrapPanel Orientation="Horizontal" 
                                                                        HorizontalSpacing="8" 
                                                                        VerticalSpacing="8" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                CornerRadius="14"
                                                                Padding="12,4">
                                                            <TextBlock Text="{x:Bind}" 
                                                                       FontFamily="Consolas" 
                                                                       FontSize="12"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>

                                            </ItemsControl>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="No options defined yet. Click Edit to add options like Size or Color."
                                       FontStyle="Italic"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       Visibility="{x:Bind ViewModel.Options.Options, Mode=OneWay, Converter={StaticResource EmptyListToVisibiltyConverter}}" />

                        </StackPanel>

                        <!-- EDIT MODE -->
                        <StackPanel Visibility="{x:Bind ViewModel.Options.IsEditing, Mode=OneWay}" Spacing="16">
                            <Grid ColumnSpacing="12" 
                                  Background="{ThemeResource LayerFillColorAltBrush}" 
                                  Padding="12" 
                                  CornerRadius="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Header="New Option Name"
                                         PlaceholderText="e.g., Material"
                                         Text="{x:Bind ViewModel.Options.DraftOptionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <StackPanel Grid.Column="1">
                                    <labs:TokenizingTextBox Header="Values (Type and press Enter)"
                                                            ItemsSource="{x:Bind ViewModel.Options.DraftOptionValues, Mode=OneWay}"
                                                            TokenDelimiter="&#13;"
                                                            PlaceholderText="e.g., Cotton, Wool"/>
                                </StackPanel>

                                <Button Grid.Column="2" 
                                        Content="Add Option" 
                                        VerticalAlignment="Bottom"
                                        Style="{StaticResource DefaultButtonStyle}"
                                        Command="{x:Bind ViewModel.Options.AddOptionCommand, Mode=OneWay}"/>
                            </Grid>

                            <MenuFlyoutSeparator />

                            <TextBlock Text="Current Options" Style="{StaticResource BodyStrongTextBlockStyle}" />

                            <ItemsControl ItemsSource="{x:Bind ViewModel.Options.Options, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="12" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:EditProductOptionViewModel">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBox Grid.Column="0" 
                                                     Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                     VerticalAlignment="Center" Margin="0,8,0,0"/>

                                            <labs:TokenizingTextBox Grid.Column="1"
                                                                    ItemsSource="{x:Bind Values, Mode=OneWay}"
                                                                    TokenDelimiter="&#13;"
                                                                    VerticalAlignment="Center"/>

                                            <Button Grid.Column="2" 
                                                    Content="&#xE74D;" 
                                                    FontFamily="Segoe MDL2 Assets" 
                                                    Style="{StaticResource SubtleButtonStyle}" 
                                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}" 
                                                    ToolTipService.ToolTip="Remove Entire Option"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding ElementName=RootPage, Path=ViewModel.Options.RemoveOptionCommand}"
                                                    CommandParameter="{x:Bind}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>

                    <!-- Variants -->
                    <StackPanel Style="{StaticResource CardStackStyle}" Visibility="{x:Bind ViewModel.HasVariants, Mode=OneWay}">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Variant Logistics" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Manage individual pricing, weight, and stock levels for each variation." 
                                           Style="{StaticResource CaptionTextBlockStyle}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <CommandBar Grid.Column="1" 
                                        Background="Transparent" 
                                        IsOpen="False" 
                                        DefaultLabelPosition="Right" 
                                        IsSticky="True">

                                <AppBarButton Icon="Edit" Label="Edit" 
                                              Visibility="{x:Bind ViewModel.Variants.IsReadonly, Mode=OneWay}"
                                              Command="{x:Bind ViewModel.Variants.BeginEditCommand, Mode=OneWay}" />

                                <AppBarButton Icon="Save" Label="Save" 
                                              AllowFocusOnInteraction="True"
                                              Visibility="{x:Bind ViewModel.Variants.IsEditing, Mode=OneWay}"
                                              Command="{x:Bind ViewModel.SaveVariantsCommand}" />

                                <AppBarButton Icon="Cancel" Label="Cancel" 
                                              Visibility="{x:Bind ViewModel.Variants.IsEditing, Mode=OneWay}"
                                              Command="{x:Bind ViewModel.Variants.CancelEditCommand, Mode=OneWay}" />
                            </CommandBar>
                        </Grid>

                        <toolkit:DataGrid ItemsSource="{x:Bind ViewModel.Variants.Variants, Mode=OneWay}"
                                          IsReadOnly="{x:Bind ViewModel.Variants.IsReadonly, Mode=OneWay}"
                                          AutoGenerateColumns="False"
                                          RowBackground="Transparent"
                                          AlternatingRowBackground="{ThemeResource LayerFillColorDefaultBrush}"
                                          MinHeight="200"
                                          MaxHeight="500"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">

                            <toolkit:DataGrid.Columns>
                                <toolkit:DataGridTextColumn Header="Variant" Binding="{Binding DisplayAttributes}" IsReadOnly="True" MinWidth="150" Width="Auto" />
                                <toolkit:DataGridTextColumn Header="SKU" Binding="{Binding Sku, Mode=TwoWay}" MinWidth="150" Width="*" />

                                <toolkit:DataGridTextColumn IsReadOnly="True" Binding="{Binding PriceCurrency, Mode=OneWay}" MinWidth="50" Width="Auto" ElementStyle="{StaticResource LeftAlignedCellStyle}"/>
                                <toolkit:DataGridTextColumn Header="Price" Binding="{Binding PriceAmount, Mode=TwoWay}" MinWidth="100" Width="Auto" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                                <toolkit:DataGridTextColumn IsReadOnly="True" Binding="{Binding CostCurrency, Mode=OneWay}" MinWidth="50" Width="Auto" ElementStyle="{StaticResource LeftAlignedCellStyle}"/>
                                <toolkit:DataGridTextColumn Header="Cost" Binding="{Binding CostAmount, Mode=TwoWay}" MinWidth="100" Width="Auto" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                                <toolkit:DataGridTextColumn Header="Weight" Binding="{Binding WeightAmount, Mode=TwoWay}" MinWidth="100" Width="Auto" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                                <toolkit:DataGridTextColumn IsReadOnly="True" Binding="{Binding WeightUnit, Mode=OneWay}" MinWidth="50" Width="Auto" ElementStyle="{StaticResource LeftAlignedCellStyle}"/>
                                <toolkit:DataGridTextColumn Header="Stock" Binding="{Binding StockOnHand, Mode=TwoWay}" MinWidth="100" Width="Auto" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                            </toolkit:DataGrid.Columns>
                        </toolkit:DataGrid>

                        <TextBlock Text="No variants defined yet. Add options and save to generate variants."
                                   FontStyle="Italic"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Visibility="{x:Bind ViewModel.Variants.Variants, Mode=OneWay, Converter={StaticResource EmptyListToVisibiltyConverter}}" />

                    </StackPanel>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
