<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Dashboard.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Dashboard"
    xmlns:controls="using:Onyx.Oms.Client.Desktop.Shared.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Custom GridView Item Container Style mirroring the Catalog cards -->
        <Style x:Key="DashboardGridViewItemStyle" TargetType="GridViewItem">
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewItem">
                        <ListViewItemPresenter
                            ContentMargin="0"
                            Padding="0"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            CornerRadius="8"
                            PointerOverBackground="{ThemeResource ControlFillColorSecondaryBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <AcrylicBrush x:Key="GlassCardAcrylicBrush"
                  TintColor="{ThemeResource SystemAltHighColor}"
                  TintOpacity="0.4"
                  FallbackColor="{ThemeResource SolidBackgroundFillColorBase}" />

        <Style x:Key="GlassQuickActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GlassCardAcrylicBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="BackgroundBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}" />

                            <Border x:Name="DisabledOverlay"
                            Background="{ThemeResource ControlFillColorDisabledBrush}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Opacity="0" />

                            <Border x:Name="HighlightOverlay"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Opacity="0" />

                            <ContentPresenter x:Name="ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />

                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HighlightOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.7" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>

                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HighlightOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.3" Duration="0:0:0.05" />
                                        </Storyboard>
                                    </VisualState>

                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.35" Duration="0" />

                                            <DoubleAnimation Storyboard.TargetName="DisabledOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.5" Duration="0" />

                                            <DoubleAnimation Storyboard.TargetName="BackgroundBorder"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.8" Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Hero Header -->
                <RowDefinition Height="Auto"/> <!-- Quick Actions -->
                <RowDefinition Height="Auto"/> <!-- SelectorBar -->
                <RowDefinition Height="Auto"/>    <!-- Content Grid -->
                <RowDefinition Height="*"/>    <!-- Content Grid -->
            </Grid.RowDefinitions>

            <!-- 1. Hero Header -->
            <Grid Grid.Row="0" Height="280">
                <controls:OpacityMaskView Height="280" VerticalAlignment="Stretch">
                    <controls:OpacityMaskView.OpacityMask>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                    <GradientStop Color="#00000000" Offset="0.0" />
                                    <GradientStop Color="{ThemeResource SolidBackgroundFillColorBase}" Offset="0.1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </controls:OpacityMaskView.OpacityMask>
                    
                    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                        <Image Source="ms-appx:///Assets/hero_bg.jpg" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </controls:OpacityMaskView>

                <!-- Greeting Content -->
                <StackPanel VerticalAlignment="Bottom" Margin="40,0,0,100">
                    <TextBlock Text="Welcome," Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.UserName, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" Foreground="{ThemeResource AccentTextFillColorTertiaryBrush}" FontWeight="Bold" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>

            <!-- 2. Quick Actions -->
            <Grid Grid.Row="1" Margin="40,-60,40,24">
                <ScrollViewer x:Name="QuickActionsScrollViewer" 
                              HorizontalScrollBarVisibility="Hidden" 
                              VerticalScrollBarVisibility="Disabled" 
                              ViewChanged="QuickActionsScrollViewer_ViewChanged"
                              PointerWheelChanged="ScrollViewer_PointerWheelChanged">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.QuickActions, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16" Padding="0,0,40,0" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:DashboardQuickAction">
                                <Button Style="{StaticResource GlassQuickActionButtonStyle}" 
                                        Command="{x:Bind Command}"
                                        IsEnabled="{x:Bind IsEnabled}" 
                                        Visibility="{x:Bind IsVisible}">

                                    <Grid Width="240" Height="120" Padding="16">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <FontIcon Grid.Row="0" 
                                                  FontFamily="Segoe Fluent Icons" 
                                                  Glyph="{x:Bind IconGlyph}" 
                                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" 
                                                  FontSize="32" 
                                                  HorizontalAlignment="Left" 
                                                  VerticalAlignment="Top"/>

                                        <TextBlock Grid.Row="1" 
                                                   Text="{x:Bind Title}" 
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" 
                                                   Margin="0,12,0,4"/>

                                        <TextBlock Grid.Row="2" 
                                                   Text="{x:Bind Description}" 
                                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Scroll Buttons -->
                <Button x:Name="ScrollLeftButton" 
                        Click="ScrollLeft_Click"
                        Visibility="Collapsed"
                        HorizontalAlignment="Left" VerticalAlignment="Center" 
                        Width="40" Height="40" CornerRadius="20"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        Margin="-20,0,0,0" Padding="0">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE76B;" FontSize="14"/>
                </Button>
                
                <Button x:Name="ScrollRightButton" 
                        Click="ScrollRight_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Width="40" Height="40" CornerRadius="20"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        Margin="0,0,-20,0" Padding="0">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE76C;" FontSize="14"/>
                </Button>
            </Grid>

            <!-- 3. Filter / Selector Bar -->
            <SelectorBar Grid.Row="2" Margin="40,0,40,16" SelectionChanged="SelectorBar_SelectionChanged">
                <SelectorBarItem Text="Recent Orders" Tag="RecentOrders" IsSelected="True" />
                <SelectorBarItem Text="Pending Tasks" Tag="PendingTasks" />
            </SelectorBar>

            <!-- 4. Content Cards Grid -->
            <Grid Grid.Row="3" Margin="40,0,40,40">
                <ScrollViewer x:Name="DashboardItemsScrollViewer" 
                              HorizontalScrollBarVisibility="Hidden" 
                              VerticalScrollBarVisibility="Disabled" 
                              ViewChanged="DashboardItemsScrollViewer_ViewChanged"
                              PointerWheelChanged="ScrollViewer_PointerWheelChanged">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.DashboardItems, Mode=OneWay}" Margin="0,0,40,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:DashboardItem">
                                <Button Padding="0" BorderThickness="0" CornerRadius="8" Background="{ThemeResource ControlFillColorDefaultBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                                    <Grid Width="300" MinHeight="96" Padding="16"
                                          Background="Transparent"
                                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                          BorderThickness="1"
                                          CornerRadius="8">
                                        
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Left: Icon representing Item Type -->
                                        <FontIcon Grid.Column="0" 
                                                  FontFamily="ms-appx:///Assets/Fonts/fa-solid-900.ttf#Font Awesome 6 Free" 
                                                  Glyph="{x:Bind IconGlyph}" 
                                                  Foreground="{ThemeResource SystemAccentColor}"
                                                  FontSize="28"
                                                  VerticalAlignment="Center" 
                                                  Margin="0,0,16,0" />

                                        <!-- Right: Text Stack -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                            <TextBlock Text="{x:Bind Title}" Style="{StaticResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Left" />
                                            <TextBlock Text="{x:Bind Subtitle}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="WordEllipsis" HorizontalAlignment="Left"/>
                                            
                                            <Border Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left" Margin="0,4,0,0">
                                                <TextBlock Text="{x:Bind StatusDisplay}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" FontSize="11" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Scroll Buttons for Content Cards -->
                <Button x:Name="DashboardItemsScrollLeftButton" 
                        Click="DashboardItemsScrollLeft_Click"
                        Visibility="Collapsed"
                        HorizontalAlignment="Left" VerticalAlignment="Center" 
                        Width="40" Height="40" CornerRadius="20"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        Margin="-20,0,0,0" Padding="0">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE76B;" FontSize="14"/>
                </Button>
                
                <Button x:Name="DashboardItemsScrollRightButton" 
                        Click="DashboardItemsScrollRight_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Width="40" Height="40" CornerRadius="20"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        Margin="0,0,-20,0" Padding="0">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE76C;" FontSize="14"/>
                </Button>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
