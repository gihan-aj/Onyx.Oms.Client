<Page
    x:Name="RootPage"
    x:Class="Onyx.Oms.Client.Desktop.Features.Products.ProductDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Products"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Sticky Header with Back Button -->
        <Grid Grid.Row="0" Padding="24,16" BorderThickness="0,0,0,1" 
              BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" 
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" Command="{x:Bind ViewModel.GoBackCommand}" Style="{StaticResource SubtleButtonStyle}" Margin="0,0,16,0">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>
            
            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Product.Name, Mode=OneWay}" 
                       Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Grid>

        <ProgressBar Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" 
                     IsIndeterminate="True" 
                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" 
                     Canvas.ZIndex="100" />

        <ScrollViewer Grid.Row="1" Padding="32" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1400" HorizontalAlignment="Center" Spacing="48">
                <!-- Top Section: Image Gallery & General Information -->
                <Grid ColumnSpacing="48">
                    <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="500" /> <!-- Left: Image Gallery -->
                    <ColumnDefinition Width="*" />   <!-- Right: Product Information -->
                </Grid.ColumnDefinitions>

                <!-- Left Column: Image Gallery -->
                <StackPanel Grid.Column="0" Spacing="16">
                    <Border CornerRadius="8" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource LayerFillColorAltBrush}" Height="500" Width="500">
                        <FlipView x:Name="ImageGallery" 
                                  ItemsSource="{x:Bind ViewModel.DisplayImages, Mode=OneWay}"
                                  SelectedIndex="{x:Bind ViewModel.SelectedImageIndex, Mode=TwoWay}">
                            <FlipView.ItemTemplate>
                                <DataTemplate x:DataType="local:ProductImageDisplayModel">
                                    <Grid Background="Transparent" Padding="16">
                                         <Image Source="{x:Bind ImageSource, Mode=OneWay}" Stretch="Uniform" />
                                    </Grid>
                                </DataTemplate>
                            </FlipView.ItemTemplate>
                        </FlipView>
                    </Border>
                    <PipsPager NumberOfPages="{x:Bind ViewModel.DisplayImages.Count, Mode=OneWay}"
                               SelectedPageIndex="{x:Bind ViewModel.SelectedImageIndex, Mode=TwoWay}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Right Column: Product Details -->
                <StackPanel Grid.Column="1" Spacing="24">
                    
                    <!-- Header -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="{x:Bind ViewModel.Product.CategoryPath, Mode=OneWay}" 
                                   Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.Product.Name, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold" TextWrapping="Wrap" />
                        <TextBlock Text="{x:Bind ViewModel.Product.BaseSku, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>

                    <!-- Pricing & Stock -->
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Price" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.Product.BasePriceCurrency, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Bottom" Margin="0,0,5,5"/>
                                <TextBlock Text="{x:Bind ViewModel.Product.BasePriceAmount, Mode=OneWay}" Style="{StaticResource TitleLargeTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Availability" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                            <Border Style="{StaticResource StatusBadgeStyle}" Background="{x:Bind ViewModel.Product.StockOnHand, Mode=OneWay, Converter={StaticResource StockBackgroundConverter}}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6" Padding="4,2">
                                     <FontIcon Glyph="{x:Bind ViewModel.Product.StockOnHand, Mode=OneWay, Converter={StaticResource StockIconConverter}}" FontSize="12" Foreground="{x:Bind ViewModel.Product.StockOnHand, Mode=OneWay, Converter={StaticResource StockForegroundConverter}}"/>
                                     <TextBlock Style="{StaticResource StatusBadgeTextStyle}" Foreground="{x:Bind ViewModel.Product.StockOnHand, Mode=OneWay, Converter={StaticResource StockForegroundConverter}}">
                                          <Run Text="{x:Bind ViewModel.Product.StockOnHand, Mode=OneWay}" />
                                          <Run Text=" In Stock" />
                                     </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <MenuFlyoutSeparator Margin="0,8"/>

                    <!-- Description -->
                    <StackPanel Visibility="{x:Bind ViewModel.HasDescription, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                         <TextBlock Text="Description" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />
                         <TextBlock Text="{x:Bind ViewModel.Product.Description, Mode=OneWay}" 
                                    Style="{StaticResource BodyTextBlockStyle}" 
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Options / Variations -->
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Options, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:ProductOptionDisplayModel">
                                 <StackPanel Margin="0,0,0,16">
                                      <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,12" />
                                      <ItemsControl ItemsSource="{x:Bind Values}">
                                           <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                     <VariableSizedWrapGrid Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                           </ItemsControl.ItemsPanel>
                                           <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="local:ProductOptionValueDisplayModel">
                                                     <ToggleButton Content="{x:Bind Value}" 
                                                                   IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                                   Command="{Binding ElementName=RootPage, Path=ViewModel.OptionSelectedCommand}"
                                                                   CommandParameter="{x:Bind}"
                                                                   CornerRadius="18" Padding="16,4"
                                                                   ToolTipService.ToolTip="{x:Bind Value}"
                                                                   MinHeight="36" MinWidth="60" Margin="4"/>
                                                </DataTemplate>
                                           </ItemsControl.ItemTemplate>
                                      </ItemsControl>
                                 </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <MenuFlyoutSeparator Margin="0,8"/>

                    <!-- Specifications -->
                    <StackPanel Visibility="{x:Bind ViewModel.HasSpecifications, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Specifications" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,16" />
                        <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Specifications, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:ProductSpecificationModel">
                                        <Grid Padding="16,12" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Label}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Value}" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <!-- Logistics -->
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Logistics &amp; Inventory" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,16" />
                        <Grid ColumnSpacing="48">
                             <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="Auto" />
                                  <ColumnDefinition Width="Auto" />
                             </Grid.ColumnDefinitions>
                             
                             <StackPanel Grid.Column="0" Spacing="4">
                                  <TextBlock Text="Base Weight" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                  <TextBlock Style="{StaticResource BodyTextBlockStyle}">
                                       <Run Text="{x:Bind ViewModel.Product.BaseWeightAmount, Mode=OneWay}" />
                                       <Run Text="{x:Bind ViewModel.Product.BaseWeightCurrency, Mode=OneWay}" />
                                  </TextBlock>
                             </StackPanel>
                             
                              <StackPanel Grid.Column="1" Spacing="4">
                                  <TextBlock Text="Reserved Quantity" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                  <TextBlock Text="{x:Bind ViewModel.Product.ReservedQuantity, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}" />
                             </StackPanel>
                        </Grid>
                    </StackPanel>

                </StackPanel>
                </Grid>

                <!-- Variants Grid -->
                <StackPanel Visibility="{x:Bind ViewModel.HasVariants, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,32">
                    <TextBlock Text="Product Variants" Style="{StaticResource TitleTextBlockStyle}" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <toolkit:DataGrid 
                            ItemsSource="{x:Bind ViewModel.Variants, Mode=OneWay}"
                            AutoGenerateColumns="False"
                            GridLinesVisibility="Horizontal"
                            HeadersVisibility="Column"
                            CanUserSortColumns="False"
                            CanUserReorderColumns="False"
                            IsReadOnly="True"
                            RowHeight="48">
                            <toolkit:DataGrid.Columns>
                                <toolkit:DataGridTextColumn Header="SKU" Binding="{Binding Dto.Sku}" Width="200" />
                                <toolkit:DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                                
                                <toolkit:DataGridTemplateColumn Header="Price" HeaderStyle="{StaticResource RightAlignedHeaderStyle}" Width="120">
                                    <toolkit:DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="local:ProductVariantDisplayModel">
                                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="{x:Bind Dto.PriceCurrency}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                                                <TextBlock Text="{x:Bind Dto.PriceAmount}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </toolkit:DataGridTemplateColumn.CellTemplate>
                                </toolkit:DataGridTemplateColumn>
                                <toolkit:DataGridTextColumn Header="On Hand" Binding="{Binding Dto.StockOnHand}" Width="120"
                                                            HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>
                                <toolkit:DataGridTextColumn Header="Reserved" Binding="{Binding Dto.ReservedQuantity}" Width="120" 
                                                            HeaderStyle="{StaticResource RightAlignedHeaderStyle}" ElementStyle="{StaticResource RightAlignedCellStyle}"/>

                                <toolkit:DataGridTemplateColumn Header="Available" Width="120" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                                    <toolkit:DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="local:ProductVariantDisplayModel">
                                            <Border Style="{StaticResource StatusBadgeStyle}" Background="{x:Bind AvailableQuantity, Converter={StaticResource StockBackgroundConverter}}" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="8,4">
                                                <TextBlock Foreground="{x:Bind AvailableQuantity, Converter={StaticResource StockForegroundConverter}}"
                                                           Text="{x:Bind AvailableQuantity}" FontWeight="SemiBold" Style="{StaticResource StatusBadgeTextStyle}" />
                                            </Border>
                                        </DataTemplate>
                                    </toolkit:DataGridTemplateColumn.CellTemplate>
                                </toolkit:DataGridTemplateColumn>
                            </toolkit:DataGrid.Columns>
                        </toolkit:DataGrid>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
