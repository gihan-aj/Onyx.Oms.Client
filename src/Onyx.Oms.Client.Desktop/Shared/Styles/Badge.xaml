<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters">

    <!-- Status Color Converters -->
    <converters:BoolToObjectConverter x:Key="StatusBackgroundConverter" TrueValue="{ThemeResource SystemFillColorSuccessBrush}" FalseValue="{ThemeResource SystemFillColorCriticalBrush}" />
    <converters:BoolToObjectConverter x:Key="StatusForegroundConverter" TrueValue="{ThemeResource TextOnAccentFillColorPrimaryBrush}" FalseValue="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
    <converters:BoolToObjectConverter x:Key="StatusTextConverter" TrueValue="Active" FalseValue="Inactive" />

    <!-- Badge Style -->
    <Style x:Key="StatusBadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
</ResourceDictionary>
