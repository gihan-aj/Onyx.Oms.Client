<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Onyx.Oms.Client.Desktop.Features.Orders.FailDeliveryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Fail Delivery"
    PrimaryButtonText="Mark as Failed"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    Style="{StaticResource DefaultContentDialogStyle}">

    <StackPanel Spacing="16" Width="400">
        <TextBlock Text="Are you sure you want to mark this delivery as failed?" TextWrapping="Wrap" />

        <CheckBox Content="Items returned to sender" 
                  IsChecked="{x:Bind IsReturnedToSender, Mode=TwoWay}" />

        <TextBox Header="Reason (Optional)" 
                 Text="{x:Bind Reason, Mode=TwoWay}"
                 PlaceholderText="e.g. Customer unavailable, incorrect address"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 MinHeight="80" />
    </StackPanel>
</ContentDialog>
