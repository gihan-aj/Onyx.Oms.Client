<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.FulfillmentTasks.List.FulfillmentTasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.FulfillmentTasks.List"
    xmlns:parent="using:Onyx.Oms.Client.Desktop.Features.FulfillmentTasks"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />

        <local:FulfillmentTaskStatusToBackgroundConverter x:Key="TaskStatusBgConverter" />
        <local:FulfillmentTaskStatusToForegroundConverter x:Key="TaskStatusFgConverter" />

        <local:FulfillmentTaskPriorityToBackgroundConverter x:Key="TaskPriorityBgConverter" />
        <local:FulfillmentTaskPriorityToForegroundConverter x:Key="TaskPriorityFgConverter" />

        <CollectionViewSource x:Name="GroupedTasksSource" 
                              IsSourceGrouped="True" 
                              Source="{x:Bind ViewModel.GroupedTasks, Mode=OneWay}" />

        <Style x:Key="ExpandCollapseToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Background="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ArrowIcon" 
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" 
                                                     To="90" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ArrowIcon" 
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" 
                                                     To="0" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <FontIcon x:Name="ArrowIcon" Glyph="&#xE76C;" FontSize="12" 
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                              RenderTransformOrigin="0.5,0.5">
                                <FontIcon.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </FontIcon.RenderTransform>
                            </FontIcon>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="16,12" 
              Background="{ThemeResource LayerFillColorDefaultBrush}" 
              ColumnSpacing="8" RowSpacing="12">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" 
                       Text="Fulfillment Tasks" 
                       Style="{StaticResource SubtitleTextBlockStyle}" 
                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0"/>

            <AutoSuggestBox Grid.Row="0" Grid.Column="1" 
                            PlaceholderText="Search by product, order number or purchase order..."
                            QueryIcon="Find"
                            Width="320"
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QuerySubmitted="OnQuerySubmitted" />

            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.RefreshCommand}" Style="{StaticResource SubtleButtonStyle}" ToolTipService.ToolTip="Refresh Data">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                </Button>

                <AppBarSeparator />

                <Button Command="{x:Bind ViewModel.NewTaskCommand}" Style="{StaticResource AccentButtonStyle}"
                        Visibility="{x:Bind ViewModel.CanCreateTasks, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="New Fulfillment Task" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="16">
                <StackPanel>
                    <TextBlock Text="Task Type" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{x:Bind ViewModel.TypeOptions}" SelectedItem="{x:Bind ViewModel.SelectedType, Mode=TwoWay}" PlaceholderText="Select Task Type" Width="140"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Priority" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{x:Bind ViewModel.PriorityOptions}" SelectedItem="{x:Bind ViewModel.SelectedPriority, Mode=TwoWay}" PlaceholderText="Select Priority" Width="140"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Created After" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <CalendarDatePicker Date="{x:Bind ViewModel.CreatedAfterFilter, Mode=TwoWay}" PlaceholderText="Created After" Width="160"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text=" " Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <CheckBox Content="Show All Statuses" IsChecked="{x:Bind ViewModel.ShowAllStatus, Mode=TwoWay}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text=" " Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <Button Content="Clear Filters" Style="{StaticResource SubtleButtonStyle}"
                        Command="{x:Bind ViewModel.ClearFiltersCommand}"/>
                </StackPanel>
            </StackPanel>

        </Grid>

        <ProgressBar Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
             IsIndeterminate="True" Canvas.ZIndex="100"
             Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <Grid Grid.Row="1" x:Name="TableContainer">

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Enabled"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Disabled">

                <toolkit:DataGrid x:Name="TasksDataGrid"
                                  Width="{Binding ActualWidth, ElementName=TableContainer}"
                                  MinWidth="1020"
                                  ItemsSource="{x:Bind GroupedTasksSource.View, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  CanUserSortColumns="True"
                                  Sorting="OnDataGridSorting"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Hidden"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{ThemeResource LayerFillColorDefaultBrush}">

                    <toolkit:DataGrid.RowGroupHeaderStyles>
                        <Style TargetType="toolkit:DataGridRowGroupHeader">
                            <Setter Property="Background" Value="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}" />
                            <Setter Property="Height" Value="48" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="toolkit:DataGridRowGroupHeader">
                                        <Grid Padding="8,0" Background="{TemplateBinding Background}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <ToggleButton Grid.Column="0" 
                                                          x:Name="ExpanderButton" 
                                                          Style="{StaticResource ExpandCollapseToggleStyle}" />

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="8">
                                                <FontIcon Glyph="&#xE768;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                                <TextBlock Text="{Binding Group.ProductName}" Style="{StaticResource BodyStrongTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <TextBlock Text="|" Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Group.Sku}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                                <!-- Variant Attributes Chips -->
                                                <ItemsControl ItemsSource="{Binding Group.VariantAttributes}" VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="4" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="parent:VariantAttributeDto">
                                                            <Border Background="{ThemeResource LayerFillColorAltBrush}" 
                                                                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" 
                                                                    BorderThickness="1" CornerRadius="4" Padding="6,2">
                                                                <TextBlock Text="{x:Bind Value}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="8">

                                                <TextBlock Text="Required:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Group.TotalRequested}" FontWeight="Bold" Foreground="{ThemeResource SystemFillColorCautionBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="|" Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="Completed:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Group.TotalCompleted}" FontWeight="Bold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" VerticalAlignment="Center"/>

                                                <Button Content="Complete Batch" Style="{StaticResource AccentButtonStyle}" Height="32"/>

                                            </StackPanel>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </toolkit:DataGrid.RowGroupHeaderStyles>

                    <toolkit:DataGrid.RowStyle>
                        <Style TargetType="toolkit:DataGridRow">
                            <Setter Property="ContextFlyout">
                                <Setter.Value>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="View Details" Icon="ContactInfo" Click="OnViewClick" />
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem Text="Start Work" Icon="Play" 
                                                        Click="OnStartWorkClick"
                                                        Visibility="{Binding IsProductionPending, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <MenuFlyoutItem Text="Issue PO" Icon="Send" 
                                                        Click="OnIssuePoClick"
                                                        Visibility="{Binding IsProcurementPending, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <MenuFlyoutItem Text="Mark Ready" Icon="Accept" 
                                                        Click="OnMarkReadyClick"
                                                        Visibility="{Binding IsInProgress, Converter={StaticResource BoolToVisibilityConverter}}" />

                                        <MenuFlyoutItem Text="Edit" Icon="Edit" Click="OnEditClick" IsEnabled="{Binding CanEdit}" />

                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem Text="Cancel Task" Icon="Cancel" Foreground="Red" 
                                                        Click="OnCancelTaskClick"
                                                        IsEnabled="{Binding CanBeCancelled}" />
                                    </MenuFlyout>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </toolkit:DataGrid.RowStyle>

                    <toolkit:DataGrid.Columns>

                        <toolkit:DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="120"
                                                    HeaderStyle="{StaticResource LeftAlignedHeaderStyle}"
                                                    ElementStyle="{StaticResource LeftAlignedCellStyle}"
                                                    FontWeight="SemiBold" />

                        <toolkit:DataGridTextColumn Header="Order" Binding="{Binding OrderNumber}" MinWidth="140" Width="*"
                                                    HeaderStyle="{StaticResource LeftAlignedHeaderStyle}"
                                                    ElementStyle="{StaticResource LeftAlignedCellStyle}" />

                        <toolkit:DataGridTemplateColumn Header="Progress" Width="180" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}">
                            <toolkit:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="local:FulfillmentTaskGridItem">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="12,0,0,0">
                                        <ProgressBar Value="{x:Bind CompletedQuantity}" Maximum="{x:Bind RequestedQuantity}" MinWidth="60" Width="Auto"
                                                     Foreground="{ThemeResource SystemFillColorSuccessBrush}" 
                                                     VerticalAlignment="Center" />
                                        <TextBlock VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}">
                                            <Run Text="{x:Bind CompletedQuantity}"/>
                                            <Run Text="/"/>
                                            <Run Text="{x:Bind RequestedQuantity}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </TextBlock>
                                        <TextBlock Text="{x:Bind ScrappedQuantity}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" 
                                                   VerticalAlignment="Center" Margin="4,0,0,0" ToolTipService.ToolTip="Scrapped Quantity"
                                                   Visibility="{x:Bind HasScrapped, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   Style="{StaticResource CaptionTextBlockStyle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </toolkit:DataGridTemplateColumn.CellTemplate>
                        </toolkit:DataGridTemplateColumn>

                        <toolkit:DataGridTextColumn Header="Expected Date" Binding="{Binding ExpectedCompletionDateDisplay}" Width="140"
                                                    HeaderStyle="{StaticResource LeftAlignedHeaderStyle}"
                                                    ElementStyle="{StaticResource LeftAlignedCellStyle}" />

                        <toolkit:DataGridTemplateColumn Header="Priority" Width="120" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                            <toolkit:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="local:FulfillmentTaskGridItem">
                                    <Border Style="{StaticResource StatusBadgeStyle}" 
                                            Background="{x:Bind Priority, Converter={StaticResource TaskPriorityBgConverter}}"
                                            HorizontalAlignment="Center" Margin="12,0,0,0">
                                        <TextBlock Text="{x:Bind Priority}" Style="{StaticResource StatusBadgeTextStyle}" 
                                                   Foreground="{x:Bind Priority, Converter={StaticResource TaskPriorityFgConverter}}" />
                                    </Border>
                                </DataTemplate>
                            </toolkit:DataGridTemplateColumn.CellTemplate>
                        </toolkit:DataGridTemplateColumn>

                        <toolkit:DataGridTemplateColumn Header="Status" Width="120" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                            <toolkit:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="local:FulfillmentTaskGridItem">
                                    <Border Style="{StaticResource StatusBadgeStyle}" 
                                            Background="{x:Bind Status, Converter={StaticResource TaskStatusBgConverter}}"
                                            HorizontalAlignment="Center" Margin="12,0,0,0">
                                        <TextBlock Text="{x:Bind Status}" Style="{StaticResource StatusBadgeTextStyle}" 
                                                   Foreground="{x:Bind Status, Converter={StaticResource TaskStatusFgConverter}}" />
                                    </Border>
                                </DataTemplate>
                            </toolkit:DataGridTemplateColumn.CellTemplate>
                        </toolkit:DataGridTemplateColumn>

                        <toolkit:DataGridTextColumn Header="Assignee" Binding="{Binding AssigneeName}" MinWidth="140" Width="*"
                                                    HeaderStyle="{StaticResource LeftAlignedHeaderStyle}"
                                                    ElementStyle="{StaticResource LeftAlignedCellStyle}" />

                        <toolkit:DataGridTemplateColumn Width="80" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                            <toolkit:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="local:FulfillmentTaskGridItem">
                                    <Button Style="{StaticResource SubtleButtonStyle}" 
                                            Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            ToolTipService.ToolTip="Actions" Tapped="OnActionButtonTapped">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE712;" />
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="View Details" Icon="ContactInfo" Click="OnViewClick" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="Start Work" Icon="Play" 
                                                                Click="OnStartWorkClick"
                                                                Visibility="{Binding IsProductionPending, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                <MenuFlyoutItem Text="Issue PO" Icon="Send" 
                                                                Click="OnIssuePoClick"
                                                                Visibility="{Binding IsProcurementPending, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                <MenuFlyoutItem Text="Mark Ready" Icon="Accept" 
                                                                Click="OnMarkReadyClick"
                                                                Visibility="{Binding IsInProgress, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                <MenuFlyoutItem Text="Edit" Icon="Edit" Click="OnEditClick" IsEnabled="{Binding CanEdit}" />

                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="Cancel Task" Icon="Cancel" Foreground="Red" 
                                                                Click="OnCancelTaskClick"
                                                                IsEnabled="{Binding CanBeCancelled}" />
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </DataTemplate>
                            </toolkit:DataGridTemplateColumn.CellTemplate>
                        </toolkit:DataGridTemplateColumn>

                    </toolkit:DataGrid.Columns>
                </toolkit:DataGrid>
            </ScrollViewer>

            <Grid Background="{ThemeResource LayerFillColorAltBrush}" Opacity="0.8" 
                  Visibility="{x:Bind ViewModel.IsListLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ProgressRing IsActive="True" Width="48" Height="48" />
            </Grid>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                        Visibility="{x:Bind ViewModel.HasNoData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <FontIcon Glyph="&#xF7EC;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="No Tasks found." Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                <Button Content="Clear Search" Command="{x:Bind ViewModel.RefreshCommand}" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Center"/>
            </StackPanel>

        </Grid>

        <Grid Grid.Row="2" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Rows per page:" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.PageSizes}" SelectedItem="{x:Bind ViewModel.PageSize, Mode=TwoWay}"
                          Style="{StaticResource DefaultComboBoxStyle}" MinWidth="80" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.PageSummary, Mode=OneWay}" 
                       Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.PreviousPageCommand}" IsEnabled="{x:Bind ViewModel.HasPreviousPage, Mode=OneWay}" ToolTipService.ToolTip="Previous Page">
                    <FontIcon Glyph="&#xE76B;" FontSize="12" />
                </Button>
                <Button Style="{StaticResource SubtleButtonStyle}" Command="{x:Bind ViewModel.NextPageCommand}" IsEnabled="{x:Bind ViewModel.HasNextPage, Mode=OneWay}" ToolTipService.ToolTip="Next Page">
                    <FontIcon Glyph="&#xE76C;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>

