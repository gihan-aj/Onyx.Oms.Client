<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Onyx.Oms.Client.Desktop.Features.FulfillmentTasks.List.IssuePoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.FulfillmentTasks.List"
    Title="Issue Purchase Order"
    PrimaryButtonText="Confirm Order"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    Style="{StaticResource DefaultContentDialogStyle}">

    <StackPanel Spacing="12" Width="420">

        <Border Background="{ThemeResource LayerFillColorAltBrush}" 
                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" 
                BorderThickness="0" 
                CornerRadius="8" 
                Padding="12">

            <StackPanel Spacing="12">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Product Details" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind Task.ProductName}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" />
                        <TextBlock Text="{x:Bind Task.Sku}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />

                        <ItemsControl ItemsSource="{x:Bind Task.VariantAttributes}" 
                                      Visibility="{x:Bind Task.ProductHasVariants}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="5"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" 
                                            BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,4,4">
                                        <TextBlock Text="{Binding Value}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Visibility="{x:Bind HasOrderNumber}">
                        <TextBlock Text="Order" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                        <TextBlock Text="{x:Bind Task.OrderNumber}" FontFamily="Consolas" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>

                <MenuFlyoutSeparator Margin="0,0"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Currently Ordered" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold">
                        <Run Text="{x:Bind Task.StartedQuantity}" />
                        <Run Text=" / " Foreground="{ThemeResource TextFillColorDisabledBrush}" />
                        <Run Text="{x:Bind Task.RequestedQuantity}" />
                    </TextBlock>
                </Grid>

                <ProgressBar Minimum="0" Maximum="{x:Bind Task.RequestedQuantity}" Value="{x:Bind Task.StartedQuantity}" />

            </StackPanel>
            
        </Border>

        <StackPanel Spacing="16">

            <TextBox Header="Purchase Order Number*" 
                     Text="{x:Bind PoNumber, Mode=TwoWay}" 
                     PlaceholderText="e.g. PO-2026-001" />

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.5*" />
                </Grid.ColumnDefinitions>

                <NumberBox Header="Order Qty*" 
                           Value="{x:Bind IssueQuantity, Mode=TwoWay}"
                           Minimum="1" 
                           Maximum="{x:Bind MaxAllowedQuantity}"
                           SpinButtonPlacementMode="Compact"
                           HorizontalAlignment="Stretch" />

                <NumberBox Grid.Column="1" 
                           Header="{x:Bind EstimatedCostHeader}" 
                           Value="{x:Bind CostAmount, Mode=TwoWay}"
                           Minimum="0" 
                           SpinButtonPlacementMode="Compact"
                           HorizontalAlignment="Stretch" />
            </Grid>

        </StackPanel>

    </StackPanel>
</ContentDialog>
