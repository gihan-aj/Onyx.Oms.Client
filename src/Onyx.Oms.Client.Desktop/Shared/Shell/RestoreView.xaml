<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Onyx.Oms.Client.Desktop.Shared.Shell.RestoreView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">
        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                CornerRadius="12" Padding="40" MinWidth="460"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <StackPanel Spacing="16">

                <TextBlock Text="Restore from Backup"
                           Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Select the .bak files for both databases. All existing data will be overwritten." />

                <!-- IdP file row -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Identity Provider Backup (OnyxIdP.bak)" Style="{StaticResource CaptionTextBlockStyle}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="IdpPathBox" IsReadOnly="True" PlaceholderText="No file selected..." />
                        <Button Grid.Column="1" Content="Browse…" Click="BrowseIdp_Click" />
                    </Grid>
                </StackPanel>

                <!-- OMS file row -->
                <StackPanel Spacing="4">
                    <TextBlock Text="OMS Backup (OnyxOms.bak)" Style="{StaticResource CaptionTextBlockStyle}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OmsPathBox" IsReadOnly="True" PlaceholderText="No file selected..." />
                        <Button Grid.Column="1" Content="Browse…" Click="BrowseOms_Click" />
                    </Grid>
                </StackPanel>

                <InfoBar x:Name="ErrorBar" IsOpen="False" Severity="Error" IsClosable="False" />

                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="Cancel_Click" />
                    <Button x:Name="RestoreBtn"
                            Content="Restore System"
                            Style="{StaticResource AccentButtonStyle}"
                            IsEnabled="False"
                            Click="Restore_Click" />
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
