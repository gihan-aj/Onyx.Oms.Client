<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Orders.Create.CreateOrderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Orders.Create"
    xmlns:parent="using:Onyx.Oms.Client.Desktop.Features.Orders"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="RootPage">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
        <converters:EmptyStringToObjectConverter x:Key="StringToVisibilityConverter" EmptyValue="Collapsed" NotEmptyValue="Visible" />
        <converters:BoolNegationConverter x:Key="InvertedBoolConverter" />
        <converters:EmptyCollectionToObjectConverter x:Key="InvertedCollectionToVisibilityConverter" EmptyValue="Visible" NotEmptyValue="Collapsed" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Command="{x:Bind ViewModel.CancelCommand}" Style="{StaticResource SubtleButtonStyle}" Margin="0,0,16,0">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.SaveCommand}" Style="{StaticResource AccentButtonStyle}" 
                IsEnabled="{x:Bind ViewModel.IsBusy, Converter={StaticResource InvertedBoolConverter}, Mode=OneWay}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" FontSize="14" />
                            <TextBlock Text="Create Order" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>

        <ProgressBar Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
             IsIndeterminate="True" Canvas.ZIndex="100"
             Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10000*" MaxWidth="1200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" Spacing="16">

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" MinWidth="350" />
                            <ColumnDefinition Width="2*" MinWidth="350" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Column -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="16">

                            <!-- Customer Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Customer Details" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="Select a return customer or add and select a new customer." 
                                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                   Margin="0,0,0,12" />
                                    </StackPanel>

                                    <CommandBar Grid.Column="1" 
                                                Background="Transparent" 
                                                IsOpen="False" 
                                                DefaultLabelPosition="Right" 
                                                IsSticky="True">
                                        <AppBarButton Icon="Add" Label="Add"
                                                      ToolTipService.ToolTip="Add a New Customer" 
                                                      Click="OnAddNewCustomerClick" />
                                        
                                        <AppBarButton Icon="Cancel" Label="Clear"
                                                      ToolTipService.ToolTip="Clear selected customer" 
                                                      Visibility="{x:Bind ViewModel.HasSelectedCustomer, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                      Command="{x:Bind ViewModel.ClearCustomerCommand}"/>

                                    </CommandBar>
                                </Grid>

                                <parent:CustomerPicker x:Name="CustomerPicker"
                                                       Width="Auto"
                                                       SelectedCustomer="{x:Bind ViewModel.SelectedCustomer, Mode=TwoWay}"
                                                       PlaceholderText="Selct a Customer..."/>

                                <!-- Customer Details Display -->
                                <StackPanel Visibility="{x:Bind ViewModel.HasSelectedCustomer, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="{ThemeResource LayerFillColorAltBrush}"
                                            Padding="16" CornerRadius="8" Margin="0,12,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <FontIcon Glyph="&#xE77B;" FontSize="32" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind ViewModel.SelectedCustomer.Name, Mode=OneWay, TargetNullValue='', FallbackValue=''}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{x:Bind ViewModel.SelectedCustomer.PrimaryPhone, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}, FallbackValue='Collapsed'}">
                                                    <FontIcon Glyph="&#xE717;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedCustomer.PrimaryPhone, Mode=OneWay, TargetNullValue='', FallbackValue=''}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                                
                                                <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{x:Bind ViewModel.SelectedCustomer.Email, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}, FallbackValue='Collapsed'}">
                                                    <FontIcon Glyph="&#xE715;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{x:Bind ViewModel.SelectedCustomer.Email, Mode=OneWay, TargetNullValue='', FallbackValue=''}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                            </StackPanel>

                            <!-- Products Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Items" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="Select products or product variants and required quantities." 
                                                   Style="{StaticResource CaptionTextBlockStyle}" 
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                    <CommandBar Grid.Column="1" 
                                                Background="Transparent" 
                                                IsOpen="False" 
                                                DefaultLabelPosition="Right" 
                                                IsSticky="True">
                                        <AppBarButton Icon="Add" Label="Add" 
                                                      ToolTipService.ToolTip="Select Product" 
                                                      Command="{x:Bind ViewModel.ShowProductPickerCommand}" />

                                    </CommandBar>
                                </Grid>

                                <ListView ItemsSource="{x:Bind ViewModel.OrderItems, Mode=OneWay}"
                                          SelectionMode="None"
                                          HorizontalAlignment="Stretch"
                                          ScrollViewer.VerticalScrollMode="Disabled">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Margin" Value="0,0,0,8" />
                                            <Setter Property="Padding" Value="0" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:CreateOrderLineItem">
                                            <Grid Background="{ThemeResource LayerFillColorAltBrush}"
                                                  CornerRadius="8"
                                                  BorderThickness="0"
                                                  BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                                  Padding="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="64" />
                                                    <ColumnDefinition Width="*" MinWidth="150" />
                                                    <ColumnDefinition Width="Auto" MinWidth="120" />
                                                    <ColumnDefinition Width="Auto" MinWidth="140" />
                                                    <ColumnDefinition Width="Auto" MinWidth="100" />
                                                    <ColumnDefinition Width="Auto" MinWidth="40" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Image -->
                                                <Grid Grid.Column="0" Width="56" Height="56" CornerRadius="4" 
                                                      Background="{ThemeResource LayerFillColorAltBrush}" BorderThickness="1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                                      VerticalAlignment="Center">
                                                    <FontIcon Glyph="&#xE8B9;" FontSize="16" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                    <Image Source="{x:Bind ImageSource, Mode=OneWay}" Stretch="UniformToFill" />
                                                </Grid>

                                                <!-- Product Details -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                                    <TextBlock Text="{x:Bind ProductName, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{x:Bind Sku, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>

                                                <!-- Unit Price -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0">
                                                    <TextBlock Text="Unit Price" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Style="{StaticResource BodyTextBlockStyle}">
                                                        <Run Text="{x:Bind BaseCurrency, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        <Run Text=" " />
                                                        <Run Text="{x:Bind UnitPrice, Mode=OneWay}" />
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Quantity & Availability -->
                                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="16,0,0,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <NumberBox Value="{x:Bind Quantity, Mode=TwoWay}" 
                                                                   Minimum="1" 
                                                                   SpinButtonPlacementMode="Inline" 
                                                                   Width="120" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                                        <ProgressBar Value="{x:Bind AvailableQuantity, Mode=OneWay}" 
                                                                     Maximum="{x:Bind Quantity, Mode=OneWay}" 
                                                                     Foreground="{x:Bind QuantityProgressBrush, Mode=OneWay}"
                                                                     Width="60" />
                                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                                                            <Run Text="{x:Bind AvailableQuantity, Mode=OneWay}"/>
                                                            <Run Text="/" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                            <Run Text="{x:Bind Quantity, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- Line Total -->
                                                <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="16,0,0,0">
                                                    <TextBlock Text="Total" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}">
                                                        <Run Text="{x:Bind BaseCurrency, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        <Run Text=" " />
                                                        <Run Text="{x:Bind LineTotal, Mode=OneWay}" />
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Remove Action -->
                                                <Button Grid.Column="5" 
                                                        Style="{StaticResource SubtleButtonStyle}" 
                                                        VerticalAlignment="Center" 
                                                        Margin="16,0,0,0"
                                                        ToolTipService.ToolTip="Remove Item"
                                                        Command="{Binding ElementName=RootPage, Path=ViewModel.RemoveLineItemCommand}"
                                                        CommandParameter="{Binding}">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="16" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                                </Button>

                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <!-- Empty State -->
                                <StackPanel Visibility="{x:Bind GetOrderItemsEmptyState(ViewModel.OrderItems.Count), Mode=OneWay}"
                                            VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Margin="0,32,0,32">
                                    <FontIcon Glyph="&#xE7B3;" FontSize="32" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Text="No items added yet" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>

                            </StackPanel>

                            <!-- Notes Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <StackPanel>
                                    <TextBlock Text="Notes" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Add notes relevant to the order (Chat messages)." 
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>

                                <TextBox 
                                         Text="{x:Bind ViewModel.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="100" Margin="0,0,0,12" />
                            </StackPanel>

                        </StackPanel>

                        <!-- Right Column -->
                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="16">
                            <!-- Logistics Section -->
                            <StackPanel Style="{StaticResource CardStackStyle}">
                                <StackPanel>
                                    <TextBlock Text="Logistics" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="Determine the shipping reality." 
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                
                            </StackPanel>
                            
                        </StackPanel>
                    </Grid>
                    
                </StackPanel>
            </Grid>
            
        </ScrollViewer>

    </Grid>
</Page>
