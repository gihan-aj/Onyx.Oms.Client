<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Onyx.Oms.Client.Desktop.Features.Products.List.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Onyx.Oms.Client.Desktop.Features.Products.List"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:controls="using:Onyx.Oms.Client.Desktop.Features.Products.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header  and Filters -->
        <Grid Grid.Row="0" Padding="16,12"
              ColumnSpacing="8" RowSpacing="12"
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Top Row: Title, Search, Actions -->
            <TextBlock Grid.Row="0" Grid.Column="0" 
                       Text="Products" 
                       Style="{StaticResource SubtitleTextBlockStyle}" 
                       VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0"/>

            <AutoSuggestBox Grid.Row="0" Grid.Column="1"
                            PlaceholderText="Search products by SKU or Name..."
                            QueryIcon="Find"
                            Width="320"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QuerySubmitted="AutoSuggestBox_QuerySubmitted"/>

            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Style="{StaticResource SubtleButtonStyle}" ToolTipService.ToolTip="Refresh Data"
                        Command="{x:Bind ViewModel.RefreshCommand}">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                </Button>

                <AppBarSeparator/>

                <Button Style="{StaticResource AccentButtonStyle}" 
                        Command="{x:Bind ViewModel.NewProductCommand}"
                        IsEnabled="{x:Bind ViewModel.CanCreateProducts}"
                        Visibility="{x:Bind ViewModel.CanCreateProducts, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="New Product" />
                        </StackPanel>
                    </Button.Content> 
                </Button>
            </StackPanel>

            <!-- Filters -->
            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="16">
                <controls:ProductCategoryPicker x:Name="CategoryPicker"
                                                IsLeafOnly="False"
                                                Width="300"
                                                SelectedCategory="{x:Bind ViewModel.SelectedProductCategory, Mode=TwoWay}"/>

                <ComboBox ItemsSource="{x:Bind ViewModel.StatusOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedStatus, Mode=TwoWay}"
                          PlaceholderText="Status"
                          Width="120"/>

                <ComboBox ItemsSource="{x:Bind ViewModel.StockStatusOptions}"
                          SelectedItem="{x:Bind ViewModel.SelectedStockStatus, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          PlaceholderText="Stock Status"
                          Width="140"/>

                <Button Content="Clear Filters" Style="{StaticResource SubtleButtonStyle}"
                        Command="{x:Bind ViewModel.ClearFiltersCommand}"/>
            </StackPanel>
        </Grid>

        <!-- DataGrid Constraints Wrapper -->
        <Grid Grid.Row="1" x:Name="TableContainer">

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Enabled"
                          VerticalScrollBarVisibility="Disabled"
                          VerticalScrollMode="Disabled">
                          
                <toolkit:DataGrid x:Name="ProductsDataGrid"
                                  Width="{Binding ActualWidth, ElementName=TableContainer}"
                                  MinWidth="1150"
                                  ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  HeadersVisibility="Column"
                                  CanUserSortColumns="True"
                                  Sorting="ProductsDataGrid_Sorting"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Hidden"
                                  BorderThickness="0"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{ThemeResource LayerFillColorDefaultBrush}">

                    <toolkit:DataGrid.RowStyle>
                        <Style TargetType="toolkit:DataGridRow">
                            <Setter Property="ContextFlyout">
                                <Setter.Value>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="View Details" Icon="View" Click="ViewMenuItem_Click" />
                                        
                                        <MenuFlyoutSeparator />

                                        <MenuFlyoutItem Text="Edit" Icon="Edit" Click="EditMenuItem_Click"
                                                        IsEnabled="{Binding CanEdit}" />

                                        <MenuFlyoutItem Text="Activate" Icon="Play" Click="ActivateMenuItem_Click" 
                                                        Visibility="{Binding IsActive, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                                        IsEnabled="{Binding CanActivate}" />

                                        <MenuFlyoutItem Text="Deactivate" Icon="Pause" Click="DeactivateMenuItem_Click"
                                                        Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        IsEnabled="{Binding CanDeactivate}" />
                                    </MenuFlyout>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </toolkit:DataGrid.RowStyle>

                <toolkit:DataGrid.Columns>

                    <!-- Image Preview -->
                    <toolkit:DataGridTemplateColumn Header="Preview"
                                                    HeaderStyle="{StaticResource CenteredHeaderStyle}"
                                                    Width="108" MinWidth="108" CanUserSort="False">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="local:ProductGridItem">
                                <Grid Width="84" Height="84" CornerRadius="4" Background="{ThemeResource LayerFillColorAltBrush}" BorderThickness="1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" Margin="12,4">
                                    <FontIcon Glyph="&#xE8B9;" FontSize="16" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <Image Source="{x:Bind MainImageSource, Mode=OneWay}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>

                    <!-- Name -->
                    <toolkit:DataGridTextColumn Header="Name" 
                                                Binding="{Binding Name}" Tag="name" 
                                                Width="*" MinWidth="200" 
                                                FontWeight="SemiBold"
                                                HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" 
                                                ElementStyle="{StaticResource LeftAlignedCellStyle}" />

                    <!-- SKU -->
                    <toolkit:DataGridTextColumn Header="SKU" 
                                                Binding="{Binding BaseSku}" 
                                                Tag="baseSku" 
                                                Width="Auto" MinWidth="120" FontFamily="Consolas" 
                                                HeaderStyle="{StaticResource LeftAlignedHeaderStyle}" 
                                                ElementStyle="{StaticResource LeftAlignedCellStyle}" />

                    <!-- Category -->
                    <toolkit:DataGridTemplateColumn Header="Category" Tag="category" Width="*" MinWidth="180" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="local:ProductGridItem">
                                <StackPanel VerticalAlignment="Center" Margin="12,4">
                                    <TextBlock Text="{x:Bind CategoryName}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind CategoryPath}" FontSize="12" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>

                    <!-- Price -->
                    <toolkit:DataGridTemplateColumn Header="Base Price" Tag="basePrice" Width="Auto" MinWidth="120" HeaderStyle="{StaticResource RightAlignedHeaderStyle}">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="local:ProductGridItem">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind BasePriceCurrency}" 
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind BasePriceAmount}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>

                    <!-- Stock -->
                    <toolkit:DataGridTemplateColumn Header="Stock" Width="Auto" MinWidth="140" HeaderStyle="{StaticResource LeftAlignedHeaderStyle}">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="local:ProductGridItem">
                                <StackPanel VerticalAlignment="Center" Margin="12,4">

                                    <Border Style="{StaticResource StatusBadgeStyle}" 
                                            Background="{x:Bind AvailableQuantity, Mode=OneWay, Converter={StaticResource StockBackgroundConverter}}" 
                                            HorizontalAlignment="Left" Margin="0,0,0,4">
                                        <StackPanel Orientation="Horizontal" Spacing="6" Padding="4,2">
                                            <FontIcon Glyph="{x:Bind AvailableQuantity, Mode=OneWay, Converter={StaticResource StockIconConverter}}" 
                                                      FontSize="12" 
                                                      Foreground="{x:Bind AvailableQuantity, Mode=OneWay, Converter={StaticResource StockForegroundConverter}}"/>
                                            <TextBlock Style="{StaticResource StatusBadgeTextStyle}" 
                                                       Foreground="{x:Bind AvailableQuantity, Mode=OneWay, Converter={StaticResource StockForegroundConverter}}">
                                                  <Run Text="{x:Bind AvailableQuantity, Mode=OneWay}" />
                                                  <Run Text=" Available" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" Margin="4,2,0,0">
                                        <Run Text="{x:Bind StockOnHand}" />
                                        <Run Text=" On Hand" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>

                    <!-- Variants -->
                    <toolkit:DataGridTextColumn Header="Variants" 
                                                Binding="{Binding HasVariantsText}" 
                                                Tag="hasVariants" Width="110" MinWidth="100" 
                                                HeaderStyle="{StaticResource CenteredHeaderStyle}" 
                                                ElementStyle="{StaticResource CenteredCellStyle}" />

                    <!-- Status Badge -->
                    <toolkit:DataGridTemplateColumn Header="Status" Tag="isActive" Width="100" MinWidth="100" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="local:ProductGridItem">
                                <Border Style="{StaticResource StatusBadgeStyle}" 
                                        HorizontalAlignment="Center"
                                        Background="{x:Bind IsActive, Converter={StaticResource StatusBackgroundConverter}}">
                                    <TextBlock Text="{x:Bind IsActive, Converter={StaticResource StatusTextConverter}}"
                                               Style="{StaticResource StatusBadgeTextStyle}"
                                               Foreground="{x:Bind IsActive, Converter={StaticResource StatusForegroundConverter}}" />
                                </Border>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>

                    <!-- Row Actions "Meatballs" Menu -->
                    <toolkit:DataGridTemplateColumn Width="80" HeaderStyle="{StaticResource CenteredHeaderStyle}">
                        <toolkit:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="local:ProductGridItem">
                                <Button Style="{StaticResource SubtleButtonStyle}" 
                                        Background="Transparent"
                                        HorizontalAlignment="Stretch" 
                                        VerticalAlignment="Stretch"
                                        ToolTipService.ToolTip="Actions"
                                        Tapped="OnActionButtonTapped">

                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE712;" />

                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem x:Name="ViewMenuItem" Text="View Details" Icon="View" Click="ViewMenuItem_Click" />

                                            <MenuFlyoutSeparator />

                                            <MenuFlyoutItem x:Name="EditMenuItem" Text="Edit" Icon="Edit" Click="EditMenuItem_Click"
                                                            IsEnabled="{x:Bind CanEdit}" />

                                            <MenuFlyoutItem x:Name="ActivateMenuItem" Text="Activate" Icon="Play" Click="ActivateMenuItem_Click" 
                                                            Visibility="{x:Bind IsActive, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                                                            IsEnabled="{x:Bind CanActivate}" />

                                            <MenuFlyoutItem x:Name="DeactivateMenuItem" Text="Deactivate" Icon="Pause" Click="DeactivateMenuItem_Click"
                                                            Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                                            IsEnabled="{x:Bind CanDeactivate}" />
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </DataTemplate>
                        </toolkit:DataGridTemplateColumn.CellTemplate>
                    </toolkit:DataGridTemplateColumn>

                </toolkit:DataGrid.Columns>
                
            </toolkit:DataGrid>
            </ScrollViewer>

            <!-- Loading Indicator -->
            <Grid Opacity="0.8" 
                  Visibility="{x:Bind ViewModel.IsListLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ProgressRing IsActive="True" Width="48" Height="48" />
            </Grid>

            <!-- No Data Message -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                        Visibility="{x:Bind ViewModel.HasNoData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <FontIcon Glyph="&#xE719;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock HorizontalAlignment="Center" Text="No products found." 
                           Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Content="Clear Filters" 
                        Command="{x:Bind ViewModel.ClearFiltersCommand}" 
                        Style="{StaticResource DefaultButtonStyle}" 
                        HorizontalAlignment="Center"/>
            </StackPanel>
            
        </Grid>

        <!-- Pagination -->
        <Grid Grid.Row="2"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Padding="16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Rows Per Page (Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Rows per page:" VerticalAlignment="Center" 
                           Style="{StaticResource CaptionTextBlockStyle}" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.PageSizes}" 
                          SelectedItem="{x:Bind ViewModel.PageSize, Mode=TwoWay}"
                          Style="{StaticResource DefaultComboBoxStyle}"
                          MinWidth="80" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Page Summary (Center) -->
            <TextBlock Grid.Column="1" 
                       Text="{x:Bind ViewModel.PageSummary, Mode=OneWay}" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}" />

            <!-- Navigation Buttons (Right) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button Style="{StaticResource SubtleButtonStyle}" 
                        Command="{x:Bind ViewModel.PreviousPageCommand}" 
                        IsEnabled="{x:Bind ViewModel.HasPreviousPage, Mode=OneWay}" 
                        ToolTipService.ToolTip="Previous Page">
                    <FontIcon Glyph="&#xE76B;" FontSize="12" />
                </Button>
                <Button Style="{StaticResource SubtleButtonStyle}" 
                        Command="{x:Bind ViewModel.NextPageCommand}" 
                        IsEnabled="{x:Bind ViewModel.HasNextPage, Mode=OneWay}" 
                        ToolTipService.ToolTip="Next Page">
                    <FontIcon Glyph="&#xE76C;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
